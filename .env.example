# Variáveis de Ambiente para o Servidor Node.js
JWT_SECRET=seu_jwt_secret_aqui
PORT=3000

# Variáveis de Conexão do TiDB Cloud
# IMPORTANTE: O DB_USER deve incluir o prefixo do cluster
# Formato: PREFIXO.root (obtenha no console do TiDB Cloud)
DB_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
DB_USER=SEU_PREFIXO.root
DB_PASSWORD=sua_senha_aqui
DB_NAME=test
DB_PORT=4000
