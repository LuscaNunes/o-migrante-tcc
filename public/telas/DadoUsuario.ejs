<!DOCTYPE html>
<html class="scroll-smooth" lang="pt-BR">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=yes">
    <meta charset="utf-8" />
    <title>Perfil do Usuário</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; }
        body { 
            font-family: 'Inter', sans-serif; 
            margin: 0; 
            padding: 0; 
            overflow-x: hidden;
            -webkit-overflow-scrolling: touch; /* Smooth scroll iOS */
        }

        /* === SIDEBAR MOBILE === */
        #sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 85vw; /* Mais largo no mobile */
            max-width: 320px;
            height: 100vh;
            background: white;
            z-index: 1000;
            transform: translateX(-100%);
            transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            box-shadow: 4px 0 20px rgba(0,0,0,0.15);
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
        }

        #sidebar.sidebar-open {
            transform: translateX(0);
        }

        /* === OVERLAY MOBILE MELHORADO === */
        .sidebar-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.6);
            z-index: 999;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }

        .sidebar-overlay.active {
            opacity: 1;
            visibility: visible;
        }

        /* === BOTÃO MOBILE MAIOR === */
        .mobile-menu-button {
            position: fixed;
            top: 16px; /* Mais espaço da borda */
            left: 16px;
            z-index: 1001;
            width: 56px; /* Tamanho WCAG */
            height: 56px;
            background: white;
            border: none;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* === MAIN CONTENT MOBILE === */
        .main-content-container {
            min-height: 100vh;
            padding: 80px 16px 24px; /* Espaço pro botão fixo */
            transition: all 0.3s ease;
            width: 100%;
        }

        /* === DESKTOP === */
        @media (min-width: 768px) {
            .main-content-container {
                padding: 24px;
                margin-left: 0;
            }
            #sidebar {
                transform: translateX(0) !important;
                position: relative;
                z-index: 10;
                width: 16rem;
            }
            .mobile-menu-button,
            .sidebar-overlay {
                display: none !important;
            }
        }

        /* === BOTÕES TOUCH FRIENDLY === */
        @media (max-width: 767px) {
            button, 
            .action-button,
            .tab,
            .tab-mobile,
            a[href] {
                min-height: 48px !important;
                min-width: 48px !important;
                padding: 12px 16px !important;
            }
            
            .tabs-container {
                padding-bottom: 8px;
            }
            
            .tab {
                flex: 1;
                text-align: center;
                font-size: 14px;
                padding: 12px 8px !important;
            }
        }

        /* === LAYOUT MOBILE SIMPLIFICADO === */
        @media (max-width: 1023px) {
            .main-content-wrapper {
                display: flex;
                flex-direction: column;
                gap: 24px;
            }
        }

        /* === CARDS MOBILE === */
        @media (max-width: 640px) {
            .profile-card {
                padding: 24px 20px !important;
            }
            
            .main-content-container {
                padding: 80px 12px 20px;
            }
        }

        /* === TABS RESPONSIVAS === */
        .tabs-container {
            display: flex;
            overflow-x: auto;
            scrollbar-width: none;
            padding: 8px 0;
            gap: 4px;
        }

        .tabs-container::-webkit-scrollbar { display: none; }

        /* === PROGRESS BARS === */
        .tab-content {
            max-height: 300px;
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
        }

        /* === BOTÕES RESPONSIVOS === */
        .mobile-action-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin: 24px 0;
        }

        .mobile-action-grid a {
            padding: 16px 12px;
            font-size: 14px;
            border-radius: 12px;
            text-align: center;
            min-height: 56px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
        }

        /* === SIDEBAR LINKS MOBILE === */
        .sidebar-link {
            padding: 16px 20px !important;
            margin-bottom: 4px !important;
            border-radius: 12px !important;
            font-size: 16px !important;
            min-height: 56px;
            display: flex;
            align-items: center;
        }

        /* === LOADING E ANIMATIONS === */
        @keyframes spin { to { transform: rotate(360deg); } }
        .loading { position: relative; pointer-events: none; opacity: 0.7; }
        .loading::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            top: 50%;
            left: 50%;
            margin-left: -10px;
            margin-top: -10px;
            border: 2px solid #fff;
            border-radius: 50%;
            border-top-color: transparent;
            animation: spin 0.6s linear infinite;
        }

        /* === PULL TO REFRESH === */
        .pull-to-refresh {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: 60px;
            background: linear-gradient(180deg, #2563EB, #1D4ED8);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            transform: translateY(-100%);
            transition: transform 0.3s ease;
            z-index: 100;
            font-weight: 600;
        }

        .pull-to-refresh.show { transform: translateY(0); }
    </style>
</head>

<body class="bg-gray-100">
