                </li>
                <li>
                    <a class="sidebar-link flex items-center text-gray-700 py-3 px-4 rounded-xl transition-all duration-200 hover:bg-blue-50 hover:text-blue-600 group bg-blue-50 text-blue-600" href="DadoUsuario.html">
