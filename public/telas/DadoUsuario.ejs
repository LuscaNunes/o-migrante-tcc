                        </div>
                        <div class="profile-stat-card bg-gradient-to-br from-blue-500 to-cyan-500 rounded-xl p-4 text-white text-center shadow">
                            <i class="fas fa-medal text-2xl text-yellow-300 mb-2"></i>
