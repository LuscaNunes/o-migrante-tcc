                            id="adminMenuButton">
                            <span class="flex items-center">
                                <i class="fas fa-cog mr-3 w-5 text-gray-400 group-hover:text-blue-600"></i>
                                <span class="font-medium">Administração</span>
                            </span>
                            <i class="fas fa-chevron-down ml-2 transition-transform duration-200" id="adminChevron"></i>
                        </button>
                        <ul class="hidden mt-2 bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden" id="adminMenuItems">
                            <li><a class="block px-4 py-3 hover:bg-blue-50 text-gray-700 transition" href="BuscaEdicaoUsuario.html">Usuários</a></li>
                            <li><a class="block px-4 py-3 hover:bg-blue-50 text-gray-700 transition" href="CaPerguntas.html">Cadastrar Níveis e Perguntas</a></li>
                            <li><a class="block px-4 py-3 hover:bg-blue-50 text-gray-700 transition" href="DadosFases.html">Dados das Fases</a></li>
