    <script>
        // === CONFIG API ===
        const API_BASE_URL = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
            ? `http://${window.location.hostname}:${window.location.port || 3000}`
            : 'https://o-migrante.onrender.com';

        let currentUserId = null;
        let isSidebarOpen = false;

        // === FEEDBACK ===
        function showFeedback(message, isError = false) {
            const feedback = document.createElement('div');
            feedback.className = `fixed bottom-6 left-1/2 -translate-x-1/2 -translate-y-1/2 px-8 py-4 rounded-2xl shadow-2xl z-[10001] text-white text-lg font-semibold max-w-[90vw] transform transition-all ${
                isError ? 'bg-red-500 animate-bounce' : 'bg-green-500'
            }`;
            feedback.textContent = message;
            document.body.appendChild(feedback);
            
            if ('vibrate' in navigator) {
                navigator.vibrate(isError ? [100, 50, 100] : 50);
            }
            
            setTimeout(() => {
                feedback.remove();
            }, 3500);
        }

        // === API HELPER ===
        async function apiCall(url, options = {}) {
            try {
                const response = await fetch(`${API_BASE_URL}${url}`, {
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json', ...options.headers },
                    ...options
                });
                return response;
            } catch (error) {
                console.error('API Error:', error);
                throw error;
            }
        }

        // === SIDEBAR MOBILE ===
        function initMobileSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebarOverlay');
            const menuBtn = document.getElementById('mobileMenuButton');
            const closeBtn = document.getElementById('closeSidebarMobile');

            function openSidebar() {
                sidebar.classList.add('sidebar-open');
                overlay.classList.add('active');
                document.body.style.overflow = 'hidden';
                isSidebarOpen = true;
            }

            function closeSidebar() {
                sidebar.classList.remove('sidebar-open');
                overlay.classList.remove('active');
                document.body.style.overflow = '';
                isSidebarOpen = false;
            }

            menuBtn?.addEventListener('click', openSidebar);
            overlay?.addEventListener('click', closeSidebar);
            closeBtn?.addEventListener('click', closeSidebar);

            // ESC fecha sidebar
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && isSidebarOpen) {
                    closeSidebar();
                }
            });

            // Fecha ao redimensionar para desktop
            window.addEventListener('resize', () => {
                if (window.innerWidth >= 768) closeSidebar();
            });
        }

        // === PULL TO REFRESH ===
        function initPullToRefresh() {
            let startY = 0;
            let startTime = 0;

            document.addEventListener('touchstart', (e) => {
                if (window.scrollY === 0) {
                    startY = e.touches[0].clientY;
                    startTime = Date.now();
                }
            }, { passive: true });

            document.addEventListener('touchend', (e) => {
                if (window.scrollY === 0) {
                    const endY = e.changedTouches[0].clientY;
                    const diffY = endY - startY;
                    const timeDiff = Date.now() - startTime;

                    if (diffY > 100 && timeDiff < 400) {
                        const refreshEl = document.getElementById('pullToRefresh');
                        refreshEl.classList.remove('hidden');
                        
                        setTimeout(() => {
                            window.location.reload();
                        }, 800);
                    }
                }
            }, { passive: true });
        }

        // === TABS ===
        function initTabs() {
            const tabs = {
                friends: document.getElementById('friendsTab'),
                requests: document.getElementById('requestsTab'),
                search: document.getElementById('searchUsersTab')
            };
            const contents = {
                friends: document.getElementById('friendsContent'),
                requests: document.getElementById('requestsContent'),
                search: document.getElementById('searchUsersContent')
            };

            Object.entries(tabs).forEach(([key, tab]) => {
                if (!tab) return;
                
                tab.addEventListener('click', () => {
                    // Remove active de todos
                    Object.values(tabs).forEach(t => t.classList.remove('active', 'bg-indigo-500', 'text-white'));
                    Object.values(contents).forEach(c => c.classList.add('hidden'));
                    
                    // Ativa atual
                    tab.classList.add('active', 'bg-indigo-500', 'text-white');
                    contents[key].classList.remove('hidden');
                    
                    // Carrega conteúdo
                    if (key === 'friends') carregarAmigos();
                    if (key === 'requests') carregarSolicitacoes();
                    if (key === 'search') initSearch();
                });
            });

            // Ativa primeira tab
            tabs.friends?.click();
        }

        // === LOAD USER DATA ===
        async function loadUserData() {
            try {
                const res = await apiCall('/auth/verifyToken');
                if (!res.ok) throw new Error('Não autenticado');
                
                const data = await res.json();
                if (!data.auth) throw new Error('Não autenticado');
                
                const user = data.user;
                currentUserId = user.id_usuario;
                
                document.getElementById('userName').textContent = user.nome || 'Usuário';
                document.getElementById('userEmail').textContent = user.email || 'Sem email';
                document.getElementById('fullName').textContent = user.nome || 'Usuário';
                document.getElementById('emailInfo').textContent = user.email || 'Sem email';
                document.getElementById('xpTotal').textContent = user.xp_total || 0;
                document.getElementById('accountType').textContent = user.tipo === 'admin' ? 'Administrador' : 'Usuário';
                
                const date = user.criado_em ? new Date(user.criado_em) : new Date();
                const formattedDate = date.toLocaleDateString('pt-BR');
                document.getElementById('registerDate').textContent = formattedDate;
                document.getElementById('userJoined').textContent = `Membro desde: ${formattedDate}`;
                
            } catch (error) {
                showFeedback('Erro ao carregar perfil', true);
                setTimeout(() => window.location.href = '/', 2000);
            }
        }

        // === PROGRESSO ===
        async function loadProgress() {
            try {
                const res = await apiCall('/progresso/detalhado');
                if (res.ok) {
                    const data = await res.json();
                    document.getElementById('niveisCompletos').textContent = 
                        Object.keys(data.niveisCompletos || {}).length;
                }
            } catch (error) {
                console.error('Erro progresso:', error);
            }
        }

        // === AMIGOS ===
        async function carregarAmigos() {
            const list = document.getElementById('friendsList');
            list.innerHTML = '<div class="text-center py-8 text-gray-500"><i class="fas fa-spinner fa-spin text-2xl mb-4"></i>Carregando...</div>';
            
            try {
                const res = await apiCall('/amizades/listar');
                const data = await res.json();
                list.innerHTML = '';
                
                if (data.amigos?.length) {
                    data.amigos.forEach(amigo => {
                        const div = document.createElement('div');
                        div.className = 'flex justify-between items-center p-6 bg-gray-50 rounded-2xl border';
                        div.innerHTML = `
                            <div>
                                <p class="font-bold text-lg text-gray-900">${amigo.nome}</p>
                                <p class="text-gray-500">${amigo.email}</p>
                            </div>
                            <button class="bg-red-100 text-red-700 px-6 py-3 rounded-xl font-semibold hover:bg-red-200 transition remove-friend" data-id="${amigo.id_amizade}">
                                Remover
                            </button>
                        `;
                        list.appendChild(div);
                    });
                    document.getElementById('friendsCount').textContent = `${data.amigos.length} amigo${data.amigos.length === 1 ? '' : 's'}`;
                } else {
                    list.innerHTML = '<div class="text-center py-12 text-gray-500"><i class="fas fa-users text-4xl mb-4"></i><p>Nenhum amigo ainda</p></div>';
                }
                
                // Event listeners
                document.querySelectorAll('.remove-friend').forEach(btn => {
                    btn.addEventListener('click', async (e) => {
                        await removerAmizade(e.target.dataset.id);
                    });
                });
                
            } catch (error) {
                list.innerHTML = '<div class="text-center py-8 text-red-500">Erro ao carregar amigos</div>';
            }
        }

        async function removerAmizade(id) {
            try {
                const res = await apiCall(`/amizades/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    showFeedback('Amigo removido!', false);
                    carregarAmigos();
                }
            } catch (error) {
                showFeedback('Erro ao remover', true);
            }
        }

        // === MODAL EDITAR ===
        function initEditModal() {
            const modal = document.getElementById('editModal');
            const form = document.getElementById('editProfileForm');
            const editBtn = document.getElementById('editProfileBtn');
            const closeBtns = document.querySelectorAll('#closeModalBtn, #cancelEditBtn');

            function openModal() {
                document.getElementById('editName').value = document.getElementById('fullName').textContent;
                document.getElementById('editEmail').value = document.getElementById('emailInfo').textContent;
                document.getElementById('editPassword').value = '';
                modal.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            }

            function closeModal() {
                modal.classList.add('hidden');
                document.body.style.overflow = '';
            }

            editBtn?.addEventListener('click', openModal);
            closeBtns.forEach(btn => btn.addEventListener('click', closeModal));

            // Clique fora fecha
            modal.addEventListener('click', (e) => {
                if (e.target === modal) closeModal();
            });

            form?.addEventListener('submit', async (e) => {
                e.preventDefault();
                const btn = e.target.querySelector('button[type="submit"]');
                const originalText = btn.innerHTML;
                btn.classList.add('loading');
                btn.disabled = true;

                const nome = document.getElementById('editName').value.trim();
                const email = document.getElementById('editEmail').value.trim();
                const senha = document.getElementById('editPassword').value.trim();

                const data = { nome };
                if (email !== document.getElementById('emailInfo').textContent) data.email = email;
                if (senha) data.senha = senha;

                try {
                    const res = await apiCall('/usuarios/atualizar', {
                        method: 'PUT',
                        body: JSON.stringify(data)
                    });
                    const result = await res.json();
                    
                    if (result.success) {
                        showFeedback('Perfil atualizado!', false);
                        closeModal();
                        loadUserData();
                    } else {
                        showFeedback(result.message || 'Erro ao atualizar', true);
                    }
                } catch (error) {
                    showFeedback('Erro de conexão', true);
                } finally {
                    btn.classList.remove('loading');
                    btn.disabled = false;
                    btn.innerHTML = originalText;
                }
            });
        }

        // === LOGOUT ===
        document.getElementById('logoutButton')?.addEventListener('click', async () => {
            try {
                await apiCall('/auth/logout', { method: 'POST' });
            } catch (error) {
                console.error('Logout error:', error);
            }
            window.location.href = '/';
        });

        // === INIT ===
        async function init() {
            initMobileSidebar();
            initPullToRefresh();
            initTabs();
            initEditModal();
            
            await loadUserData();
            await loadProgress();
            
            // Loading skeletons
            setTimeout(() => {
                document.querySelectorAll('[id*="Carregando"]').forEach(el => {
                    el.textContent = 'Não disponível';
                });
            }, 3000);
        }

        // Start app
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }
    </script>
</body>
</html>