    <script>
        const API_BASE_URL = (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') 
            ? `http://${window.location.hostname}:${window.location.port || 3000}` 
            : 'https://o-migrante.onrender.com';
        
        let currentUserId = null;

        // helpers
        function showFeedback(msg, isError = false) {
            const div = document.createElement('div');
            div.className = `fixed bottom-6 left-1/2 -translate-x-1/2 z-[1200] px-5 py-3 rounded-xl text-white font-medium text-center max-w-[85vw] shadow-lg ${isError ? 'bg-red-500' : 'bg-green-600'}`;
            div.innerText = msg;
            document.body.appendChild(div);
            setTimeout(() => div.remove(), 2800);
        }

        async function apiFetch(url, options = {}) {
            const res = await fetch(`${API_BASE_URL}${url}`, { credentials: 'include', headers: { 'Content-Type': 'application/json', ...options.headers }, ...options });
            return res;
        }

        async function checkAuth() {
            try {
                const res = await apiFetch('/auth/verifyToken');
                if (!res.ok) return null;
                const data = await res.json();
                return data.auth ? data.user : null;
            } catch(e) { return null; }
        }

        async function logout() {
            await apiFetch('/auth/logout', { method: 'POST' });
            localStorage.clear();
            window.location.href = '/';
        }

        // Carregar amigos
        async function loadFriends() {
            try {
                const res = await apiFetch('/amizades/listar');
                const data = await res.json();
                const amigos = data.amigos || [];
                const container = document.getElementById('friendsList');
                const countSpan = document.getElementById('friendsCount');
                if (amigos.length === 0) { container.innerHTML = '<div class="text-gray-400 text-center py-6">Nenhum amigo adicionado</div>'; countSpan.innerText = '0'; return; }
                countSpan.innerText = amigos.length;
                container.innerHTML = amigos.map(a => `<div class="friend-item flex justify-between items-center p-3 bg-gray-50 rounded-xl"><div><p class="font-medium">${escapeHtml(a.nome)}</p><p class="text-xs text-gray-500">${escapeHtml(a.email)}</p></div><button class="remove-friend bg-red-100 text-red-700 px-3 py-1.5 rounded-lg text-xs" data-id="${a.id_amizade}">Remover</button></div>`).join('');
                document.querySelectorAll('.remove-friend').forEach(btn => btn.addEventListener('click', async (e) => { await removeFriendship(btn.dataset.id); loadFriends(); }));
            } catch(e) { document.getElementById('friendsList').innerHTML = '<div class="text-red-400">Erro ao carregar</div>'; }
        }

        async function loadRequests() {
            try {
                const res = await apiFetch('/amizades/listar');
                const data = await res.json();
                const recebidas = data.pedidosPendentes || [];
                const enviadas = data.solicitacoesEnviadas || [];
                const receivedDiv = document.getElementById('receivedRequestsList');
                const sentDiv = document.getElementById('sentRequestsList');
                if(recebidas.length) receivedDiv.innerHTML = recebidas.map(r => `<div class="request-item flex justify-between items-center p-3 bg-gray-50 rounded-lg"><div><p class="font-medium">${escapeHtml(r.nome)}</p><p class="text-xs">${escapeHtml(r.email)}</p></div><div class="flex gap-2"><button class="accept-req bg-green-100 text-green-700 px-3 py-1 rounded text-xs" data-id="${r.id_amizade}">Aceitar</button><button class="reject-req bg-red-100 text-red-700 px-3 py-1 rounded text-xs" data-id="${r.id_amizade}">Recusar</button></div></div>`).join('') : receivedDiv.innerHTML = '<div class="text-gray-400 text-center py-3">Nenhuma solicitação</div>';
                if(enviadas.length) sentDiv.innerHTML = enviadas.map(s => `<div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg"><div><p class="font-medium">${escapeHtml(s.nome)}</p><p class="text-xs">${escapeHtml(s.email)}</p></div><button class="cancel-req bg-yellow-100 text-yellow-700 px-3 py-1 rounded text-xs" data-id="${s.id_amizade}">Cancelar</button></div>`).join('') : sentDiv.innerHTML = '<div class="text-gray-400 text-center py-3">Nenhuma enviada</div>';
                attachRequestActions();
            } catch(e) { console.error(e); }
        }

        function attachRequestActions() {
            document.querySelectorAll('.accept-req').forEach(btn => btn.addEventListener('click', async (e) => { await updateFriendship(btn.dataset.id, 'aceito'); loadRequests(); loadFriends(); }));
            document.querySelectorAll('.reject-req').forEach(btn => btn.addEventListener('click', async (e) => { await updateFriendship(btn.dataset.id, 'recusado'); loadRequests(); }));
            document.querySelectorAll('.cancel-req').forEach(btn => btn.addEventListener('click', async (e) => { await cancelRequest(btn.dataset.id); loadRequests(); }));
        }

        async function updateFriendship(id, status) { await apiFetch(`/amizades/${id}/atualizar`, { method: 'PATCH', body: JSON.stringify({ status }) }); showFeedback(status === 'aceito' ? 'Amizade aceita!' : 'Solicitação recusada', false); }
        async function cancelRequest(id) { await apiFetch(`/amizades/${id}`, { method: 'DELETE' }); showFeedback('Cancelado', false); }
        async function removeFriendship(id) { await apiFetch(`/amizades/${id}`, { method: 'DELETE' }); showFeedback('Amizade removida', false); }

        // Pesquisa
        const searchInput = document.getElementById('searchInput');
        if(searchInput) searchInput.addEventListener('input', async (e) => {
            const term = e.target.value.trim();
            const resultsDiv = document.getElementById('searchResults');
            if(term.length < 2) { resultsDiv.innerHTML = '<div class="text-gray-400 text-center">Digite pelo menos 2 caracteres</div>'; return; }
            try {
                const res = await apiFetch(`/amizades/pesquisar?termo=${encodeURIComponent(term)}`);
                const { usuarios } = await res.json();
                if(!usuarios?.length) { resultsDiv.innerHTML = '<div class="text-gray-400 text-center">Nenhum usuário encontrado</div>'; return; }
                resultsDiv.innerHTML = usuarios.filter(u => u.id_usuario != currentUserId).map(u => `<div class="flex justify-between items-center p-3 bg-gray-50 rounded-xl"><div><p class="font-medium">${escapeHtml(u.nome)}</p><p class="text-xs">${escapeHtml(u.email)}</p></div><button class="send-friend-request bg-indigo-100 text-indigo-700 px-3 py-1.5 rounded-lg text-xs" data-id="${u.id_usuario}">Adicionar</button></div>`).join('');
                document.querySelectorAll('.send-friend-request').forEach(btn => btn.addEventListener('click', async (e) => { await sendFriendRequest(btn.dataset.id); searchInput.value = ''; resultsDiv.innerHTML = '<div class="text-gray-400">Pedido enviado!</div>'; }));
            } catch(err) { resultsDiv.innerHTML = '<div class="text-red-400">Erro na busca</div>'; }
        });

        async function sendFriendRequest(idUsuario2) { const res = await apiFetch('/amizades/criar', { method: 'POST', body: JSON.stringify({ id_usuario2: idUsuario2 }) }); const data = await res.json(); if(data.success) showFeedback('Solicitação enviada!', false); else showFeedback(data.message || 'Erro', true); }

        function escapeHtml(str) { if(!str) return ''; return str.replace(/[&<>]/g, function(m){ if(m === '&') return '&amp;'; if(m === '<') return '&lt;'; if(m === '>') return '&gt;'; return m;}); }

        // Progresso detalhado
        async function loadDetailedProgress() {
            try {
                const res = await apiFetch('/progresso/detalhado');
                if(res.ok) { const data = await res.json(); const qtd = Object.keys(data.niveisCompletos || {}).length; document.getElementById('niveisCompletos').innerText = qtd; }
                else document.getElementById('niveisCompletos').innerText = '0';
            } catch(e) { document.getElementById('niveisCompletos').innerText = '0'; }
        }

        async function loadNiveisProgress() {
            const container = document.getElementById('progressoNiveis');
            try {
                const niveisRes = await apiFetch('/niveis/ativos');
                if(!niveisRes.ok) throw new Error();
                const { niveis } = await niveisRes.json();
                if(!niveis?.length) { container.innerHTML = '<div class="text-center text-gray-400">Nenhum nível ativo</div>'; return; }
                let html = '';
                for(let nivel of niveis) {
                    const botoesRes = await apiFetch(`/progresso/botoes/${nivel.id}`);
                    let currentButton = 0;
                    if(botoesRes.ok) { const { botoesCompletos } = await botoesRes.json(); const ordens = Object.keys(botoesCompletos).map(Number).sort((a,b)=>b-a); for(let ord of ordens) { if(botoesCompletos[ord].concluido || botoesCompletos[ord].xp_ganho>0){ currentButton=ord; break; } } }
                    const percent = Math.round((currentButton/12)*100);
                    html += `<div class="bg-gray-50 p-4 rounded-xl shadow-sm"><div class="flex justify-between mb-1"><span class="font-semibold text-indigo-800">Nível ${nivel.id}: ${escapeHtml(nivel.titulo)}</span><span class="text-sm">${currentButton}/12</span></div><p class="text-xs text-gray-500 mb-2">${escapeHtml(nivel.descricao||'')}</p><div class="w-full bg-gray-200 rounded-full h-2.5"><div class="bg-indigo-500 h-2.5 rounded-full progress-bar-fill" style="width: ${percent}%"></div></div></div>`;
                }
                container.innerHTML = html;
            } catch(e) { container.innerHTML = '<div class="text-red-400 text-center">Falha ao carregar progresso</div>'; }
        }

        // Tabs interface
        function initTabs() {
            const tabs = document.querySelectorAll('.tab-btn');
            const panels = { friends: document.getElementById('friendsPanel'), requests: document.getElementById('requestsPanel'), search: document.getElementById('searchPanel') };
            function activateTab(tabId) {
                Object.values(panels).forEach(p => p.classList.add('hidden'));
                panels[tabId].classList.remove('hidden');
                tabs.forEach(t => { t.classList.remove('active', 'border-b-2', 'border-indigo-600', 'text-indigo-700'); t.classList.add('text-gray-600'); });
                const activeTabBtn = document.querySelector(`.tab-btn[data-tab="${tabId}"]`);
                activeTabBtn.classList.add('active', 'border-b-2', 'border-indigo-600', 'text-indigo-700');
                if(tabId === 'friends') loadFriends();
                if(tabId === 'requests') loadRequests();
            }
            tabs.forEach(tab => tab.addEventListener('click', (e) => { const tabId = tab.getAttribute('data-tab'); if(tabId) activateTab(tabId); }));
           