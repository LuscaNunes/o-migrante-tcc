                            <button id="logoutButton" class="flex-1 sm:flex-none bg-red-500 hover:bg-red-600 text-white font-semibold py-2.5 px-4 rounded-xl transition flex items-center justify-center gap-2 touch-button"><i class="fas fa-sign-out-alt"></i> Sair</button>
                        </div>
                    </div>

                    <!-- Cards de estatísticas (XP / Níveis) -->
                    <div class="grid grid-cols-2 gap-4 mt-6">
                        <div class="profile-stat-card bg-gradient-to-br from-indigo-500 to-indigo-600 rounded-xl p-4 text-white text-center shadow">
                            <i class="fas fa-star text-2xl text-yellow-300 mb-2"></i>
