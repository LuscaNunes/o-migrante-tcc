    <!-- Modal de edição de perfil -->
    <div id="editModal" class="fixed inset-0 bg-black/50 z-[1100] flex items-center justify-center hidden p-4">
        <div class="bg-white rounded-2xl w-full max-w-md shadow-xl modal-content">
            <div class="flex justify-between items-center p-5 border-b"><h3 class="text-xl font-bold">Editar Perfil</h3><button id="closeModalBtn" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times text-xl"></i></button></div>
            <form id="editProfileForm" class="p-5 space-y-4">
                <div><label class="block text-gray-700 text-sm font-medium mb-1">Nome completo</label><input id="editName" type="text" class="w-full border rounded-xl px-4 py-2.5"><p id="editNameError" class="text-red-500 text-xs hidden">Nome obrigatório</p></div>
                <div><label class="block text-gray-700 text-sm font-medium mb-1">E-mail</label><input id="editEmail" type="email" class="w-full border rounded-xl px-4 py-2.5"><p id="editEmailError" class="text-red-500 text-xs hidden">E-mail inválido</p></div>
                <div><label class="block text-gray-700 text-sm font-medium mb-1">Nova senha (opcional)</label><input id="editPassword" type="password" class="w-full border rounded-xl px-4 py-2.5"><p id="editPasswordError" class="text-red-500 text-xs hidden">Mínimo 6 caracteres</p></div>
                <div class="flex justify-end gap-3 pt-2"><button type="button" id="cancelEditBtn" class="px-5 py-2.5 border rounded-xl">Cancelar</button><button type="submit" class="bg-indigo-600 text-white px-5 py-2.5 rounded-xl">Salvar</button></div>
            </form>
        </div>
