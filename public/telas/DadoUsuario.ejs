<!DOCTYPE html>
<html class="scroll-smooth" lang="pt-BR">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0, viewport-fit=cover" name="viewport" />
    <title>Perfil do Usuário</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
    <style>
        :root {
            --sidebar-w: 16rem;
            --blue: #2563EB;
            --blue-light: #EFF6FF;
            --blue-dark: #1D4ED8;
            --text: #111827;
            --muted: #6B7280;
            --bg: #F3F6FB;
            --card: #ffffff;
            --border: #E5E7EB;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            overflow-x: hidden;
        }

        h1, h2, h3 { font-family: 'Sora', sans-serif; }

        /* ─── SIDEBAR ─────────────────────────────────── */
        #sidebar {
            position: fixed;
            top: 0; left: 0;
            width: var(--sidebar-w);
            height: 100dvh;
            background: var(--card);
            border-right: 1px solid var(--border);
            z-index: 50;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            transition: transform 0.3s cubic-bezier(.4,0,.2,1);
        }

        /* Mobile: escondida por padrão */
        @media (max-width: 767px) {
            #sidebar { transform: translateX(-100%); box-shadow: 4px 0 24px rgba(0,0,0,.12); }
            #sidebar.open { transform: translateX(0); }
        }

        /* Desktop: sempre visível */
        @media (min-width: 768px) {
            #sidebar { transform: translateX(0) !important; }
        }

        /* ─── OVERLAY ─────────────────────────────────── */
        #overlay {
            position: fixed; inset: 0;
            background: rgba(0,0,0,.45);
            z-index: 45;
            opacity: 0; pointer-events: none;
            transition: opacity 0.3s ease;
        }
        #overlay.active { opacity: 1; pointer-events: all; }

        /* ─── LAYOUT ROOT ──────────────────────────────── */
        #app {
            min-height: 100dvh;
            display: flex;
            flex-direction: column;
        }

        /* Desktop: deslocar conteúdo pela largura da sidebar */
        @media (min-width: 768px) {
            #app { margin-left: var(--sidebar-w); }
        }

        /* ─── TOP BAR (mobile only) ────────────────────── */
        #topbar {
            display: none;
            position: sticky;
            top: 0; z-index: 40;
            background: var(--card);
            border-bottom: 1px solid var(--border);
            padding: 0.75rem 1rem;
            align-items: center;
            gap: 0.75rem;
        }

        @media (max-width: 767px) {
            #topbar { display: flex; }
        }

        #topbar .logo-text { font-family: 'Sora', sans-serif; font-weight: 700; color: var(--blue); font-size: 1.1rem; }

        /* ─── MAIN CONTENT ─────────────────────────────── */
        #main {
            flex: 1;
            padding: 1.5rem 1rem;
        }

        @media (min-width: 640px) { #main { padding: 2rem 1.5rem; } }
        @media (min-width: 1024px) { #main { padding: 2.5rem 2rem; } }

        /* Two-column layout em telas grandes */
        .content-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.5rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        @media (min-width: 1100px) {
            .content-grid { grid-template-columns: 1fr 22rem; }
        }

        /* ─── CARDS ────────────────────────────────────── */
        .card {
            background: var(--card);
            border-radius: 1rem;
            box-shadow: 0 1px 4px rgba(0,0,0,.07), 0 4px 16px rgba(37,99,235,.06);
            padding: 1.5rem;
        }

        /* ─── PROFILE HEADER ───────────────────────────── */
        .profile-header {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid var(--border);
            margin-bottom: 1.5rem;
        }

        @media (min-width: 480px) {
            .profile-header {
                flex-direction: row;
                align-items: center;
                justify-content: space-between;
            }
        }

        .profile-identity { display: flex; align-items: center; gap: 1rem; flex: 1; min-width: 0; }

        .avatar-wrap { position: relative; flex-shrink: 0; }
        .avatar-wrap img {
            width: 4.5rem; height: 4.5rem;
            border-radius: 50%;
            border: 3px solid var(--blue);
            object-fit: cover;
        }
        @media (min-width: 480px) {
            .avatar-wrap img { width: 5.5rem; height: 5.5rem; }
        }
        .avatar-btn {
            position: absolute; bottom: 0; right: 0;
            background: var(--blue); color: white;
            border: none; border-radius: 50%;
            width: 1.75rem; height: 1.75rem;
            display: flex; align-items: center; justify-content: center;
            font-size: .75rem; cursor: pointer;
            box-shadow: 0 2px 6px rgba(37,99,235,.4);
        }

        .profile-name { font-size: clamp(1.1rem, 4vw, 1.5rem); font-weight: 700; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .profile-email { color: var(--blue); font-size: .9rem; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .profile-since { color: var(--muted); font-size: .8rem; margin-top: 2px; }

        .profile-actions {
            display: flex;
            gap: .625rem;
            flex-wrap: wrap;
        }

        @media (max-width: 479px) {
            .profile-actions { width: 100%; }
            .profile-actions .btn { flex: 1; justify-content: center; }
        }

        /* ─── BUTTONS ──────────────────────────────────── */
        .btn {
            display: inline-flex; align-items: center; gap: .4rem;
            padding: .5rem 1rem;
            border-radius: .625rem;
            font-size: .875rem; font-weight: 600;
            border: none; cursor: pointer;
            transition: all .18s ease;
            text-decoration: none;
            white-space: nowrap;
        }
        .btn-primary { background: var(--blue); color: white; }
        .btn-primary:hover { background: var(--blue-dark); transform: translateY(-1px); }
        .btn-danger { background: #FEE2E2; color: #DC2626; }
        .btn-danger:hover { background: #FECACA; }

        /* ─── STATS GRID ───────────────────────────────── */
        .stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .stat-card {
            border-radius: .875rem;
            padding: 1.25rem 1rem;
            text-align: center;
            color: white;
        }
        .stat-card.xp { background: linear-gradient(135deg, #4F46E5, #2563EB); }
        .stat-card.niveis { background: linear-gradient(135deg, #0EA5E9, #06B6D4); }
        .stat-card i { font-size: 1.75rem; opacity: .9; margin-bottom: .5rem; }
        .stat-card .stat-label { font-size: .8rem; opacity: .85; font-weight: 500; }
        .stat-card .stat-value { font-size: clamp(1.4rem, 5vw, 2rem); font-weight: 700; font-family: 'Sora', sans-serif; }

        /* ─── PROGRESS SECTION ─────────────────────────── */
        #progressoNiveis { display: flex; flex-direction: column; gap: .875rem; }

        .nivel-card {
            background: white;
            border: 1px solid #E0E7FF;
            border-radius: .875rem;
            padding: 1rem 1.25rem;
            transition: box-shadow .2s;
        }
        .nivel-card:hover { box-shadow: 0 4px 20px rgba(79,70,229,.12); }

        .nivel-header { display: flex; justify-content: space-between; align-items: flex-start; gap: .5rem; margin-bottom: .375rem; flex-wrap: wrap; }
        .nivel-title { font-weight: 600; color: #4338CA; font-size: .95rem; }
        .nivel-count { font-size: .8rem; color: var(--blue); font-weight: 600; white-space: nowrap; }
        .nivel-desc { font-size: .82rem; color: var(--muted); margin-bottom: .625rem; line-height: 1.4; }

        .progress-track { background: #E0E7FF; border-radius: 99px; height: .625rem; overflow: hidden; }
        .progress-fill {
            height: 100%; border-radius: 99px;
            background: linear-gradient(90deg, #4F46E5, #2563EB);
            animation: fillBar 1.4s ease forwards;
        }
        @keyframes fillBar { from { width: 0; } to { width: var(--pct); } }

        /* ─── TABS ─────────────────────────────────────── */
        .tabs-bar {
            display: flex;
            border-bottom: 2px solid var(--border);
            margin-bottom: 1.25rem;
            overflow-x: auto;
            scrollbar-width: none;
            -ms-overflow-style: none;
        }
        .tabs-bar::-webkit-scrollbar { display: none; }

        .tab-btn {
            flex-shrink: 0;
            padding: .625rem 1.1rem;
            font-size: .875rem; font-weight: 500;
            color: var(--muted);
            border: none; background: none; cursor: pointer;
            border-bottom: 2px solid transparent;
            margin-bottom: -2px;
            transition: all .18s;
            white-space: nowrap;
        }
        .tab-btn.active { color: var(--blue); border-bottom-color: var(--blue); font-weight: 700; }

        .tab-panel { display: none; }
        .tab-panel.active { display: block; }

        /* ─── FRIEND ITEMS ─────────────────────────────── */
        .friend-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: .75rem;
            padding: .875rem 1rem;
            background: var(--bg);
            border-radius: .75rem;
            border: 1px solid var(--border);
            margin-bottom: .625rem;
        }
        .friend-item:last-child { margin-bottom: 0; }
        .friend-info { min-width: 0; }
        .friend-name { font-weight: 600; font-size: .9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .friend-email { font-size: .78rem; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .friend-actions { display: flex; gap: .5rem; flex-shrink: 0; }

        .btn-sm {
            padding: .35rem .75rem;
            font-size: .78rem; font-weight: 600;
            border-radius: .5rem; border: none; cursor: pointer;
            transition: all .15s;
        }
        .btn-sm-danger { background: #FEE2E2; color: #DC2626; }
        .btn-sm-danger:hover { background: #FECACA; }
        .btn-sm-success { background: #D1FAE5; color: #059669; }
        .btn-sm-success:hover { background: #A7F3D0; }
        .btn-sm-primary { background: var(--blue-light); color: var(--blue); }
        .btn-sm-primary:hover { background: #DBEAFE; }

        /* ─── SEARCH INPUT ─────────────────────────────── */
        .search-input {
            width: 100%;
            padding: .625rem .875rem;
            border: 1px solid var(--border);
            border-radius: .625rem;
            font-size: .9rem;
            font-family: 'DM Sans', sans-serif;
            outline: none;
            transition: border-color .18s;
        }
        .search-input:focus { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(37,99,235,.1); }

        /* ─── SIDEBAR LINKS ────────────────────────────── */
        .sidebar-link {
            display: flex; align-items: center; gap: .75rem;
            padding: .625rem .875rem;
            border-radius: .625rem;
            font-size: .9rem; font-weight: 500;
            color: var(--text);
            text-decoration: none;
            transition: all .15s;
        }
        .sidebar-link:hover, .sidebar-link.active {
            background: var(--blue-light);
            color: var(--blue);
        }
        .sidebar-link i { width: 1.125rem; text-align: center; }

        /* ─── INFO GRID ────────────────────────────────── */
        .info-grid { display: grid; gap: .875rem; }
        .info-item label { font-size: .78rem; color: var(--muted); display: block; margin-bottom: 2px; }
        .info-item p { font-weight: 600; font-size: .92rem; color: var(--text); }

        /* ─── ACTION LINKS ─────────────────────────────── */
        .action-links { display: grid; grid-template-columns: 1fr 1fr; gap: .625rem; margin-top: 1.25rem; }
        .action-link {
            display: flex; align-items: center; justify-content: center;
            padding: .625rem;
            background: var(--blue-light);
            color: var(--blue);
            border-radius: .625rem;
            font-size: .85rem; font-weight: 600;
            text-decoration: none;
            text-align: center;
            transition: all .15s;
        }
        .action-link:hover { background: #DBEAFE; transform: translateY(-1px); }

        /* ─── MODAL ────────────────────────────────────── */
        .modal-overlay {
            position: fixed; inset: 0;
            background: rgba(0,0,0,.5);
            z-index: 100;
            display: flex; align-items: center; justify-content: center;
            padding: 1rem;
        }
        .modal-overlay.hidden { display: none; }
        .modal-box {
            background: white;
            border-radius: 1rem;
            padding: 1.75rem;
            width: 100%; max-width: 28rem;
            max-height: 90dvh;
            overflow-y: auto;
        }

        .form-group { margin-bottom: 1rem; }
        .form-group label { display: block; font-size: .85rem; font-weight: 600; color: var(--text); margin-bottom: .375rem; }
        .form-input {
            width: 100%; padding: .625rem .875rem;
            border: 1px solid var(--border);
            border-radius: .625rem;
            font-size: .9rem; font-family: 'DM Sans', sans-serif;
            outline: none; transition: border-color .18s;
        }
        .form-input:focus { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(37,99,235,.1); }
        .form-error { font-size: .78rem; color: #DC2626; margin-top: .25rem; }
        .form-error.hidden { display: none; }

        /* ─── TOAST ────────────────────────────────────── */
        .toast {
            position: fixed; bottom: 1.5rem; right: 1rem;
            padding: .875rem 1.25rem;
            border-radius: .75rem;
            color: white; font-weight: 600; font-size: .875rem;
            z-index: 200;
            box-shadow: 0 4px 20px rgba(0,0,0,.15);
            animation: slideUp .3s ease;
        }
        @keyframes slideUp { from { transform: translateY(2rem); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

        /* ─── ADMIN DROPDOWN ───────────────────────────── */
        .admin-menu {
            position: relative;
        }
        .admin-menu-items {
            position: absolute; left: 0; top: 100%;
            width: 100%; background: white;
            border: 1px solid var(--border);
            border-radius: .625rem;
            z-index: 60;
            box-shadow: 0 8px 24px rgba(0,0,0,.1);
            overflow: hidden;
        }
        .admin-menu-items.hidden { display: none; }
        .admin-menu-items a {
            display: block; padding: .625rem 1rem;
            font-size: .85rem; color: var(--text); text-decoration: none;
            transition: background .15s;
        }
        .admin-menu-items a:hover { background: var(--blue-light); color: var(--blue); }

        /* ─── SECTION TITLE ────────────────────────────── */
        .section-title {
            font-size: 1rem; font-weight: 700;
            color: var(--text); margin-bottom: 1rem;
        }

        /* ─── UTILITIES ────────────────────────────────── */
        .hidden { display: none !important; }
        .text-muted { color: var(--muted); font-size: .875rem; }

        /* Smooth fade in */
        @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
        .fade-in { animation: fadeIn .4s ease forwards; }
    </style>
</head>

