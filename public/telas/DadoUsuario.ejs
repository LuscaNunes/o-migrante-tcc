            </ul>
        </nav>
    </div>

    <!-- Main Content -->
    <div class="main-content-container">
        <button id="mobileMenuButton" class="mobile-menu-button">
            <i class="fas fa-bars text-blue-600 text-xl"></i>
        </button>

        <div class="main-content-wrapper">
            <!-- CONTEÚDO PRINCIPAL -->
            <div class="animate-fadeIn">
                <!-- Card Principal do Perfil -->
                <div class="bg-white rounded-2xl shadow-lg overflow-hidden mb-6">
                    <div class="bg-gradient-to-r from-blue-600 to-indigo-600 h-32"></div>
                    <div class="px-6 pb-6">
                        <div class="flex flex-col md:flex-row justify-between items-start md:items-center -mt-16 mb-6">
                            <div class="flex items-center space-x-4">
                                <div class="relative">
                                    <img id="userAvatar" alt="Foto do perfil"
                                        class="w-28 h-28 rounded-full border-4 border-white shadow-lg object-cover bg-white"
                                        src="https://storage.googleapis.com/a1aa/image/c564a5f6-93d6-4de8-e1b9-7405cfa7024a.jpg" />
                                    <button class="absolute bottom-0 right-0 bg-blue-600 text-white rounded-full p-2 shadow-lg edit-button hover:bg-blue-700 transition">
                                        <i class="fas fa-camera text-sm"></i>
                                    </button>
                                </div>
                                <div class="mt-12 md:mt-0">
                                    <h1 class="text-2xl md:text-3xl font-bold text-gray-900" id="userName">Carregando...</h1>
                                    <p class="text-blue-600 font-medium text-sm md:text-base" id="userEmail">Carregando...</p>
                                    <p class="text-gray-500 text-xs md:text-sm mt-1" id="userJoined">Membro desde: Carregando...</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-3 mt-4 md:mt-0 w-full md:w-auto">
                                <button class="flex-1 md:flex-none bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 px-5 rounded-xl transition flex items-center justify-center gap-2 shadow-md" id="editProfileBtn">
                                    <i class="fas fa-user-edit"></i>
                                    <span>Editar</span>
                                </button>
                                <button class="flex-1 md:flex-none bg-red-500 hover:bg-red-600 text-white font-medium py-2.5 px-5 rounded-xl transition flex items-center justify-center gap-2 shadow-md" id="logoutButton">
                                    <i class="fas fa-sign-out-alt"></i>
                                    <span>Sair</span>
                                </button>
                            </div>
                        </div>

                        <!-- Cards de Estatísticas -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
                            <div class="profile-card bg-gradient-to-r from-blue-500 to-blue-600 rounded-xl p-5 text-white text-center shadow-md">
                                <i class="fas fa-star text-3xl mb-2 text-yellow-300"></i>
                                <h3 class="text-sm font-semibold mb-1 opacity-90">XP Total</h3>
                                <p class="text-3xl font-bold" id="xpTotal">0</p>
                            </div>
                            <div class="profile-card bg-gradient-to-r from-indigo-500 to-indigo-600 rounded-xl p-5 text-white text-center shadow-md">
                                <i class="fas fa-medal text-3xl mb-2 text-yellow-300"></i>
                                <h3 class="text-sm font-semibold mb-1 opacity-90">Níveis Iniciados</h3>
                                <p class="text-3xl font-bold" id="niveisCompletos">0</p>
                            </div>
                        </div>

                        <!-- Progresso por Nível -->
                        <div>
                            <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
                                <i class="fas fa-chart-line text-blue-600"></i>
                                Progresso por Nível
                            </h2>
                            <div class="bg-gray-50 rounded-xl p-5 shadow-sm space-y-4" id="progressoNiveis">
                                <div class="text-center py-8">
                                    <div class="loading-spinner"></div>
                                    <p class="text-gray-600 mt-2">Carregando níveis...</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar Direita -->
            <div class="sidebar-right space-y-6 animate-fadeIn" style="animation-delay: 0.1s;">
                <!-- Informações Pessoais -->
                <div class="bg-white rounded-2xl shadow-lg p-6">
                    <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
                        <i class="fas fa-info-circle text-blue-600"></i>
                        Informações Pessoais
                    </h2>
                    <div class="space-y-3">
                        <div class="flex justify-between items-center py-2 border-b border-gray-100">
                            <span class="text-gray-500 text-sm">Nome Completo</span>
                            <span class="text-gray-900 font-medium text-sm" id="fullName">Carregando...</span>
                        </div>
                        <div class="flex justify-between items-center py-2 border-b border-gray-100">
                            <span class="text-gray-500 text-sm">Email</span>
                            <span class="text-gray-900 font-medium text-sm" id="emailInfo">Carregando...</span>
                        </div>
                        <div class="flex justify-between items-center py-2 border-b border-gray-100">
                            <span class="text-gray-500 text-sm">Tipo de Conta</span>
                            <span class="text-gray-900 font-medium text-sm" id="accountType">Carregando...</span>
                        </div>
                        <div class="flex justify-between items-center py-2">
                            <span class="text-gray-500 text-sm">Data de Cadastro</span>
                            <span class="text-gray-900 font-medium text-sm" id="registerDate">Carregando...</span>
                        </div>
                    </div>
                    <div class="mt-6 grid grid-cols-1 gap-2">
                        <a href="/app/biblia" class="action-button bg-blue-50 text-blue-700 font-medium py-2.5 px-4 rounded-xl transition text-center hover:bg-blue-100">
                            <i class="fas fa-bible mr-2"></i>Bíblia
                        </a>
                        <a href="../PaginaProducao.html" class="action-button bg-blue-50 text-blue-700 font-medium py-2.5 px-4 rounded-xl transition text-center hover:bg-blue-100">
