                    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 pb-5 border-b border-gray-100">
                        <div class="flex items-center gap-4">
                            <div class="relative">
                                <img id="userAvatar" class="w-20 h-20 md:w-24 md:h-24 rounded-full border-4 border-indigo-500 object-cover shadow-md" src="https://storage.googleapis.com/a1aa/image/c564a5f6-93d6-4de8-e1b9-7405cfa7024a.jpg" alt="Avatar">
                                <button class="absolute bottom-0 right-0 bg-indigo-500 text-white rounded-full p-1.5 border-2 border-white shadow-sm edit-button"><i class="fas fa-camera text-xs"></i></button>
