                    <li><a href="DadosNiveis.html" class="block py-2 px-3 rounded-lg text-gray-600 hover:bg-blue-100">Editar Níveis</a></li>
                    <li><a href="MensagemDiaria.html" class="block py-2 px-3 rounded-lg text-gray-600 hover:bg-blue-100">Mensagem do dia</a></li>
                </ul>
            </li>
        </ul>
    </aside>

    <!-- Botão menu mobile -->
    <button id="mobileMenuBtn" class="menu-toggle" aria-label="Menu">
        <i class="fas fa-bars text-blue-600 text-xl"></i>
    </button>

    <!-- Conteúdo principal -->
    <main class="main-container" id="mainContainer">
        <div class="two-column-layout">
            <!-- COLUNA PRINCIPAL (ESQUERDA) -->
            <div>
                <!-- Card de cabeçalho do perfil -->
