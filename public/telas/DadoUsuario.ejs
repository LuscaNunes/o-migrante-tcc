                    <a class="sidebar-link flex items-center text-gray-700 py-3 px-4 rounded-xl transition-all duration-200 hover:bg-blue-50 hover:text-blue-600 group" href="Fases.html">
                        <i class="fas fa-tasks mr-3 w-5 text-gray-400 group-hover:text-blue-600"></i>
                        <span class="font-medium">Missão</span>
