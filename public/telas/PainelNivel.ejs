<%
  // Esta página será injetada no layout.ejs como 'body'
  // O objeto 'user' já vem do server.js
%>

<style>
  .nivel-button {
    background-color: #007bff;
    transition: background-color 0.3s ease, transform 0.2s ease;
    width: 128px;
    height: 128px;
    font-size: 2rem;
    font-weight: bold;
  }

  .nivel-button.bloqueado {
    background-color: #ef4444;
  }

  .nivel-button.disponivel {
    background-color: #3b82f6;
  }

  .nivel-button.concluido {
    background-color: #10b981;
  }

  .nivel-button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .hover-animate:hover:not(:disabled) {
    transform: scale(1.05);
  }

  .bolinha {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  /* Desktop positions (original) */
  .btn-1 { top: 150px; left: 650px; }
  .btn-2 { top: 350px; left: 580px; }
  .btn-3 { top: 575px; left: 500px; }
  .btn-4 { top: 770px; left: 530px; }
  .btn-5 { top: 950px; left: 600px; }
  .btn-6 { top: 1140px; left: 700px; }
  .btn-7 { top: 1355px; left: 750px; }
  .btn-8 { top: 1550px; left: 680px; }
  .btn-9 { top: 1740px; left: 580px; }
  .btn-10 { top: 1950px; left: 550px; }
  .btn-11 { top: 2150px; left: 600px; }
  .btn-12 { top: 2350px; left: 650px; }

  .bola-1 { top: 295px; left: 655px; }
  .bola-2 { top: 505px; left: 580px; }
  .bola-3 { top: 720px; left: 550px; }
  .bola-4 { top: 910px; left: 605px; }
  .bola-5 { top: 1100px; left: 695px; }
  .bola-6 { top: 1295px; left: 775px; }
  .bola-7 { top: 1499px; left: 760px; }
  .bola-8 { top: 1690px; left: 675px; }
  .bola-9 { top: 1890px; left: 605px; }
  .bola-10 { top: 2105px; left: 605px; }
  .bola-11 { top: 2300px; left: 665px; }

  @media (max-width: 768px) {
    .nivel-button, .bolinha { transform: scale(0.7); }
    .btn-1, .btn-2, .btn-3, .btn-4, .btn-5, .btn-6, .btn-7, .btn-8, .btn-9, .btn-10, .btn-11, .btn-12 {
      left: 50% !important;
      transform: translateX(-50%) scale(0.7);
      transform-origin: center;
    }
    .bola-1, .bola-2, .bola-3, .bola-4, .bola-5, .bola-6, .bola-7, .bola-8, .bola-9, .bola-10, .bola-11 {
      left: 50% !important;
      transform: translateX(-50%) scale(0.7);
      transform-origin: center;
    }
    .btn-1 { top: 100px; }
    .bola-1 { top: 200px; }
    .btn-2 { top: 250px; }
    .bola-2 { top: 350px; }
    .btn-3 { top: 400px; }
    .bola-3 { top: 500px; }
    .btn-4 { top: 550px; }
    .bola-4 { top: 650px; }
    .btn-5 { top: 700px; }
    .bola-5 { top: 800px; }
    .btn-6 { top: 850px; }
    .bola-6 { top: 950px; }
    .btn-7 { top: 1000px; }
    .bola-7 { top: 1100px; }
    .btn-8 { top: 1150px; }
    .bola-8 { top: 1250px; }
    .btn-9 { top: 1300px; }
    .bola-9 { top: 1400px; }
    .btn-10 { top: 1450px; }
    .bola-10 { top: 1550px; }
    .btn-11 { top: 1600px; }
    .bola-11 { top: 1700px; }
    .btn-12 { top: 1750px; }
  }
</style>

<div class="w-full max-w-5xl mx-auto relative min-h-screen pb-20">
  <!-- Loading -->
  <div id="loadingContainer" class="text-center py-20">
    <i class="fas fa-spinner fa-spin text-indigo-600 text-4xl mb-3"></i>
    <p class="text-gray-500">Carregando nível...</p>
  </div>

  <!-- Conteúdo Principal -->
  <div id="mainContent" class="hidden">
    <div class="bg-white rounded-2xl shadow-lg p-6 sm:p-10 text-center mb-12">
      <h1 id="nivelTitle" class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4 flex items-center justify-center">
        <i class="fas fa-layer-group text-indigo-600 mr-3"></i>
        <span>Carregando...</span>
      </h1>
      <h2 id="nivelDescription" class="text-xl sm:text-2xl text-gray-600">Carregando descrição...</h2>
    </div>

    <!-- Mapa de Níveis (Posicionamento Absoluto) -->
    <div class="relative min-h-[2500px]">
      <!-- Botão 1 -->
      <button class="nivel-button absolute rounded-full flex items-center justify-center shadow-lg btn-1" data-ordem="1" onclick="redirectToPerguntas(1)">1</button>
      <div class="bolinha absolute bola-1"></div>

      <!-- Botão 2 -->
      <button class="nivel-button absolute rounded-full flex items-center justify-center shadow-lg btn-2" data-ordem="2" onclick="redirectToPerguntas(2)" disabled>2</button>
      <div class="bolinha absolute bola-2"></div>

      <!-- Botão 3 -->
      <button class="nivel-button absolute rounded-full flex items-center justify-center shadow-lg btn-3" data-ordem="3" onclick="redirectToPerguntas(3)" disabled>3</button>
      <div class="bolinha absolute bola-3"></div>

      <!-- Botão 4 -->
      <button class="nivel-button absolute rounded-full flex items-center justify-center shadow-lg btn-4" data-ordem="4" onclick="redirectToPerguntas(4)" disabled>4</button>
      <div class="bolinha absolute bola-4"></div>

      <!-- Botão 5 -->
      <button class="nivel-button absolute rounded-full flex items-center justify-center shadow-lg btn-5" data-ordem="5" onclick="redirectToPerguntas(5)" disabled>5</button>
      <div class="bolinha absolute bola-5"></div>

      <!-- Botão 6 -->
      <button class="nivel-button absolute rounded-full flex items-center justify-center shadow-lg btn-6" data-ordem="6" onclick="redirectToPerguntas(6)" disabled>6</button>
      <div class="bolinha absolute bola-6"></div>

      <!-- Botão 7 -->
      <button class="nivel-button absolute rounded-full flex items-center justify-center shadow-lg btn-7" data-ordem="7" onclick="redirectToPerguntas(7)" disabled>7</button>
      <div class="bolinha absolute bola-7"></div>

      <!-- Botão 8 -->
      <button class="nivel-button absolute rounded-full flex items-center justify-center shadow-lg btn-8" data-ordem="8" onclick="redirectToPerguntas(8)" disabled>8</button>
      <div class="bolinha absolute bola-8"></div>

      <!-- Botão 9 -->
      <button class="nivel-button absolute rounded-full flex items-center justify-center shadow-lg btn-9" data-ordem="9" onclick="redirectToPerguntas(9)" disabled>9</button>
      <div class="bolinha absolute bola-9"></div>

      <!-- Botão 10 -->
      <button class="nivel-button absolute rounded-full flex items-center justify-center shadow-lg btn-10" data-ordem="10" onclick="redirectToPerguntas(10)" disabled>10</button>
      <div class="bolinha absolute bola-10"></div>

      <!-- Botão 11 -->
      <button class="nivel-button absolute rounded-full flex items-center justify-center shadow-lg btn-11" data-ordem="11" onclick="redirectToPerguntas(11)" disabled>11</button>
      <div class="bolinha absolute bola-11"></div>

      <!-- Botão 12 -->
      <button class="nivel-button absolute rounded-full flex items-center justify-center shadow-lg btn-12" data-ordem="12" onclick="redirectToPerguntas(12)" disabled>12</button>
    </div>
  </div>
</div>

<script>
  (function() {
    'use strict';

    const API_BASE_URL = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
      ? `http://${window.location.hostname}:${window.location.port || 3000}`
      : 'https://o-migrante.onrender.com';

    let nivelId = null;

    function showFeedback(message, isError = true) {
      const existingFeedback = document.querySelector('.feedback-toast');
      if (existingFeedback) existingFeedback.remove();
      
      const div = document.createElement('div');
      div.className = `feedback-toast fixed bottom-4 right-4 p-4 rounded-lg shadow-lg z-50 transition-all duration-300 ${isError ? 'bg-red-500' : 'bg-green-500'} text-white`;
      div.innerHTML = `<i class="fas ${isError ? 'fa-exclamation-triangle' : 'fa-check-circle'} mr-2"></i>${message}`;
      document.body.appendChild(div);
      setTimeout(() => {
        div.style.opacity = '0';
        setTimeout(() => div.remove(), 300);
      }, 3000);
    }

    function redirectToPerguntas(ordem) {
      if (!nivelId) {
        showFeedback("ID do nível inválido.");
        return;
      }

      const botao = document.querySelector(`.nivel-button[data-ordem="${ordem}"]`);
      if (botao && botao.disabled) {
        showFeedback("Complete as perguntas anteriores para acessar esta fase.");
        return;
      }

      window.location.href = `/app/perguntas?nivel_id=${nivelId}&ordem=${ordem}`;
    }

    async function loadNivelData() {
      try {
        const token = localStorage.getItem('token');
        const response = await fetch(`${API_BASE_URL}/niveis/${nivelId}`, {
          method: "GET",
          headers: { "Authorization": `Bearer ${token}` }
        });

        if (!response.ok) {
          throw new Error(`Erro ${response.status}: ${response.statusText}`);
        }

        const data = await response.json();
        
        document.getElementById("nivelTitle").innerHTML = `
          <i class="fas fa-layer-group text-indigo-600 mr-3"></i>
          <span>${escapeHtml(data.titulo)}</span>
        `;
        document.getElementById("nivelDescription").textContent = data.descricao;
      } catch (error) {
        console.error("Erro ao carregar dados do nível:", error);
        showFeedback(`Erro ao carregar dados do nível: ${error.message}`);
        setTimeout(() => window.location.href = "/app/missao", 2000);
      }
    }

    async function carregarProgressoBotoes() {
      try {
        const token = localStorage.getItem('token');
        const response = await fetch(`${API_BASE_URL}/progresso/botoes/${nivelId}`, {
          method: "GET",
          headers: { "Authorization": `Bearer ${token}` }
        });

        if (!response.ok) {
          throw new Error(`Erro ${response.status}: Falha ao carregar progresso`);
        }

        const data = await response.json();

        // Determinar o último botão com progresso
        let ultimoBotaoConcluido = 0;
        for (let i = 1; i <= 12; i++) {
          if (data.botoesCompletos[i]?.xp_ganho > 0) {
            ultimoBotaoConcluido = Math.max(ultimoBotaoConcluido, i);
          }
        }

        // Atualizar botões
        document.querySelectorAll('.nivel-button').forEach(botao => {
          const botaoOrdem = parseInt(botao.getAttribute('data-ordem'));
          botao.classList.remove('bloqueado', 'disponivel', 'concluido');

          if (data.botoesCompletos[botaoOrdem]?.xp_ganho > 0) {
            botao.classList.add('concluido');
            botao.disabled = false;
          } else if (botaoOrdem === ultimoBotaoConcluido + 1) {
            botao.classList.add('disponivel');
            botao.disabled = false;
          } else {
            botao.classList.add('bloqueado');
            botao.disabled = true;
          }
        });

        // Atualizar bolinhas
        const bolinhas = document.querySelectorAll('.bolinha');
        bolinhas.forEach((bolinha, index) => {
          bolinha.classList.remove('bg-blue-500', 'bg-green-500', 'bg-gray-500');
          if (index + 1 <= ultimoBotaoConcluido) {
            bolinha.classList.add('bg-green-500');
          } else {
            bolinha.classList.add('bg-gray-500');
          }
        });

      } catch (error) {
        console.error("Erro ao carregar progresso:", error);
        showFeedback(`Erro ao carregar progresso: ${error.message}`);
      }
    }

    function escapeHtml(text) {
      if (!text) return '';
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    // Expor função global para onclick
    window.redirectToPerguntas = redirectToPerguntas;

    // Inicialização
    document.addEventListener("DOMContentLoaded", async () => {
      const urlParams = new URLSearchParams(window.location.search);
      nivelId = urlParams.get('nivel_id');

      if (!nivelId || isNaN(parseInt(nivelId))) {
        showFeedback("ID do nível inválido.");
        setTimeout(() => window.location.href = "/app/missao", 1500);
        return;
      }

      // Carregar dados e mostrar conteúdo
      await loadNivelData();
      await carregarProgressoBotoes();

      // Esconder loading e mostrar conteúdo
      document.getElementById('loadingContainer').classList.add('hidden');
      document.getElementById('mainContent').classList.remove('hidden');
    });
  })();
</script>