<%
  // Esta página será injetada no layout.ejs como 'body'
  // O objeto 'user' já vem do server.js
%>

<style>
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-5px); }
    75% { transform: translateX(5px); }
  }

  @keyframes pop {
    0% { transform: scale(1); }
    50% { transform: scale(1.05); }
    100% { transform: scale(1); }
  }

  .animate-error { animation: shake 0.3s ease-in-out; }
  .animate-success { animation: pop 0.4s ease-out; }
  
  .option-btn {
    transition: all 0.2s ease;
  }
  
  .option-btn.correct {
    background-color: #22c55e !important;
    border-color: #16a34a !important;
    color: white !important;
  }

  .option-btn.wrong {
    background-color: #ef4444 !important;
    border-color: #dc2626 !important;
    color: white !important;
  }

  .indicador-progresso {
    transition: all 0.3s ease-in-out;
  }
</style>

<!-- Indicadores de Progresso -->
<div class="fixed top-4 left-0 right-0 flex justify-center space-x-2 z-10">
  <div class="w-4 h-4 bg-gray-500 rounded-full indicador-progresso"></div>
  <div class="w-4 h-4 bg-gray-500 rounded-full indicador-progresso"></div>
  <div class="w-4 h-4 bg-gray-500 rounded-full indicador-progresso"></div>
  <div class="w-4 h-4 bg-gray-500 rounded-full indicador-progresso"></div>
  <div class="w-4 h-4 bg-gray-500 rounded-full indicador-progresso"></div>
</div>

<div class="min-h-screen flex items-center justify-center p-4">
  <div class="max-w-md w-full bg-white rounded-2xl shadow-xl p-8">
    <!-- Cabeçalho -->
    <div class="mb-8">
      <h2 class="text-2xl font-bold text-slate-800 mt-2" id="perguntaTitulo">Carregando pergunta...</h2>
    </div>

    <!-- Opções -->
    <div id="options-container" class="space-y-3"></div>

    <!-- Feedback -->
    <div id="feedback" class="mt-6 text-center font-bold h-6 transition-all duration-300 opacity-0"></div>
  </div>
</div>

<!-- Resultado Final -->
<div id="resultadoContainer" class="hidden fixed inset-0 bg-black bg-opacity-75 flex items-center justify-center z-50">
  <div class="bg-white rounded-2xl shadow-xl p-8 w-full max-w-md mx-4">
    <div class="text-center">
      <i class="fas fa-trophy text-yellow-500 text-5xl mb-4"></i>
      <h1 class="text-2xl font-bold text-slate-800 mb-4" id="resultadoTitulo">Parabéns!</h1>
      <p class="text-slate-600 mb-6">Você completou a missão com sucesso.</p>
      <div class="space-y-2 mb-6">
        <p class="text-lg font-semibold">Total de XP: <span class="text-green-600" id="xpTotal">0</span></p>
        <p class="text-lg font-semibold">Total de Acertos: <span class="text-green-600" id="totalAcertos">0</span></p>
        <p class="text-lg font-semibold">Porcentagem: <span class="text-green-600" id="porcentagemAcertos">0</span>%</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4">
        <button id="voltarMissoesButton" class="flex-1 bg-blue-500 text-white py-3 px-4 rounded-xl hover:bg-blue-600 transition font-medium">
          <i class="fas fa-arrow-left mr-2"></i>Voltar às Missões
        </button>
        <button id="proximoNivelButton" class="flex-1 bg-green-500 text-white py-3 px-4 rounded-xl hover:bg-green-600 transition font-medium">
          Próximo Nível <i class="fas fa-arrow-right ml-2"></i>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Overlay de Confirmação de Saída -->
<div id="sairOverlay" class="fixed inset-0 bg-black bg-opacity-75 flex items-center justify-center hidden z-50">
  <div class="bg-white rounded-2xl shadow-xl p-8 w-full max-w-md mx-4">
    <div class="text-center">
      <i class="fas fa-exclamation-triangle text-yellow-500 text-5xl mb-4"></i>
      <p class="text-xl font-semibold mb-6 text-slate-800">Se sair, irá perder seu progresso até o momento.</p>
      <div class="flex gap-4">
        <button id="confirmarSair" class="flex-1 py-3 bg-gray-100 border-2 border-slate-300 text-slate-700 rounded-xl hover:bg-gray-200 transition font-medium">Sim</button>
        <button id="cancelarSair" class="flex-1 py-3 bg-red-500 text-white rounded-xl hover:bg-red-600 transition font-medium">Não</button>
      </div>
    </div>
  </div>
</div>

<!-- Mensagem de Erro -->
<div id="erroContainer" class="hidden fixed inset-0 bg-black bg-opacity-75 flex items-center justify-center z-50">
  <div class="bg-white rounded-2xl shadow-xl p-8 w-full max-w-md mx-4">
    <div class="text-center">
      <i class="fas fa-exclamation-circle text-red-500 text-5xl mb-4"></i>
      <h2 class="text-xl font-bold mb-4 text-red-600">Erro</h2>
      <p id="mensagemErro" class="mb-6 text-slate-600">Ocorreu um erro ao carregar as perguntas.</p>
      <button id="recarregarPagina" class="w-full bg-blue-500 text-white py-3 px-4 rounded-xl hover:bg-blue-600 transition font-medium">
        <i class="fas fa-sync-alt mr-2"></i>Recarregar Página
      </button>
    </div>
  </div>
</div>

<script>
(function() {
  'use strict';

  const API_BASE_URL = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
    ? `http://${window.location.hostname}:${window.location.port || 3000}`
    : 'https://o-migrante.onrender.com';

  let perguntas = [];
  let indicePerguntaAtual = 0;
  let acertos = 0;
  let respostaSelecionada = null;
  let respostasCorretas = [];
  let xpTotal = 0;
  let nivelId = null;
  let ordem = null;
  let answered = false;
  let aguardandoProximo = false;

  function showFeedback(message, isError = true) {
    const existingFeedback = document.querySelector('.feedback-toast');
    if (existingFeedback) existingFeedback.remove();
    
    const div = document.createElement('div');
    div.className = `feedback-toast fixed bottom-4 right-4 p-4 rounded-lg shadow-lg z-50 transition-all duration-300 ${isError ? 'bg-red-500' : 'bg-green-500'} text-white`;
    div.innerHTML = `<i class="fas ${isError ? 'fa-exclamation-triangle' : 'fa-check-circle'} mr-2"></i>${message}`;
    document.body.appendChild(div);
    setTimeout(() => {
      div.style.opacity = '0';
      setTimeout(() => div.remove(), 300);
    }, 3000);
  }

  function mostrarErro(mensagem) {
    document.getElementById('mensagemErro').textContent = mensagem;
    document.getElementById('erroContainer').classList.remove('hidden');
  }

  function atualizarIndicadoresProgresso(indiceAtual) {
    const indicadores = document.querySelectorAll('.indicador-progresso');
    indicadores.forEach((indicador, index) => {
      indicador.classList.remove('w-6', 'h-6', 'bg-blue-500', 'bg-green-500', 'bg-red-500');
      indicador.classList.add('w-4', 'h-4', 'bg-gray-500');
      if (index === indiceAtual) {
        indicador.classList.remove('w-4', 'h-4', 'bg-gray-500');
        indicador.classList.add('w-6', 'h-6', 'bg-blue-500');
      }
      if (index < indiceAtual) {
        indicador.classList.remove('bg-gray-500');
        indicador.classList.add(respostasCorretas[index] ? 'bg-green-500' : 'bg-red-500');
      }
    });
  }

  function shuffleArray(array) {
    for (let i = array.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [array[i], array[j]] = [array[j], array[i]];
    }
    return array;
  }

  async function buscarPerguntas() {
    try {
      const response = await fetch(`${API_BASE_URL}/perguntas/aleatorias?nivel_id=${nivelId}&quantidade=5`, {
        method: "GET",
        headers: { "Authorization": `Bearer ${localStorage.getItem('token')}` }
      });

      if (!response.ok) {
        const errorData = await response.json().catch(() => ({}));
        throw new Error(errorData.error || "Erro ao buscar perguntas");
      }

      const data = await response.json();
      if (!data || !Array.isArray(data.perguntas) || data.perguntas.length === 0) {
        throw new Error("Nenhuma pergunta válida encontrada");
      }

      perguntas = data.perguntas;
      xpTotal = data.xp_total;
      carregarPergunta();
    } catch (error) {
      console.error("Erro ao buscar perguntas:", error);
      mostrarErro(`Erro ao carregar perguntas: ${error.message}`);
    }
  }

  function carregarPergunta() {
    const perguntaAtual = perguntas[indicePerguntaAtual];
    if (!perguntaAtual) {
      finalizarQuiz();
      return;
    }

    answered = false;
    aguardandoProximo = false;
    document.getElementById('perguntaTitulo').textContent = perguntaAtual.texto;
    document.getElementById('feedback').classList.remove('opacity-100');
    document.getElementById('feedback').classList.add('opacity-0');
    document.getElementById('feedback').innerHTML = '';

    const todasOpcoes = [
      perguntaAtual.resposta_correta,
      perguntaAtual.opcao1,
      perguntaAtual.opcao2,
      perguntaAtual.opcao3
    ].filter(opcao => opcao);

    const opcoesEmbaralhadas = shuffleArray([...todasOpcoes]);
    const container = document.getElementById('options-container');
    container.innerHTML = '';

    opcoesEmbaralhadas.forEach(opcao => {
      const button = document.createElement('button');
      button.className = 'option-btn w-full text-left p-4 rounded-xl border-2 border-slate-200 hover:border-blue-400 hover:bg-blue-50 font-medium text-slate-700 transition-all duration-200';
      button.textContent = opcao;
      button.onclick = () => verificarResposta(button, opcao);
      container.appendChild(button);
    });

    atualizarIndicadoresProgresso(indicePerguntaAtual);
  }

  function verificarResposta(button, resposta) {
    if (answered || aguardandoProximo) return;
    
    const perguntaAtual = perguntas[indicePerguntaAtual];
    const isCorrect = resposta === perguntaAtual.resposta_correta;
    const feedback = document.getElementById('feedback');
    
    answered = true;
    respostaSelecionada = resposta;

    if (isCorrect) {
      acertos++;
      respostasCorretas[indicePerguntaAtual] = true;
      button.classList.add('correct', 'animate-success');
      feedback.innerHTML = "✨ Parabéns, você acertou!";
      feedback.classList.remove('opacity-0', 'text-red-600');
      feedback.classList.add('opacity-100', 'text-green-600');
    } else {
      respostasCorretas[indicePerguntaAtual] = false;
      button.classList.add('wrong', 'animate-error');
      feedback.innerHTML = `❌ Ops, resposta incorreta. A resposta certa era: ${perguntaAtual.resposta_correta}`;
      feedback.classList.remove('opacity-0', 'text-green-600');
      feedback.classList.add('opacity-100', 'text-red-600');

      // Destacar a opção correta
      setTimeout(() => {
        const botoes = document.querySelectorAll('.option-btn');
        botoes.forEach(btn => {
          if (btn.textContent === perguntaAtual.resposta_correta) {
            btn.classList.add('correct', 'animate-success');
          }
        });
      }, 400);
    }

    // Desabilitar hover nos botões
    const botoes = document.querySelectorAll('.option-btn');
    botoes.forEach(btn => {
      btn.classList.remove('hover:border-blue-400', 'hover:bg-blue-50');
    });

    // Avançar para próxima pergunta após delay
    aguardandoProximo = true;
    setTimeout(() => {
      indicePerguntaAtual++;
      if (indicePerguntaAtual < perguntas.length) {
        carregarPergunta();
      } else {
        finalizarQuiz();
      }
    }, 2000);
  }

  
  async function salvarProgressoNoServidor(xpGanho) {
  try {
    const response = await fetch(`${API_BASE_URL}/progresso`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',  // ← estava faltando as aspas
        'Authorization': `Bearer ${localStorage.getItem('token')}`
      },
      body: JSON.stringify({
        nivel_id: parseInt(nivelId),
        xp_ganho: xpGanho,
        ordem: parseInt(ordem)
      })
    });

    const data = await response.json();
    if (!response.ok) throw new Error(data.error || 'Erro ao salvar progresso');
    return { success: true, data };
  } catch (error) {
    console.error('Erro ao salvar progresso:', error);
    return { success: false, error: error.message };
  }
}


  async function finalizarQuiz() {
  try {
    // Buscar progresso atual para verificar se a ordem já foi concluída
    const progressoResponse = await fetch(`${API_BASE_URL}/progresso/botoes/${nivelId}`, {
      method: "GET",
      headers: { "Authorization": `Bearer ${localStorage.getItem('token')}` }
    });
    
    if (!progressoResponse.ok) {
      throw new Error('Erro ao verificar progresso');
    }
    
    const progressoData = await progressoResponse.json();
    const ordemJaConcluida = progressoData.botoesCompletos[ordem]?.concluido === true;
    
    // Calcular XP ganho: 1 XP por acerto (máximo 5)
    let xpGanho = acertos;
    
    // Se já foi concluído antes, ainda ganha XP (revisão)
    // Se não foi concluído, ganha XP normalmente
    console.log('Finalizando quiz:', { 
      nivelId, 
      ordem, 
      acertos, 
      xpGanho, 
      ordemJaConcluida,
      totalPerguntas: perguntas.length 
    });
    
    // Salvar progresso no servidor (sempre salvar, mesmo se for 0)
    const salvarResponse = await fetch(`${API_BASE_URL}/progresso`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${localStorage.getItem('token')}`
      },
      body: JSON.stringify({
        nivel_id: parseInt(nivelId),
        xp_ganho: xpGanho,
        ordem: parseInt(ordem)
      })
    });
    
    if (!salvarResponse.ok) {
      const errorData = await salvarResponse.json();
      throw new Error(errorData.error || 'Erro ao salvar progresso');
    }
    
    const salvarData = await salvarResponse.json();
    console.log('Progresso salvo:', salvarData);
    
    // Verificar se a ordem foi concluída após o salvamento
    const verificarResponse = await fetch(`${API_BASE_URL}/progresso/botoes/${nivelId}`, {
      method: "GET",
      headers: { "Authorization": `Bearer ${localStorage.getItem('token')}` }
    });
    
    const verificarData = await verificarResponse.json();
    const foiConcluida = verificarData.botoesCompletos[ordem]?.concluido === true;
    
    console.log('Ordem concluída?', foiConcluida);
    
    // Esconder quiz e mostrar resultado
    const indicadoresContainer = document.querySelector('.fixed.top-4.left-0.right-0');
    if (indicadoresContainer) indicadoresContainer.classList.add('hidden');
    
    const quizCard = document.querySelector('.max-w-md.w-full.bg-white.rounded-2xl.shadow-xl.p-8');
    if (quizCard) quizCard.classList.add('hidden');
    
    const resultadoDiv = document.getElementById('resultadoContainer');
    if (resultadoDiv) resultadoDiv.classList.remove('hidden');
    
    // Atualizar texto do resultado
    const resultadoTitulo = document.getElementById('resultadoTitulo');
    if (resultadoTitulo) {
      resultadoTitulo.innerHTML = `<i class="fas fa-trophy mr-2 text-yellow-500"></i>Parabéns, ${window.userName || 'Jogador'}!`;
    }
    
    const xpTotalSpan = document.getElementById('xpTotal');
    if (xpTotalSpan) xpTotalSpan.textContent = xpGanho;
    
    const totalAcertosSpan = document.getElementById('totalAcertos');
    if (totalAcertosSpan) totalAcertosSpan.textContent = `${acertos} de ${perguntas.length}`;
    
    const porcentagemSpan = document.getElementById('porcentagemAcertos');
    if (porcentagemSpan) {
      const porcentagem = ((acertos / perguntas.length) * 100).toFixed(2);
      porcentagemSpan.textContent = porcentagem;
    }
    
    // Se a ordem foi concluída, mostrar mensagem especial
    if (foiConcluida && !ordemJaConcluida) {
      showFeedback("🎉 Missão completa! Você desbloqueou a próxima fase!", false);
    }
    
  } catch (error) {
    console.error("Erro ao finalizar quiz:", error);
    showFeedback("Erro ao finalizar o quiz. Redirecionando...", true);
    setTimeout(() => {
      window.location.href = `/app/painel-nivel?nivel_id=${nivelId}`;
    }, 3000);
  }
}


  // Event Listeners
  document.getElementById('voltarMissoesButton')?.addEventListener('click', () => {
    window.location.href = `/app/painel-nivel?nivel_id=${nivelId}`;
  });

  document.getElementById('proximoNivelButton')?.addEventListener('click', async () => {
    const ordemNum = parseInt(ordem);
    const nivelIdNum = parseInt(nivelId);
    let proximaOrdem, proximoNivelId;

    if (ordemNum === 12) {
        // Última fase do nível atual
        try {
            const response = await fetch(`${API_BASE_URL}/niveis/${nivelIdNum + 1}`, {
                headers: { "Authorization": `Bearer ${localStorage.getItem('token')}` }
            });
            if (!response.ok) {
                showFeedback("🎉 Você completou todos os níveis disponíveis!", false);
                setTimeout(() => window.location.href = "/app/missao", 2000);
                return;
            }
            proximoNivelId = nivelIdNum + 1;
            proximaOrdem = 1;
        } catch {
            showFeedback("🎉 Você completou todos os níveis disponíveis!", false);
            setTimeout(() => window.location.href = "/app/missao", 2000);
            return;
        }
    } else {
        // Próxima fase do mesmo nível
        proximoNivelId = nivelIdNum;
        proximaOrdem = ordemNum + 1;
    }

    // 🔥 CORREÇÃO: Usar a lógica de jogo (par = CompletarFrase, ímpar = Quiz)
    const tipoJogo = (proximaOrdem % 2 === 0) ? 'CompletarFrase' : 'Quiz';
    
    window.location.href = `/app/jogo/${tipoJogo}?nivel_id=${proximoNivelId}&ordem=${proximaOrdem}`;
  });


  // Sair
  const sairButton = document.getElementById('sairButton');
  const sairOverlay = document.getElementById('sairOverlay');
  
  if (sairButton) {
    sairButton.addEventListener('click', () => {
      sairOverlay.classList.remove('hidden');
    });
  }
  
  document.getElementById('confirmarSair')?.addEventListener('click', () => {
    window.location.href = `/app/painel-nivel?nivel_id=${nivelId}`;
  });
  
  document.getElementById('cancelarSair')?.addEventListener('click', () => {
    sairOverlay.classList.add('hidden');
  });

  document.getElementById('recarregarPagina')?.addEventListener('click', () => {
    window.location.reload();
  });

  // Inicialização
  document.addEventListener("DOMContentLoaded", () => {
    const token = localStorage.getItem('token');
    if (!token) {
      showFeedback("Você precisa estar logado!", true);
      setTimeout(() => window.location.href = "/", 2000);
      return;
    }

    const urlParams = new URLSearchParams(window.location.search);
    nivelId = urlParams.get('nivel_id');
    ordem = urlParams.get('ordem');

    if (!nivelId || !ordem) {
      mostrarErro("Parâmetros inválidos");
      setTimeout(() => window.location.href = "/app/missao", 2000);
      return;
    }

    buscarPerguntas();
  });
})();
</script>