<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>O Migrante - Login & Cadastro</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: "Inter", sans-serif;
    }

    body {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      overflow: hidden;
      color: #fff;
    }

    /* Anéis giratórios neon com cores do sistema */
    .ring {
      position: relative;
      width: 500px;
      height: 500px;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .ring i {
      position: absolute;
      inset: 0;
      border: 2px solid #fff;
      transition: 0.5s;
    }

    .ring i:nth-child(1) {
      border-radius: 38% 62% 63% 37% / 41% 44% 56% 59%;
      animation: animate 6s linear infinite;
      border-color: #3b82f6;
    }

    .ring i:nth-child(2) {
      border-radius: 41% 44% 56% 59%/38% 62% 63% 37%;
      animation: animate 4s linear infinite;
      border-color: #8b5cf6;
    }

    .ring i:nth-child(3) {
      border-radius: 41% 44% 56% 59%/38% 62% 63% 37%;
      animation: animate2 10s linear infinite;
      border-color: #06b6d4;
    }

    .ring:hover i {
      border-width: 6px;
      filter: drop-shadow(0 0 20px var(--clr));
    }

    @keyframes animate {
      from {
        transform: rotate(0deg);
      }
      to {
        transform: rotate(360deg);
      }
    }

    @keyframes animate2 {
      from {
        transform: rotate(360deg);
      }
      to {
        transform: rotate(0deg);
      }
    }

    .container {
      position: absolute;
      width: min(380px, 90vw);
      padding: 40px 30px;
      text-align: center;
      z-index: 10;
      background: rgba(15, 23, 42, 0.8);
      backdrop-filter: blur(10px);
      border-radius: 24px;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
      border: 1px solid rgba(59, 130, 246, 0.2);
    }

    h2 {
      font-size: 2.2em;
      font-weight: 700;
      margin-bottom: 30px;
      background: linear-gradient(135deg, #3b82f6, #8b5cf6, #06b6d4);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .inputBx {
      position: relative;
      margin: 20px 0;
    }

    .inputBx input {
      width: 100%;
      padding: 14px 20px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(59, 130, 246, 0.3);
      border-radius: 12px;
      outline: none;
      color: #fff;
      font-size: 1em;
      transition: 0.3s;
      font-weight: 500;
    }

    .inputBx input:focus {
      border-color: #3b82f6;
      box-shadow: 0 0 20px rgba(59, 130, 246, 0.3);
      background: rgba(59, 130, 246, 0.1);
    }

    .inputBx input::placeholder {
      color: rgba(255, 255, 255, 0.5);
    }

    /* Botão com efeito gradiente */
    button {
      position: relative;
      width: 100%;
      padding: 14px;
      background: linear-gradient(135deg, #3b82f6, #8b5cf6);
      border: none;
      border-radius: 12px;
      color: #fff;
      font-size: 1em;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      overflow: hidden;
      margin-top: 10px;
    }

    button:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 25px -5px rgba(59, 130, 246, 0.4);
    }

    button:active {
      transform: translateY(0);
    }

    /* Efeito de carregamento */
    button.loading {
      background: rgba(59, 130, 246, 0.5);
      cursor: not-allowed;
      animation: pulse 1.5s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.7; }
    }

    .links {
      margin-top: 24px;
      display: flex;
      justify-content: center;
      gap: 20px;
      flex-wrap: wrap;
    }

    .links a {
      color: rgba(255, 255, 255, 0.7);
      text-decoration: none;
      font-size: 0.9em;
      transition: 0.3s;
    }

    .links a:hover {
      color: #3b82f6;
    }

    .error {
      color: #ef4444;
      margin-top: 12px;
      font-size: 0.85em;
      background: rgba(239, 68, 68, 0.1);
      padding: 8px;
      border-radius: 8px;
    }

    .hidden {
      display: none !important;
    }

    #messageBox {
      position: fixed;
      top: 20px;
      right: 20px;
      padding: 16px 24px;
      border-radius: 12px;
      color: #fff;
      font-weight: 600;
      z-index: 1000;
      transform: translateX(120%);
      transition: transform 0.4s ease;
      backdrop-filter: blur(10px);
    }

    #messageBox.show {
      transform: translateX(0);
    }

    /* Logo */
    .logo-container {
      margin-bottom: 10px;
    }

    .logo-icon {
      font-size: 3em;
      background: linear-gradient(135deg, #3b82f6, #8b5cf6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    @media (max-width: 480px) {
      .container {
        padding: 30px 20px;
      }
      
      h2 {
        font-size: 1.8em;
      }
      
      button {
        padding: 12px;
      }
    }
  </style>
</head>

<body>

  <div class="ring">
    <i style="--clr:#3b82f6"></i>
    <i style="--clr:#8b5cf6"></i>
    <i style="--clr:#06b6d4"></i>

    <!-- Login -->
    <div id="loginContainer" class="container">
      <div class="logo-container">
        <i class="fas fa-mountain logo-icon"></i>
      </div>
      <h2>O Migrante</h2>
      <form id="loginForm">
        <div class="inputBx">
          <input type="email" id="loginEmail" placeholder="seu.email@exemplo.com" required>
        </div>
        <div class="inputBx">
          <input type="password" id="loginPassword" placeholder="••••••••" required>
        </div>
        <button type="submit" id="loginButton">Entrar</button>
        <p id="loginError" class="error hidden"></p>
        <div class="links">
          <a href="#" id="showRegister">Criar conta</a>
        </div>
      </form>
    </div>

    <!-- Cadastro -->
    <div id="registerContainer" class="container hidden">
      <div class="logo-container">
        <i class="fas fa-mountain logo-icon"></i>
      </div>
      <h2>Criar Conta</h2>
      <form id="registerForm">
        <div class="inputBx">
          <input type="text" id="registerName" placeholder="Nome Completo" required>
        </div>
        <div class="inputBx">
          <input type="email" id="registerEmail" placeholder="seu.email@exemplo.com" required>
        </div>
        <div class="inputBx">
          <input type="password" id="registerPassword" placeholder="Mínimo 6 caracteres" required>
        </div>
        <button type="submit" id="registerButton">Cadastrar</button>
        <p id="registerError" class="error hidden"></p>
        <div class="links">
          <a href="#" id="showLogin">Já tem conta? Faça login</a>
        </div>
      </form>
    </div>
  </div>

  <div id="messageBox">
    <p id="messageText"></p>
  </div>

  <script>
    const API_BASE_URL = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
      ? `http://${window.location.hostname}:${window.location.port || 3000}`
      : 'https://o-migrante.onrender.com';

    function showMessage(msg, success = false) {
      const box = document.getElementById('messageBox');
      const text = document.getElementById('messageText');
      text.textContent = msg;
      box.style.background = success ? 'rgba(16, 185, 129, 0.9)' : 'rgba(239, 68, 68, 0.9)';
      box.classList.add('show');
      setTimeout(() => box.classList.remove('show'), 4000);
    }

    function mostrarErro(id, msg) {
      const el = document.getElementById(id);
      el.textContent = msg;
      el.classList.remove('hidden');
    }

    function setLoading(button, loading) {
      button.disabled = loading;
      if (loading) {
        button.classList.add('loading');
        button.textContent = button.id === 'loginButton' ? 'Entrando...' : 'Cadastrando...';
      } else {
        button.classList.remove('loading');
        button.textContent = button.id === 'loginButton' ? 'Entrar' : 'Cadastrar';
      }
    }

    function validarEmail(email) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    document.addEventListener('DOMContentLoaded', () => {
      const loginCont = document.getElementById('loginContainer');
      const regCont = document.getElementById('registerContainer');
      const loginBtn = document.getElementById('loginButton');
      const registerBtn = document.getElementById('registerButton');

      document.getElementById('showRegister').onclick = e => { e.preventDefault(); loginCont.classList.add('hidden'); regCont.classList.remove('hidden'); };
      document.getElementById('showLogin').onclick = e => { e.preventDefault(); regCont.classList.add('hidden'); loginCont.classList.remove('hidden'); };

      // CADASTRO
      document.getElementById('registerForm').onsubmit = async e => {
        e.preventDefault();
        const nome = document.getElementById('registerName').value.trim();
        const email = document.getElementById('registerEmail').value.trim();
        const senha = document.getElementById('registerPassword').value;

        document.getElementById('registerError').classList.add('hidden');
        if (!nome || !email || !senha) return mostrarErro('registerError', 'Preencha todos os campos.');
        if (!validarEmail(email)) return mostrarErro('registerError', 'Email inválido.');
        if (senha.length < 6) return mostrarErro('registerError', 'Senha deve ter no mínimo 6 caracteres.');

        setLoading(registerBtn, true);

        try {
          const res = await fetch(`${API_BASE_URL}/auth/register`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ nome, email, senha })
          });
          const data = await res.json();
          if (res.ok) {
            showMessage(data.message || 'Cadastro realizado com sucesso!', true);
            e.target.reset();
            regCont.classList.add('hidden');
            loginCont.classList.remove('hidden');
          } else {
            mostrarErro('registerError', data.message || 'Erro no cadastro.');
          }
        } catch (err) {
          console.error('Erro:', err);
          mostrarErro('registerError', 'Erro de conexão. Tente novamente.');
        } finally {
          setLoading(registerBtn, false);
        }
      };

      // LOGIN
      document.getElementById('loginForm').onsubmit = async e => {
        e.preventDefault();
        const email = document.getElementById('loginEmail').value.trim();
        const senha = document.getElementById('loginPassword').value;

        document.getElementById('loginError').classList.add('hidden');
        if (!email || !senha) return mostrarErro('loginError', 'Preencha todos os campos.');
        if (!validarEmail(email)) return mostrarErro('loginError', 'Email inválido.');

        setLoading(loginBtn, true);

        try {
          const res = await fetch(`${API_BASE_URL}/auth/login`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, senha })
          });
          const data = await res.json();

          if (data.auth) {
            localStorage.setItem('token', data.token);
            showMessage('Login realizado com sucesso!', true);
            setTimeout(() => window.location.href = '/app/painel', 1500);
          } else {
            mostrarErro('loginError', data.message || 'Email ou senha incorretos.');
          }
        } catch (err) {
          console.error('Erro:', err);
          mostrarErro('loginError', 'Erro de conexão. Tente novamente.');
        } finally {
          setLoading(loginBtn, false);
        }
      };
    });
  </script>
</body>

</html>