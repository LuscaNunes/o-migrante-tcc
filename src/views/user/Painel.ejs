<% /* 
 * Painel.ejs - Versão Corrigida com Navegação para Bíblia
 * Este arquivo contém APENAS o HTML da seção principal do Dashboard.
 */ %>

<section class="max-w-5xl mx-auto space-y-8">
    <div class="flex flex-col md:flex-row md:justify-between md:items-center bg-white rounded-2xl shadow-sm p-8 fadeInUp delay-100">
        <div>
            <h1 class="text-3xl font-semibold text-[#111827] mb-1 select-none">
                Bem-vindo,
                <span class="font-bold">
                    <%= user ? user.nome : 'Usuário' %>
                </span>!
            </h1>
            <p class="text-gray-600 select-none">Você está logado com sucesso.</p>
        </div>
        
        <button class="mt-6 md:mt-0 bg-[#2563eb] hover:bg-[#1e40af] text-white font-semibold px-6 py-2 rounded-lg shadow-md transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-[#1e40af] flex items-center select-none" id="logoutButtonConteudo">
            <i class="fas fa-sign-out-alt mr-2"></i>Sair
        </button>
    </div>

    <!-- Mensagem Diária -->
    <section aria-label="Mensagem Diária" class="grid grid-cols-1 gap-6 fadeInUp delay-200 max-w-6xl mx-auto">
        <div id="mensagemDiaria" class="bg-white rounded-2xl shadow-sm p-6 flex flex-col text-left hover:shadow-md transition-shadow duration-300 cursor-pointer select-none border-l-4 border-l-[#2563eb]">
            <div class="flex items-center mb-2">
                <i class="fas fa-envelope-open-text text-[#2563eb] text-xl mr-2"></i>
                <span class="font-semibold text-[#2563eb] text-lg">📖 Mensagem Diária</span>
            </div>
            
            <!-- Carregando -->
            <div id="mensagemLoading" class="text-gray-500 text-center py-4">
                <i class="fas fa-spinner fa-spin mr-2"></i> Carregando mensagem...
            </div>
            
            <!-- Conteúdo da Mensagem -->
            <div id="mensagemContent" class="hidden">
                <h3 id="mensagemTitulo" class="font-semibold text-[#111827] text-xl mb-2"></h3>
                <p id="mensagemReferencia" class="text-sm text-indigo-600 font-medium mb-2"></p>
                <p id="mensagemDescricao" class="text-gray-700 leading-relaxed"></p>
            </div>
            
            <!-- Erro -->
            <p id="mensagemErro" class="text-gray-500 hidden text-center py-4">
                <i class="fas fa-info-circle mr-2"></i> Nenhuma mensagem disponível hoje.
            </p>
        </div>
    </section>

    <!-- Notificações -->
    <section aria-label="Atividades recentes do usuário" class="max-w-4xl mx-auto bg-white rounded-2xl shadow-sm p-8 fadeInUp delay-400">
        <h2 class="text-xl font-semibold text-[#111827] mb-6 select-none flex items-center">
            <i class="fas fa-bell text-[#2563eb] mr-2"></i>
            Notificações
        </h2>
        <ul class="space-y-4 text-gray-700">
            <li class="flex items-center space-x-3">
                <i aria-hidden="true" class="fas fa-check-circle text-[#2563eb]"></i>
                <span>Você completou a missão <strong class="text-[#111827]">"Descobrir o Novo Testamento"</strong>.</span>
            </li>
            <li class="flex items-center space-x-3">
                <i aria-hidden="true" class="fas fa-save text-[#2563eb]"></i>
                <span>Você salvou uma anotação na <strong class="text-[#111827]">Biblioteca Bíblica</strong>.</span>
            </li>
            <li class="flex items-center space-x-3">
                <i aria-hidden="true" class="fas fa-comment-alt text-[#2563eb]"></i>
                <span>Você enviou uma mensagem diária para o grupo.</span>
            </li>
            <li class="flex items-center space-x-3">
                <i aria-hidden="true" class="fas fa-cog text-[#2563eb]"></i>
                <span>Você atualizou suas configurações de perfil.</span>
            </li>
            <li class="flex items-center space-x-3">
                <i aria-hidden="true" class="fas fa-flag-checkered text-[#2563eb]"></i>
                <span>Você iniciou a missão <strong class="text-[#111827]">"Estudo do Antigo Testamento"</strong>.</span>
            </li>
        </ul>
    </section>
</section>

<script>
    console.log("Script do Painel.ejs carregado");

    // Armazenar dados da mensagem atual para navegação
    let currentMensagemData = null;

    function showFeedback(message, isError = true) {
        const feedbackDiv = document.createElement("div");
        feedbackDiv.className = `fixed bottom-4 right-4 p-4 rounded-lg shadow-lg ${isError ? "bg-red-500" : "bg-green-500"} text-white z-50`;
        feedbackDiv.textContent = message;
        document.body.appendChild(feedbackDiv);
        setTimeout(() => feedbackDiv.remove(), 3000);
    }

    function getVersionName(version) {
        const versions = {
            acf: "Almeida Corrigida Fiel",
            nvi: "Nova Versão Internacional",
            aa: "Almeida Atualizada"
        };
        return versions[version] || version;
    }

    async function loadMensagemDiaria() {
        const loadingDiv = document.getElementById("mensagemLoading");
        const contentDiv = document.getElementById("mensagemContent");
        const erroDiv = document.getElementById("mensagemErro");

        try {
            loadingDiv.classList.remove("hidden");
            contentDiv.classList.add("hidden");
            erroDiv.classList.add("hidden");

            const response = await fetch("/mensagens/diaria", {
                method: "GET",
                headers: {
                    "Content-Type": "application/json"
                }
            });

            console.log("Resposta de /mensagens/diaria:", response.status);

            if (!response.ok) {
                throw new Error(`HTTP ${response.status}`);
            }

            const data = await response.json();
            console.log("Dados recebidos:", data);

            if (!data.success || !data.mensagem) {
                throw new Error("Nenhuma mensagem disponível");
            }

            const mensagem = data.mensagem;
            
            // Armazenar dados para navegação
            currentMensagemData = {
                versao: mensagem.versao,
                livro: mensagem.livro,
                capitulo: mensagem.capítulo || mensagem.capitulo,
                versiculo: mensagem.versículo || mensagem.versiculo
            };

            console.log("Mensagem carregada:", currentMensagemData);

            // Preencher os elementos
            document.getElementById("mensagemTitulo").textContent = mensagem.título || mensagem.titulo;
            document.getElementById("mensagemReferencia").innerHTML = `<i class="fas fa-book-open mr-1"></i> ${mensagem.livro} ${currentMensagemData.capitulo}:${currentMensagemData.versiculo} (${getVersionName(currentMensagemData.versao)})`;
            document.getElementById("mensagemDescricao").textContent = mensagem.descrição || mensagem.descricao;

            // Mostrar conteúdo, esconder loading
            loadingDiv.classList.add("hidden");
            contentDiv.classList.remove("hidden");

        } catch (error) {
            console.error("Erro ao carregar mensagem:", error);
            loadingDiv.classList.add("hidden");
            erroDiv.classList.remove("hidden");
            currentMensagemData = null;
        }
    }

    // Função para redirecionar para a Bíblia
    function irParaBiblia() {
        if (!currentMensagemData) {
            console.log("Nenhuma mensagem disponível para navegação");
            showFeedback("Nenhuma mensagem disponível para navegação", true);
            return;
        }

        const { versao, livro, capitulo, versiculo } = currentMensagemData;
        console.log("Redirecionando para Bíblia:", { versao, livro, capitulo, versiculo });
        
        // Construir URL com parâmetros
        const params = new URLSearchParams({
            versao: versao,
            livro: encodeURIComponent(livro),
            capitulo: capitulo,
            versiculo: versiculo
        });
        
        // Redirecionar para a tela da Bíblia (usando rota EJS)
        window.location.href = `/app/biblia?${params.toString()}`;
    }

    // Configurar evento de clique na mensagem diária
    const mensagemDiariaDiv = document.getElementById("mensagemDiaria");
    if (mensagemDiariaDiv) {
        mensagemDiariaDiv.addEventListener("click", irParaBiblia);
    }

    // Configurar logout
    const logoutButtonConteudo = document.getElementById("logoutButtonConteudo");
    if (logoutButtonConteudo) {
        logoutButtonConteudo.addEventListener("click", () => {
            localStorage.removeItem("token");
            fetch('/auth/logout', { method: 'POST' })
                .finally(() => { window.location.href = "/"; });
        });
    }

    // Carregar mensagem ao iniciar
    loadMensagemDiaria();
</script>