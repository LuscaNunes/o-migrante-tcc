<%
  // Esta página será injetada no layout.ejs como 'body'
  // O objeto 'user' já vem do server.js
%>

<style>
  /* Estilos específicos para a página de anotações */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-fadeIn {
    animation: fadeIn 0.5s ease forwards;
  }
  
  .anotacao-card {
    transition: all 0.2s ease;
  }
  
  .anotacao-card:hover {
    background-color: #EFF6FF;
    transform: translateY(-2px);
  }
  
  .action-button {
    transition: all 0.2s ease;
  }
  
  .action-button:hover {
    transform: scale(1.05);
  }
  
  #anotacoes-container {
    scrollbar-width: thin;
    scrollbar-color: #CBD5E1 #F1F5F9;
  }
  
  #anotacoes-container::-webkit-scrollbar {
    width: 6px;
  }
  
  #anotacoes-container::-webkit-scrollbar-track {
    background: #F1F5F9;
    border-radius: 10px;
  }
  
  #anotacoes-container::-webkit-scrollbar-thumb {
    background: #CBD5E1;
    border-radius: 10px;
  }
  
  #anotacoes-container::-webkit-scrollbar-thumb:hover {
    background: #94A3B8;
  }
  
  /* Modal styles */
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
  }
  
  .modal-content {
    animation: fadeIn 0.3s ease;
    max-width: 90vw;
    max-height: 90vh;
    overflow-y: auto;
  }
</style>

<div class="w-full max-w-5xl mx-auto">
  <div class="bg-white rounded-2xl shadow-lg p-6 sm:p-10 animate-fadeIn">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-8 gap-4">
      <h1 class="text-2xl sm:text-3xl font-semibold text-gray-900 flex items-center">
        <i class="fas fa-pen-alt text-indigo-600 mr-3"></i>
        Minhas Anotações
      </h1>
      <div class="flex items-center gap-4 w-full sm:w-auto">
        <label for="filtro-visibilidade" class="font-semibold text-indigo-700 whitespace-nowrap">
          <i class="fas fa-filter mr-1"></i> Filtrar:
        </label>
        <select id="filtro-visibilidade" class="block w-full sm:w-auto bg-indigo-50 border border-indigo-200 rounded-lg py-2 px-3 text-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500">
          <option value="todos" selected>Todos</option>
          <option value="publico">Público</option>
          <option value="privado">Privado</option>
        </select>
        <a href="/app/painel" class="action-button bg-indigo-100 text-indigo-700 font-medium py-2 px-4 rounded-lg transition flex items-center text-sm sm:text-base hover:bg-indigo-200">
          <i class="fas fa-arrow-left mr-2"></i> Voltar
        </a>
      </div>
    </div>

    <div id="anotacoes-container" class="space-y-4">
      <div class="text-center text-gray-500 py-8">
        <i class="fas fa-spinner fa-spin text-4xl mb-2"></i>
        <p>Carregando anotações...</p>
      </div>
    </div>
  </div>
</div>

<!-- Modal de Edição -->
<div id="editModal" class="modal-overlay" style="display: none;">
  <div class="modal-content bg-white rounded-2xl shadow-xl w-full max-w-2xl">
    <div class="p-6 border-b border-gray-200">
      <h2 class="text-2xl font-semibold text-gray-900 flex items-center">
        <i class="fas fa-edit text-indigo-600 mr-2"></i>
        Editar Anotação
      </h2>
    </div>
    <div class="p-6">
      <div class="mb-4">
        <label class="block text-gray-700 font-semibold mb-2">
          <i class="fas fa-bible mr-1"></i> Referência
        </label>
        <p id="edit-referencia" class="text-indigo-700 font-medium bg-indigo-50 p-3 rounded-lg"></p>
      </div>
      <div class="mb-4">
        <label class="block text-gray-700 font-semibold mb-2">
          <i class="fas fa-quote-left mr-1"></i> Versículo
        </label>
        <p id="edit-versiculo" class="text-gray-600 italic bg-gray-50 p-3 rounded-lg"></p>
      </div>
      <div class="mb-4">
        <label for="edit-texto" class="block text-gray-700 font-semibold mb-2">
          <i class="fas fa-pen-alt mr-1"></i> Sua Anotação
        </label>
        <textarea id="edit-texto" rows="6" class="w-full bg-indigo-50 border border-indigo-200 rounded-lg py-2 px-3 text-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500"></textarea>
      </div>
      <div class="mb-4">
        <label for="edit-visibilidade" class="block text-gray-700 font-semibold mb-2">
          <i class="fas fa-eye mr-1"></i> Visibilidade
        </label>
        <select id="edit-visibilidade" class="w-full bg-indigo-50 border border-indigo-200 rounded-lg py-2 px-3 text-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500">
          <option value="publico">Público</option>
          <option value="privado">Privado</option>
        </select>
      </div>
      <div class="flex justify-end gap-3">
        <button onclick="closeEditModal()" class="px-4 py-2 bg-gray-300 text-gray-700 rounded-lg hover:bg-gray-400 transition">
          Cancelar
        </button>
        <button onclick="saveEdit()" class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition">
          <i class="fas fa-save mr-1"></i> Salvar
        </button>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  'use strict';
  
  const API_BASE_URL = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
    ? `http://${window.location.hostname}:${window.location.port || 3000}`
    : '';
  
  let anotacoesData = [];
  let currentEditId = null;
  
  function showFeedback(message, isError = false) {
    const existingFeedback = document.querySelector('.feedback-toast');
    if (existingFeedback) existingFeedback.remove();
    
    const div = document.createElement('div');
    div.className = `feedback-toast fixed bottom-4 right-4 p-4 rounded-lg shadow-lg z-50 transition-all duration-300 ${isError ? 'bg-red-500' : 'bg-green-500'} text-white`;
    div.innerHTML = `<i class="fas ${isError ? 'fa-exclamation-triangle' : 'fa-check-circle'} mr-2"></i>${message}`;
    document.body.appendChild(div);
    setTimeout(() => {
      div.style.opacity = '0';
      setTimeout(() => div.remove(), 300);
    }, 3000);
  }
  
  function showConfirmation(message, title = 'Confirmar') {
    return new Promise((resolve) => {
      const overlay = document.createElement('div');
      overlay.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
      const modal = document.createElement('div');
      modal.className = 'bg-white rounded-lg p-6 max-w-sm w-full shadow-lg text-center';
      const titleEl = document.createElement('h3');
      titleEl.className = 'text-lg font-semibold mb-4 text-gray-900';
      titleEl.textContent = title;
      const msg = document.createElement('p');
      msg.className = 'mb-6 text-gray-800';
      msg.textContent = message;
      const buttonsDiv = document.createElement('div');
      buttonsDiv.className = 'flex justify-center gap-6';
      const btnYes = document.createElement('button');
      btnYes.className = 'bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-6 rounded transition';
      btnYes.textContent = 'Sim, excluir';
      const btnNo = document.createElement('button');
      btnNo.className = 'bg-gray-300 hover:bg-gray-400 text-gray-800 font-semibold py-2 px-6 rounded transition';
      btnNo.textContent = 'Cancelar';
      buttonsDiv.appendChild(btnYes);
      buttonsDiv.appendChild(btnNo);
      modal.appendChild(titleEl);
      modal.appendChild(msg);
      modal.appendChild(buttonsDiv);
      overlay.appendChild(modal);
      document.body.appendChild(overlay);
      btnYes.focus();
      
      btnYes.addEventListener('click', () => {
        document.body.removeChild(overlay);
        resolve(true);
      });
      btnNo.addEventListener('click', () => {
        document.body.removeChild(overlay);
        resolve(false);
      });
    });
  }
  
  async function makeAuthenticatedRequest(url, options = {}) {
    const defaultOptions = {
      credentials: 'include',
      headers: { 
        'Content-Type': 'application/json',
        ...options.headers 
      }
    };
    const finalOptions = { ...defaultOptions, ...options };
    const fullUrl = API_BASE_URL ? `${API_BASE_URL}${url}` : url;
    
    try {
      const response = await fetch(fullUrl, finalOptions);
      return response;
    } catch (error) {
      console.error('Erro na requisição:', error);
      throw error;
    }
  }
  
  function navigateToBible(versao, livro, capitulo, versiculo) {
    const params = new URLSearchParams({
      versao: versao,
      livro: livro,
      capitulo: capitulo,
      versiculo: versiculo
    });
    window.location.href = `/app/biblia?${params.toString()}`;
  }
  
  async function deleteAnnotation(id) {
    const confirm = await showConfirmation('Tem certeza que deseja excluir esta anotação?', 'Excluir Anotação');
    if (!confirm) return;
    
    try {
      const response = await makeAuthenticatedRequest(`/anotacoes/${id}`, {
        method: 'DELETE'
      });
      
      const result = await response.json();
      
      if (!response.ok) {
        throw new Error(result.message || 'Erro ao excluir anotação');
      }
      
      showFeedback('Anotação excluída com sucesso!', false);
      
      // Recarregar a lista
      await loadAnnotations();
      const currentFilter = document.getElementById('filtro-visibilidade')?.value || 'todos';
      renderAnnotations(currentFilter);
    } catch (error) {
      console.error('Erro ao excluir anotação:', error);
      showFeedback(error.message || 'Erro ao excluir anotação', true);
    }
  }
  
  window.deleteAnnotation = deleteAnnotation;
  
  async function editAnnotation(id) {
    try {
      const response = await makeAuthenticatedRequest(`/anotacoes/${id}`, {
        method: 'GET'
      });
      
      const result = await response.json();
      
      if (!response.ok) {
        throw new Error(result.message || 'Erro ao carregar anotação');
      }
      
      const anotacao = result.anotacao;
      currentEditId = id;
      
      document.getElementById('edit-referencia').textContent = 
        `${anotacao.versao.toUpperCase()} - ${anotacao.livro} ${anotacao.capitulo}:${anotacao.versiculo}`;
      document.getElementById('edit-versiculo').textContent = `"${anotacao.texto_versiculo}"`;
      document.getElementById('edit-texto').value = anotacao.texto_anotacao;
      document.getElementById('edit-visibilidade').value = anotacao.visibilidade === 'public' ? 'publico' : 'privado';
      
      document.getElementById('editModal').style.display = 'flex';
    } catch (error) {
      console.error('Erro ao carregar anotação para edição:', error);
      showFeedback(error.message || 'Erro ao carregar anotação', true);
    }
  }
  
  window.editAnnotation = editAnnotation;
  
  async function saveEdit() {
    const texto = document.getElementById('edit-texto').value.trim();
    const visibilidade = document.getElementById('edit-visibilidade').value;
    
    if (!texto) {
      showFeedback('O texto da anotação não pode estar vazio', true);
      return;
    }
    
    try {
      const response = await makeAuthenticatedRequest(`/anotacoes/${currentEditId}`, {
        method: 'PUT',
        body: JSON.stringify({
          texto_anotacao: texto,
          visibilidade: visibilidade === 'publico' ? 'public' : 'private'
        })
      });
      
      const result = await response.json();
      
      if (!response.ok) {
        throw new Error(result.message || 'Erro ao atualizar anotação');
      }
      
      showFeedback('Anotação atualizada com sucesso!', false);
      closeEditModal();
      
      // Recarregar a lista
      await loadAnnotations();
      const currentFilter = document.getElementById('filtro-visibilidade')?.value || 'todos';
      renderAnnotations(currentFilter);
    } catch (error) {
      console.error('Erro ao salvar edição:', error);
      showFeedback(error.message || 'Erro ao salvar alterações', true);
    }
  }
  
  window.saveEdit = saveEdit;
  
  function closeEditModal() {
    document.getElementById('editModal').style.display = 'none';
    currentEditId = null;
    document.getElementById('edit-texto').value = '';
  }
  
  window.closeEditModal = closeEditModal;
  
  function renderAnnotations(filter = 'todos') {
    const container = document.getElementById('anotacoes-container');
    if (!container) return;
    
    container.innerHTML = '';
    
    let filtered = anotacoesData;
    if (filter === 'publico') {
      filtered = anotacoesData.filter(a => a.visibilidade === 'publico');
    } else if (filter === 'privado') {
      filtered = anotacoesData.filter(a => a.visibilidade === 'privado');
    }
    
    if (!filtered || filtered.length === 0) {
      container.innerHTML = `
        <div class="text-center text-gray-500 py-8">
          <i class="fas fa-inbox text-4xl mb-2"></i>
          <p>Nenhuma anotação encontrada.</p>
          <a href="/app/biblia" class="inline-block mt-4 text-indigo-600 hover:text-indigo-700">
            <i class="fas fa-bible mr-1"></i> Fazer anotações na Bíblia
          </a>
        </div>
      `;
      return;
    }
    
    filtered.forEach(anotacao => {
      const div = document.createElement('div');
      div.className = 'anotacao-card p-4 bg-indigo-50 rounded-lg border border-indigo-100';
      
      div.innerHTML = `
        <div class="flex justify-between items-start">
          <div class="flex-1 cursor-pointer" onclick="navigateToBible('${anotacao.versao}', '${anotacao.livro}', ${anotacao.capitulo}, ${anotacao.versiculo})">
            <p class="font-semibold text-indigo-700 text-lg">
              ${anotacao.versao.toUpperCase()} - ${anotacao.livro} ${anotacao.capitulo}:${anotacao.versiculo}
            </p>
            <p class="text-gray-600 mt-2 italic">"${anotacao.texto_versiculo.substring(0, 100)}${anotacao.texto_versiculo.length > 100 ? '...' : ''}"</p>
            <p class="text-gray-700 mt-3"><strong>Anotação:</strong> ${anotacao.texto_anotacao.substring(0, 150)}${anotacao.texto_anotacao.length > 150 ? '...' : ''}</p>
            <p class="text-sm text-gray-500 mt-2">
              <i class="fas fa-calendar-alt mr-1"></i> Criado em: ${new Date(anotacao.criado_em).toLocaleString('pt-BR')}
            </p>
          </div>
          <div class="flex flex-col items-end gap-2 ml-4">
            <span class="inline-block px-2 py-1 text-xs rounded-full ${anotacao.visibilidade === 'publico' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-700'}">
              <i class="fas ${anotacao.visibilidade === 'publico' ? 'fa-globe' : 'fa-lock'} mr-1"></i>
              ${anotacao.visibilidade === 'publico' ? 'Público' : 'Privado'}
            </span>
            <div class="flex gap-2">
              <button onclick="editAnnotation(${anotacao.id})" class="action-button bg-blue-100 text-blue-600 p-2 rounded-lg hover:bg-blue-200 transition" title="Editar">
                <i class="fas fa-edit"></i>
              </button>
              <button onclick="deleteAnnotation(${anotacao.id})" class="action-button bg-red-100 text-red-600 p-2 rounded-lg hover:bg-red-200 transition" title="Excluir">
                <i class="fas fa-trash-alt"></i>
              </button>
            </div>
          </div>
        </div>
      `;
      
      container.appendChild(div);
    });
  }
  
  async function loadAnnotations() {
    const container = document.getElementById('anotacoes-container');
    if (container) {
      container.innerHTML = `
        <div class="text-center text-gray-500 py-8">
          <i class="fas fa-spinner fa-spin text-4xl mb-2"></i>
          <p>Carregando anotações...</p>
        </div>
      `;
    }
    
    try {
      const response = await makeAuthenticatedRequest('/anotacoes', {
        method: 'GET'
      });
      
      const data = await response.json();
      
      if (!response.ok) {
        throw new Error(data.message || 'Erro ao carregar anotações');
      }
      
      anotacoesData = (data.anotacoes || []).map(anotacao => ({
        ...anotacao,
        visibilidade: anotacao.visibilidade === 'public' ? 'publico' : 'privado'
      }));
      
      const currentFilter = document.getElementById('filtro-visibilidade')?.value || 'todos';
      renderAnnotations(currentFilter);
    } catch (error) {
      console.error('Erro ao carregar anotações:', error);
      showFeedback(error.message || 'Erro ao carregar anotações', true);
      if (container) {
        container.innerHTML = `
          <div class="text-center text-red-500 py-8">
            <i class="fas fa-exclamation-triangle text-4xl mb-2"></i>
            <p>Erro ao carregar anotações. Tente novamente.</p>
            <button onclick="location.reload()" class="mt-4 bg-indigo-600 text-white px-4 py-2 rounded-lg">
              <i class="fas fa-sync-alt mr-1"></i> Recarregar
            </button>
          </div>
        `;
      }
    }
  }
  
  // Expor funções globais
  window.navigateToBible = navigateToBible;
  
  // Inicialização
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      loadAnnotations();
      
      const filtroSelect = document.getElementById('filtro-visibilidade');
      if (filtroSelect) {
        filtroSelect.addEventListener('change', () => {
          renderAnnotations(filtroSelect.value);
        });
      }
    });
  } else {
    loadAnnotations();
    
    const filtroSelect = document.getElementById('filtro-visibilidade');
    if (filtroSelect) {
      filtroSelect.addEventListener('change', () => {
        renderAnnotations(filtroSelect.value);
      });
    }
  }
})();
</script>