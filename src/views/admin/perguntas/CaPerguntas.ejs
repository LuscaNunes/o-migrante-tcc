<div class="container mx-auto p-6">
    <h1 class="text-2xl font-bold mb-6">Cadastro de Níveis e Perguntas</h1>
    
    <!-- ============================================ -->
    <!-- SEÇÃO 1: CADASTRO DE NÍVEIS -->
    <!-- ============================================ -->
    <div class="bg-white rounded-lg shadow-md p-6 mb-8">
        <h2 class="text-xl font-semibold mb-4 text-blue-600">
            <i class="fas fa-layer-group mr-2"></i>Cadastrar Novo Nível
        </h2>
        
        <form id="formCadastroNivel" class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Título do Nível *</label>
                    <input type="text" id="nivelTitulo" required
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                           placeholder="Ex: Iniciante, Intermediário, Avançado">
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">XP Total *</label>
                    <input type="number" id="nivelXpTotal" required value="100"
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                           placeholder="Pontos de experiência">
                </div>
            </div>
            
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Descrição *</label>
                <textarea id="nivelDescricao" rows="3" required
                          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                          placeholder="Descreva o que será aprendido neste nível..."></textarea>
            </div>
            
            <div class="flex gap-3">
                <button type="submit" 
                        class="bg-green-600 text-white px-6 py-2 rounded-lg hover:bg-green-700 transition flex items-center gap-2">
                    <i class="fas fa-save"></i> Salvar Nível
                </button>
                <button type="button" id="btnLimparNivel"
                        class="bg-gray-500 text-white px-6 py-2 rounded-lg hover:bg-gray-600 transition flex items-center gap-2">
                    <i class="fas fa-eraser"></i> Limpar
                </button>
            </div>
        </form>
        
        <div id="feedbackNivel" class="mt-4 hidden"></div>
    </div>
    
    <!-- ============================================ -->
    <!-- SEÇÃO 2: CADASTRO DE PERGUNTAS -->
    <!-- ============================================ -->
    <div class="bg-white rounded-lg shadow-md p-6 mb-8">
        <h2 class="text-xl font-semibold mb-4 text-blue-600">
            <i class="fas fa-question-circle mr-2"></i>Cadastrar Nova Pergunta
        </h2>
        
        <!-- Seletor de Nível -->
        <div class="mb-6">
            <label for="nivelSelect" class="block text-sm font-medium text-gray-700 mb-2">
                Selecione o Nível *
            </label>
            <select id="nivelSelect" required
                    class="w-full md:w-96 px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                <option value="">Carregando níveis...</option>
            </select>
        </div>

        <!-- Seletor de Tipo de Pergunta -->
        <div class="mb-6">
            <label for="tipoPergunta" class="block text-sm font-medium text-gray-700 mb-2">
                Tipo de Pergunta *
            </label>
            <select id="tipoPergunta" required
                    class="w-full md:w-96 px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                <option value="quiz">Múltipla Escolha (Quiz)</option>
                <option value="completar">Complete a Frase (Drag & Drop)</option>
            </select>
        </div>
        
        <!-- Formulário para Quiz (Múltipla Escolha) -->
        <form id="formCadastroPergunta" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Texto da Pergunta *</label>
                <textarea id="textoPergunta" rows="3" required
                          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                          placeholder="Digite a pergunta..."></textarea>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Resposta Correta *</label>
                    <input type="text" id="respostaCorreta" required
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 bg-green-50"
                           placeholder="Opção correta">
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Opção 1 (Errada) *</label>
                    <input type="text" id="opcao1" required
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 bg-red-50"
                           placeholder="Opção errada 1">
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Opção 2 (Errada) *</label>
                    <input type="text" id="opcao2" required
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 bg-red-50"
                           placeholder="Opção errada 2">
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Opção 3 (Errada) *</label>
                    <input type="text" id="opcao3" required
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 bg-red-50"
                           placeholder="Opção errada 3">
                </div>
            </div>
            
            <div class="flex gap-3">
                <button type="submit" 
                        class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition flex items-center gap-2">
                    <i class="fas fa-save"></i> Salvar Pergunta
                </button>
                <button type="button" id="btnLimparPergunta"
                        class="bg-gray-500 text-white px-6 py-2 rounded-lg hover:bg-gray-600 transition flex items-center gap-2">
                    <i class="fas fa-eraser"></i> Limpar
                </button>
            </div>
        </form>

        <!-- Formulário para Complete a Frase (Drag & Drop) - Inicialmente escondido -->
        <form id="formCadastroCompletar" class="space-y-4 hidden">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Frase Incompleta *</label>
                <textarea id="textoFrase" rows="3" required
                          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                          placeholder='Ex: Deus disse haja {_______},é houve luz. Use {_______} para indicar a lacuna'></textarea>
                <p class="text-xs text-gray-500 mt-1">Use <code class="bg-gray-100 px-1">{_______}</code> para marcar onde a palavra deve ser encaixada</p>
            </div>
            
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Palavra Correta *</label>
                <input type="text" id="palavraCorreta" required
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 bg-green-50"
                       placeholder="Ex: Luz">
            </div>
            
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Opções de Palavras (separadas por vírgula) *</label>
                <input type="text" id="opcoesPalavras" required
                       class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                       placeholder="Ex: Luz, Escuridão, Céu, Terra">
                <p class="text-xs text-gray-500 mt-1">Inclua a palavra correta entre as opções. Mínimo 2 opções.</p>
            </div>
            
            <div class="flex gap-3">
                <button type="submit" 
                        class="bg-green-600 text-white px-6 py-2 rounded-lg hover:bg-green-700 transition flex items-center gap-2">
                    <i class="fas fa-save"></i> Salvar Complete a Frase
                </button>
                <button type="button" id="btnLimparCompletar"
                        class="bg-gray-500 text-white px-6 py-2 rounded-lg hover:bg-gray-600 transition flex items-center gap-2">
                    <i class="fas fa-eraser"></i> Limpar
                </button>
            </div>
        </form>
        
        <div id="feedbackPergunta" class="mt-4 hidden"></div>
    </div>
    
    <!-- ============================================ -->
    <!-- SEÇÃO 3: LISTA DE PERGUNTAS DO NÍVEL -->
    <!-- ============================================ -->
    <div class="bg-white rounded-lg shadow-md p-6">
        <div class="flex justify-between items-center mb-4">
            <h2 class="text-xl font-semibold text-blue-600">
                <i class="fas fa-list mr-2"></i>Perguntas do Nível
            </h2>
            <button id="btnAtualizarPerguntas" 
                    class="bg-gray-500 text-white px-4 py-2 rounded-lg hover:bg-gray-600 transition text-sm flex items-center gap-2">
                <i class="fas fa-sync-alt"></i> Atualizar
            </button>
        </div>
        
        <!-- Abas para alternar entre os tipos de pergunta -->
        <div class="flex border-b border-gray-200 mb-4">
            <button id="tabQuiz" class="tab-button px-4 py-2 text-sm font-medium text-gray-600 hover:text-blue-600 transition border-b-2 border-transparent">
                <i class="fas fa-question-circle mr-1"></i> Quiz
            </button>
            <button id="tabCompletar" class="tab-button px-4 py-2 text-sm font-medium text-gray-600 hover:text-blue-600 transition border-b-2 border-transparent">
                <i class="fas fa-puzzle-piece mr-1"></i> Complete a Frase
            </button>
        </div>
        
        <!-- Lista de perguntas do tipo Quiz -->
        <div id="listaPerguntasQuiz" class="space-y-4">
            <div class="text-center text-gray-500 py-8">
                <i class="fas fa-info-circle mr-2"></i> Selecione um nível para ver as perguntas do Quiz
            </div>
        </div>
        
        <!-- Lista de perguntas do tipo Complete a Frase -->
        <div id="listaPerguntasCompletar" class="space-y-4 hidden">
            <div class="text-center text-gray-500 py-8">
                <i class="fas fa-info-circle mr-2"></i> Selecione um nível para ver as perguntas de Complete a Frase
            </div>
        </div>
    </div>
</div>

<script>
let niveis = [];
let nivelSelecionado = null;
let abaAtual = 'quiz'; // 'quiz' ou 'completar'

// Função para mostrar feedback
function showFeedback(elementId, message, isSuccess = true) {
    const element = document.getElementById(elementId);
    element.textContent = message;
    element.className = `mt-4 p-3 rounded-lg ${isSuccess ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`;
    element.classList.remove('hidden');
    
    setTimeout(() => {
        element.classList.add('hidden');
    }, 3000);
}

// Função para escapar HTML
function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

// ============================================
// ALTERNAR ENTRE FORMULÁRIOS
// ============================================
function toggleFormulario() {
    const tipo = document.getElementById('tipoPergunta').value;
    const formQuiz = document.getElementById('formCadastroPergunta');
    const formCompletar = document.getElementById('formCadastroCompletar');
    
    if (tipo === 'quiz') {
        formQuiz.classList.remove('hidden');
        formCompletar.classList.add('hidden');
    } else {
        formQuiz.classList.add('hidden');
        formCompletar.classList.remove('hidden');
    }
}

// ============================================
// ALTERNAR ENTRE ABAS
// ============================================
function toggleAba(aba) {
    abaAtual = aba;
    const listaQuiz = document.getElementById('listaPerguntasQuiz');
    const listaCompletar = document.getElementById('listaPerguntasCompletar');
    const tabQuiz = document.getElementById('tabQuiz');
    const tabCompletar = document.getElementById('tabCompletar');
    
    if (aba === 'quiz') {
        listaQuiz.classList.remove('hidden');
        listaCompletar.classList.add('hidden');
        tabQuiz.classList.add('border-blue-500', 'text-blue-600');
        tabQuiz.classList.remove('border-transparent', 'text-gray-600');
        tabCompletar.classList.remove('border-blue-500', 'text-blue-600');
        tabCompletar.classList.add('border-transparent', 'text-gray-600');
        if (nivelSelecionado) carregarPerguntasQuiz(nivelSelecionado);
    } else {
        listaQuiz.classList.add('hidden');
        listaCompletar.classList.remove('hidden');
        tabCompletar.classList.add('border-blue-500', 'text-blue-600');
        tabCompletar.classList.remove('border-transparent', 'text-gray-600');
        tabQuiz.classList.remove('border-blue-500', 'text-blue-600');
        tabQuiz.classList.add('border-transparent', 'text-gray-600');
        if (nivelSelecionado) carregarPerguntasCompletar(nivelSelecionado);
    }
}

// ============================================
// CADASTRO DE NÍVEL
// ============================================
async function cadastrarNivel(event) {
    event.preventDefault();
    
    const token = localStorage.getItem('token');
    const dados = {
        titulo: document.getElementById('nivelTitulo').value.trim(),
        descricao: document.getElementById('nivelDescricao').value.trim(),
        xp_total: parseInt(document.getElementById('nivelXpTotal').value)
    };
    
    if (!dados.titulo || !dados.descricao || !dados.xp_total) {
        showFeedback('feedbackNivel', 'Preencha todos os campos do nível!', false);
        return;
    }
    
    try {
        const response = await fetch('/niveis', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(dados)
        });
        
        const result = await response.json();
        
        if (!response.ok) {
            throw new Error(result.message || 'Erro ao cadastrar nível');
        }
        
        showFeedback('feedbackNivel', result.message || 'Nível cadastrado com sucesso!', true);
        
        document.getElementById('formCadastroNivel').reset();
        document.getElementById('nivelXpTotal').value = '100';
        
        await carregarNiveis();
        
    } catch (error) {
        console.error('Erro ao cadastrar nível:', error);
        showFeedback('feedbackNivel', error.message, false);
    }
}

// ============================================
// CADASTRO DE PERGUNTA (QUIZ)
// ============================================
async function cadastrarPergunta(event) {
    event.preventDefault();
    
    const token = localStorage.getItem('token');
    
    if (!nivelSelecionado) {
        showFeedback('feedbackPergunta', 'Selecione um nível primeiro!', false);
        return;
    }
    
    const dados = {
        nivel_id: parseInt(nivelSelecionado),
        texto: document.getElementById('textoPergunta').value.trim(),
        resposta_correta: document.getElementById('respostaCorreta').value.trim(),
        opcao1: document.getElementById('opcao1').value.trim(),
        opcao2: document.getElementById('opcao2').value.trim(),
        opcao3: document.getElementById('opcao3').value.trim()
    };
    
    if (!dados.texto || !dados.resposta_correta || !dados.opcao1 || !dados.opcao2 || !dados.opcao3) {
        showFeedback('feedbackPergunta', 'Preencha todos os campos da pergunta!', false);
        return;
    }
    
    try {
        const response = await fetch('/perguntas', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(dados)
        });
        
        const result = await response.json();
        
        if (!response.ok) {
            throw new Error(result.message || 'Erro ao cadastrar pergunta');
        }
        
        showFeedback('feedbackPergunta', result.message || 'Pergunta cadastrada com sucesso!', true);
        
        document.getElementById('formCadastroPergunta').reset();
        
        if (nivelSelecionado && abaAtual === 'quiz') {
            await carregarPerguntasQuiz(nivelSelecionado);
        }
        
    } catch (error) {
        console.error('Erro ao cadastrar pergunta:', error);
        showFeedback('feedbackPergunta', error.message, false);
    }
}

// ============================================
// CADASTRO DE COMPLETE A FRASE
// ============================================
async function cadastrarCompletar(event) {
    event.preventDefault();
    
    const token = localStorage.getItem('token');
    
    if (!nivelSelecionado) {
        showFeedback('feedbackPergunta', 'Selecione um nível primeiro!', false);
        return;
    }
    
    const textoFrase = document.getElementById('textoFrase').value.trim();
    const palavraCorreta = document.getElementById('palavraCorreta').value.trim();
    const opcoesPalavras = document.getElementById('opcoesPalavras').value.trim();
    
    if (!textoFrase || !palavraCorreta || !opcoesPalavras) {
        showFeedback('feedbackPergunta', 'Preencha todos os campos!', false);
        return;
    }
    
    // Verificar se a frase tem o placeholder
    if (!textoFrase.includes('{_______}')) {
        showFeedback('feedbackPergunta', 'A frase deve conter {_______} para indicar a lacuna!', false);
        return;
    }
    
    // Converter opções em array
    const palavrasArray = opcoesPalavras.split(',').map(p => p.trim());
    if (palavrasArray.length < 2) {
        showFeedback('feedbackPergunta', 'Informe pelo menos 2 opções de palavras!', false);
        return;
    }
    
    // Verificar se a palavra correta está nas opções
    if (!palavrasArray.includes(palavraCorreta)) {
        showFeedback('feedbackPergunta', 'A palavra correta deve estar entre as opções!', false);
        return;
    }
    
    const dados = {
        nivel_id: parseInt(nivelSelecionado),
        texto_frase: textoFrase,
        resposta_correta: palavraCorreta,
        palavras_opcoes: palavrasArray
    };
    
    try {
        const response = await fetch('/completar', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(dados)
        });
        
        const result = await response.json();
        
        if (!response.ok) {
            throw new Error(result.message || 'Erro ao cadastrar pergunta');
        }
        
        showFeedback('feedbackPergunta', result.message || 'Pergunta de Complete a Frase cadastrada com sucesso!', true);
        
        document.getElementById('formCadastroCompletar').reset();
        
        if (nivelSelecionado && abaAtual === 'completar') {
            await carregarPerguntasCompletar(nivelSelecionado);
        }
        
    } catch (error) {
        console.error('Erro ao cadastrar pergunta:', error);
        showFeedback('feedbackPergunta', error.message, false);
    }
}

// ============================================
// CARREGAR NÍVEIS
// ============================================
async function carregarNiveis() {
    try {
        const token = localStorage.getItem('token');
        const response = await fetch('/niveis', {
            headers: {
                'Authorization': `Bearer ${token}`
            }
        });
        
        if (!response.ok) throw new Error('Erro ao carregar níveis');
        
        const data = await response.json();
        niveis = Array.isArray(data) ? data : (data.niveis || []);
        
        const select = document.getElementById('nivelSelect');
        select.innerHTML = '<option value="">Selecione um nível</option>';
        
        niveis.forEach(nivel => {
            select.innerHTML += `<option value="${nivel.id}">${escapeHtml(nivel.titulo)} (ID: ${nivel.id})</option>`;
        });
        
    } catch (error) {
        console.error('Erro ao carregar níveis:', error);
        const select = document.getElementById('nivelSelect');
        select.innerHTML = '<option value="">Erro ao carregar níveis</option>';
    }
}

// ============================================
// CARREGAR PERGUNTAS DO QUIZ
// ============================================
async function carregarPerguntasQuiz(nivelId) {
    if (!nivelId) return;
    
    const container = document.getElementById('listaPerguntasQuiz');
    container.innerHTML = '<div class="text-center py-8"><i class="fas fa-spinner fa-spin mr-2"></i> Carregando perguntas do Quiz...</div>';
    
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`/perguntas?nivel_id=${nivelId}`, {
            headers: {
                'Authorization': `Bearer ${token}`
            }
        });
        
        if (!response.ok) throw new Error('Erro ao carregar perguntas');
        
        const data = await response.json();
        const perguntas = Array.isArray(data) ? data : (data.perguntas || []);
        
        if (perguntas.length === 0) {
            container.innerHTML = `
                <div class="text-center text-gray-500 py-8">
                    <i class="fas fa-info-circle mr-2"></i> 
                    Nenhuma pergunta de Quiz cadastrada para este nível.
                </div>
            `;
            return;
        }
        
        container.innerHTML = perguntas.map(pergunta => `
            <div class="border border-gray-200 rounded-lg p-4 hover:shadow-md transition">
                <div class="flex justify-between items-start">
                    <div class="flex-1">
                        <p class="font-semibold text-gray-800 mb-2">
                            <i class="fas fa-question-circle text-blue-500 mr-2"></i>
                            ${escapeHtml(pergunta.texto)}
                        </p>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-2 mt-3 text-sm">
                            <div class="flex items-center">
                                <span class="w-24 text-gray-600">Correta:</span>
                                <span class="text-green-600 font-medium">✓ ${escapeHtml(pergunta.resposta_correta)}</span>
                            </div>
                            <div class="flex items-center">
                                <span class="w-24 text-gray-600">Opção 1:</span>
                                <span class="text-gray-700">${escapeHtml(pergunta.opcao1)}</span>
                            </div>
                            <div class="flex items-center">
                                <span class="w-24 text-gray-600">Opção 2:</span>
                                <span class="text-gray-700">${escapeHtml(pergunta.opcao2)}</span>
                            </div>
                            <div class="flex items-center">
                                <span class="w-24 text-gray-600">Opção 3:</span>
                                <span class="text-gray-700">${escapeHtml(pergunta.opcao3)}</span>
                            </div>
                        </div>
                    </div>
                    <div class="text-xs text-gray-400 ml-4">
                        ID: ${pergunta.id}
                    </div>
                </div>
            </div>
        `).join('');
        
    } catch (error) {
        console.error('Erro ao carregar perguntas:', error);
        container.innerHTML = `
            <div class="text-center text-red-500 py-8">
                <i class="fas fa-exclamation-triangle mr-2"></i>
                Erro ao carregar perguntas. Tente novamente.
            </div>
        `;
    }
}

// ============================================
// CARREGAR PERGUNTAS DE COMPLETE A FRASE
// ============================================
async function carregarPerguntasCompletar(nivelId) {
    if (!nivelId) return;
    
    const container = document.getElementById('listaPerguntasCompletar');
    container.innerHTML = '<div class="text-center py-8"><i class="fas fa-spinner fa-spin mr-2"></i> Carregando perguntas de Complete a Frase...</div>';
    
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`/completar?nivel_id=${nivelId}`, {
            headers: {
                'Authorization': `Bearer ${token}`
            }
        });
        
        if (!response.ok) throw new Error('Erro ao carregar perguntas');
        
        const data = await response.json();
        const perguntas = data.perguntas || [];
        
        if (perguntas.length === 0) {
            container.innerHTML = `
                <div class="text-center text-gray-500 py-8">
                    <i class="fas fa-info-circle mr-2"></i> 
                    Nenhuma pergunta de Complete a Frase cadastrada para este nível.
                </div>
            `;
            return;
        }
        
        container.innerHTML = perguntas.map(pergunta => `
            <div class="border border-gray-200 rounded-lg p-4 hover:shadow-md transition">
                <div class="flex justify-between items-start">
                    <div class="flex-1">
                        <p class="font-semibold text-gray-800 mb-2">
                            <i class="fas fa-puzzle-piece text-green-500 mr-2"></i>
                            ${escapeHtml(pergunta.texto_frase)}
                        </p>
                        <div class="mt-3 text-sm">
                            <div class="flex items-center mb-1">
                                <span class="w-24 text-gray-600">Resposta:</span>
                                <span class="text-green-600 font-medium">✓ ${escapeHtml(pergunta.resposta_correta)}</span>
                            </div>
                            <div class="flex items-center flex-wrap">
                                <span class="w-24 text-gray-600">Opções:</span>
                                <span class="text-gray-700">${escapeHtml(pergunta.palavras_opcoes?.join(', ') || '')}</span>
                            </div>
                        </div>
                    </div>
                    <div class="text-xs text-gray-400 ml-4">
                        ID: ${pergunta.id}
                    </div>
                </div>
            </div>
        `).join('');
        
    } catch (error) {
        console.error('Erro ao carregar perguntas:', error);
        container.innerHTML = `
            <div class="text-center text-red-500 py-8">
                <i class="fas fa-exclamation-triangle mr-2"></i>
                Erro ao carregar perguntas. Tente novamente.
            </div>
        `;
    }
}

// ============================================
// EVENT LISTENERS
// ============================================
document.addEventListener('DOMContentLoaded', () => {
    const token = localStorage.getItem('token');
    if (!token) {
        alert('Você precisa estar logado!');
        window.location.href = '/';
        return;
    }
    
    carregarNiveis();
    
    // Alternar entre tipos de formulário
    document.getElementById('tipoPergunta').addEventListener('change', toggleFormulario);
    
    // Abas
    document.getElementById('tabQuiz').addEventListener('click', () => toggleAba('quiz'));
    document.getElementById('tabCompletar').addEventListener('click', () => toggleAba('completar'));
    
    // Selecionar nível
    document.getElementById('nivelSelect').addEventListener('change', (e) => {
        nivelSelecionado = e.target.value;
        if (nivelSelecionado) {
            if (abaAtual === 'quiz') {
                carregarPerguntasQuiz(nivelSelecionado);
            } else {
                carregarPerguntasCompletar(nivelSelecionado);
            }
        } else {
            document.getElementById('listaPerguntasQuiz').innerHTML = `
                <div class="text-center text-gray-500 py-8">
                    <i class="fas fa-info-circle mr-2"></i> Selecione um nível para ver as perguntas
                </div>
            `;
            document.getElementById('listaPerguntasCompletar').innerHTML = `
                <div class="text-center text-gray-500 py-8">
                    <i class="fas fa-info-circle mr-2"></i> Selecione um nível para ver as perguntas
                </div>
            `;
        }
    });
    
    // Cadastrar nível
    document.getElementById('formCadastroNivel').addEventListener('submit', cadastrarNivel);
    
    // Cadastrar pergunta (Quiz)
    document.getElementById('formCadastroPergunta').addEventListener('submit', cadastrarPergunta);
    
    // Cadastrar Complete a Frase
    document.getElementById('formCadastroCompletar').addEventListener('submit', cadastrarCompletar);
    
    // Limpar formulário de nível
    document.getElementById('btnLimparNivel').addEventListener('click', () => {
        document.getElementById('formCadastroNivel').reset();
        document.getElementById('nivelXpTotal').value = '100';
    });
    
    // Limpar formulário de pergunta (Quiz)
    document.getElementById('btnLimparPergunta').addEventListener('click', () => {
        document.getElementById('formCadastroPergunta').reset();
    });
    
    // Limpar formulário de Complete a Frase
    document.getElementById('btnLimparCompletar').addEventListener('click', () => {
        document.getElementById('formCadastroCompletar').reset();
    });
    
    // Atualizar perguntas
    document.getElementById('btnAtualizarPerguntas').addEventListener('click', () => {
        if (nivelSelecionado) {
            if (abaAtual === 'quiz') {
                carregarPerguntasQuiz(nivelSelecionado);
                showFeedback('feedbackPergunta', 'Perguntas do Quiz atualizadas!', true);
            } else {
                carregarPerguntasCompletar(nivelSelecionado);
                showFeedback('feedbackPergunta', 'Perguntas de Complete a Frase atualizadas!', true);
            }
        }
    });
});
</script>