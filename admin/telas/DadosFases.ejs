<div class="container mx-auto p-6">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold">Gerenciamento de Níveis</h1>
        <button id="logoutButton" class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600 transition">Sair</button>
    </div>

    <!-- Botão de Ordenação -->
    <div class="mb-4 flex justify-end">
        <button id="ordenarBtn" class="bg-green-500 text-white px-4 py-2 rounded-lg hover:bg-green-600 transition shadow-md flex items-center gap-2">
            <i class="fas fa-sort"></i> Salvar Ordem dos Níveis
        </button>
    </div>

    <!-- Lista de Níveis -->
    <div class="bg-white rounded-lg shadow-md p-6">
        <h2 class="text-xl font-semibold mb-4 text-blue-600">
            <i class="fas fa-layer-group mr-2"></i>Níveis Cadastrados
        </h2>
        <ul id="niveisList" class="space-y-4">
            <li class="text-center text-gray-500 py-8">
                <i class="fas fa-spinner fa-spin mr-2"></i> Carregando níveis...
            </li>
        </ul>
    </div>
</div>

<!-- Modal de Situação -->
<div id="statusModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-md p-6">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-xl font-semibold">Situação do Nível</h3>
            <button class="closeModal text-gray-500 hover:text-gray-700">&times;</button>
        </div>
        <div id="statusContent"></div>
        <div id="positionInput" class="hidden mt-4">
            <label class="block text-sm font-medium text-gray-700 mb-2">Posição:</label>
            <input type="number" id="posicao" class="w-full px-3 py-2 border rounded-lg" placeholder="Informe a posição" />
        </div>
        <button id="toggleStatusButton" class="w-full mt-4 px-4 py-2 rounded-lg transition">Desativar</button>
        <button id="saveChangesButton" class="hidden w-full mt-4 bg-blue-500 text-white px-4 py-2 rounded-lg hover:bg-blue-600 transition">Salvar Alterações</button>
    </div>
</div>

<!-- Modal de Perguntas -->
<div id="questionsModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-3xl max-h-[80vh] overflow-y-auto p-6">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-xl font-semibold" id="questionsModalTitle">Perguntas do Nível</h3>
            <button class="closeQuestionsModal text-gray-500 hover:text-gray-700">&times;</button>
        </div>
        <div id="questionsList"></div>
    </div>
</div>

<!-- Modal de Editar Pergunta -->
<div id="editQuestionModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-md p-6">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-xl font-semibold">Editar Pergunta</h3>
            <button class="closeEditModal text-gray-500 hover:text-gray-700">&times;</button>
        </div>
        <form id="editQuestionForm">
            <div class="mb-3">
                <label class="block text-sm font-medium text-gray-700 mb-2">Texto da Pergunta:</label>
                <textarea id="editTexto" rows="3" class="w-full px-3 py-2 border rounded-lg" required></textarea>
            </div>
            <div class="mb-3">
                <label class="block text-sm font-medium text-gray-700 mb-2">Opção 1 (Correta):</label>
                <input type="text" id="editOpcao1" class="w-full px-3 py-2 border rounded-lg bg-green-50" required>
            </div>
            <div class="mb-3">
                <label class="block text-sm font-medium text-gray-700 mb-2">Opção 2 (Errada):</label>
                <input type="text" id="editOpcao2" class="w-full px-3 py-2 border rounded-lg bg-red-50" required>
            </div>
            <div class="mb-3">
                <label class="block text-sm font-medium text-gray-700 mb-2">Opção 3 (Errada):</label>
                <input type="text" id="editOpcao3" class="w-full px-3 py-2 border rounded-lg bg-red-50" required>
            </div>
            <div class="mb-3">
                <label class="block text-sm font-medium text-gray-700 mb-2">Resposta Correta:</label>
                <select id="editRespostaCorreta" class="w-full px-3 py-2 border rounded-lg" required>
                    <option value="opcao1">Opção 1</option>
                    <option value="opcao2">Opção 2</option>
                    <option value="opcao3">Opção 3</option>
                </select>
            </div>
            <div class="flex gap-2 mt-4">
                <button type="submit" class="flex-1 bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 transition">Salvar</button>
                <button type="button" id="cancelEditBtn" class="flex-1 bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition">Cancelar</button>
            </div>
        </form>
    </div>
</div>

<style>
    .nivel-item {
        transition: all 0.3s ease;
        cursor: default;
    }
    .nivel-item:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }
    .ordem-handle {
        cursor: move;
        color: #9ca3af;
    }
    .ordem-handle:hover {
        color: #3b82f6;
    }
    .dragging {
        opacity: 0.5;
    }
    .drag-over {
        border-top: 2px solid #3b82f6;
        margin-top: -2px;
    }
    .pergunta-card {
        border-left: 3px solid #3b82f6;
        padding: 12px;
        margin-bottom: 12px;
        background: #f9fafb;
        border-radius: 8px;
    }
    .pergunta-card:hover {
        background: #f3f4f6;
    }
    .opcao-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 10px;
        margin: 6px 0;
        border-radius: 6px;
    }
    .opcao-correta {
        background-color: #d1fae5;
        border: 1px solid #10b981;
    }
    .opcao-normal {
        background-color: #f3f4f6;
        border: 1px solid #e5e7eb;
    }
</style>

<script>
function showFeedback(message, isSuccess = true) {
    const feedbackDiv = document.createElement('div');
    feedbackDiv.className = `fixed bottom-4 right-4 p-4 rounded-lg shadow-lg z-50 transition-opacity duration-300 ${isSuccess ? 'bg-green-500' : 'bg-red-500'} text-white`;
    feedbackDiv.textContent = message;
    document.body.appendChild(feedbackDiv);
    setTimeout(() => feedbackDiv.remove(), 3000);
}

function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

let currentNivelId = null;
let currentEditPerguntaId = null;
let niveisOrdenados = [];

// ============================================
// CARREGAR NÍVEIS
// ============================================
async function carregarNiveis() {
    try {
        const token = localStorage.getItem('token');
        const response = await fetch('/niveis', {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        
        if (!response.ok) {
            if (response.status === 401) {
                localStorage.removeItem('token');
                window.location.href = '/';
                return;
            }
            throw new Error('Erro ao carregar níveis');
        }
        
        const data = await response.json();
        niveisOrdenados = data.niveis || [];
        renderizarNiveis(niveisOrdenados);
    } catch (error) {
        console.error('Erro:', error);
        document.getElementById('niveisList').innerHTML = `
            <li class="text-center text-red-500 py-8">
                <i class="fas fa-exclamation-triangle mr-2"></i> Erro ao carregar níveis
            </li>
        `;
    }
}

// ============================================
// RENDERIZAR NÍVEIS
// ============================================
function renderizarNiveis(niveis) {
    const container = document.getElementById('niveisList');
    
    if (!niveis || niveis.length === 0) {
        container.innerHTML = '<li class="text-center text-gray-500 py-8">Nenhum nível cadastrado.</li>';
        return;
    }
    
    container.innerHTML = niveis.map(nivel => `
        <li class="nivel-item bg-gray-100 p-4 rounded-lg shadow-md" data-id="${nivel.id}">
            <div class="flex justify-between items-center flex-wrap gap-2">
                <div class="flex items-center gap-3 flex-1">
                    <i class="fas fa-grip-vertical ordem-handle text-gray-400 hover:text-blue-500 cursor-move"></i>
                    <div>
                        <span class="font-bold text-lg">${escapeHtml(nivel.titulo)}</span>
                        ${nivel.posicao ? `<span class="text-sm text-gray-500 ml-2">(Pos: ${nivel.posicao})</span>` : ''}
                        <span class="text-sm ml-2 px-2 py-1 rounded ${nivel.ativo ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}">
                            ${nivel.ativo ? 'Ativo' : 'Inativo'}
                        </span>
                    </div>
                </div>
                <div class="flex gap-2 flex-wrap">
                    <button onclick="mostrarDetalhes(${nivel.id})" class="bg-blue-500 text-white px-3 py-1 rounded-lg hover:bg-blue-600 transition text-sm">
                        <i class="fas fa-info-circle mr-1"></i>Detalhes
                    </button>
                    <button onclick="mostrarPerguntas(${nivel.id}, '${escapeHtml(nivel.titulo)}')" class="bg-purple-500 text-white px-3 py-1 rounded-lg hover:bg-purple-600 transition text-sm">
                        <i class="fas fa-question-circle mr-1"></i>Perguntas
                    </button>
                    <button onclick="mostrarModalSituacao(${nivel.id}, '${escapeHtml(nivel.titulo)}', ${nivel.ativo})" class="bg-yellow-500 text-white px-3 py-1 rounded-lg hover:bg-yellow-600 transition text-sm">
                        <i class="fas fa-toggle-${nivel.ativo ? 'on' : 'off'} mr-1"></i>Situação
                    </button>
                </div>
            </div>
            <div id="detalhes${nivel.id}" class="mt-4 hidden">
                <p class="text-gray-600"><strong>Descrição:</strong> ${escapeHtml(nivel.descricao || 'Sem descrição')}</p>
                <p class="text-gray-600"><strong>XP Total:</strong> ${nivel.xp_total || 'Não definido'}</p>
            </div>
        </li>
    `).join('');
    
    configurarDragAndDrop();
}

// ============================================
// DRAG AND DROP
// ============================================
function configurarDragAndDrop() {
    const items = document.querySelectorAll('#niveisList .nivel-item');
    let draggedItem = null;

    items.forEach(item => {
        item.setAttribute('draggable', 'true');
        
        item.addEventListener('dragstart', (e) => {
            draggedItem = item;
            item.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
        });

        item.addEventListener('dragend', () => {
            item.classList.remove('dragging');
            draggedItem = null;
            document.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
        });

        item.addEventListener('dragover', (e) => {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
        });

        item.addEventListener('dragenter', (e) => {
            e.preventDefault();
            if (draggedItem !== item) item.classList.add('drag-over');
        });

        item.addEventListener('dragleave', () => item.classList.remove('drag-over'));

        item.addEventListener('drop', (e) => {
            e.preventDefault();
            item.classList.remove('drag-over');
            
            if (draggedItem && draggedItem !== item) {
                const parent = document.getElementById('niveisList');
                const draggedIndex = Array.from(parent.children).indexOf(draggedItem);
                const targetIndex = Array.from(parent.children).indexOf(item);
                
                if (draggedIndex < targetIndex) {
                    parent.insertBefore(draggedItem, item.nextSibling);
                } else {
                    parent.insertBefore(draggedItem, item);
                }
                
                const novaOrdem = Array.from(parent.children).map(li => parseInt(li.dataset.id));
                niveisOrdenados = novaOrdem.map(id => niveisOrdenados.find(n => n.id === id)).filter(Boolean);
            }
        });
    });
}

// ============================================
// SALVAR ORDEM
// ============================================
document.getElementById('ordenarBtn')?.addEventListener('click', async () => {
    try {
        const token = localStorage.getItem('token');
        const items = document.querySelectorAll('#niveisList .nivel-item');
        
        for (let index = 0; index < items.length; index++) {
            const item = items[index];
            const nivelId = parseInt(item.dataset.id);
            const novaPosicao = index + 1;
            
            const responseGet = await fetch(`/niveis/${nivelId}`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const nivel = await responseGet.json();
            
            if (nivel.ativo) {
                await fetch(`/niveis/${nivelId}/ativar`, {
                    method: "PUT",
                    headers: {
                        "Content-Type": "application/json",
                        "Authorization": `Bearer ${token}`
                    },
                    body: JSON.stringify({ ativo: true, posicao: novaPosicao })
                });
            }
        }
        
        showFeedback("Ordem salva com sucesso!", true);
        carregarNiveis();
    } catch (error) {
        console.error('Erro:', error);
        showFeedback("Erro ao salvar ordem: " + error.message, false);
    }
});

// ============================================
// MOSTRAR DETALHES
// ============================================
function mostrarDetalhes(nivelId) {
    const detalhes = document.getElementById(`detalhes${nivelId}`);
    if (detalhes) {
        detalhes.classList.toggle('hidden');
    }
}

// ============================================
// MODAL DE SITUAÇÃO
// ============================================
async function mostrarModalSituacao(nivelId, titulo, ativo) {
    currentNivelId = nivelId;
    const modal = document.getElementById('statusModal');
    const statusContent = document.getElementById('statusContent');
    const positionInput = document.getElementById('positionInput');
    const posicaoInput = document.getElementById('posicao');
    const toggleButton = document.getElementById('toggleStatusButton');
    const saveButton = document.getElementById('saveChangesButton');

    positionInput.classList.add('hidden');
    toggleButton.classList.remove('hidden');
    saveButton.classList.add('hidden');
    modal.classList.remove('hidden');
    modal.classList.add('flex');

    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`/niveis/${nivelId}`, {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await response.json();

        statusContent.innerHTML = `
            <p class="mb-2"><strong>Nível:</strong> ${escapeHtml(data.titulo)}</p>
            <p class="mb-2"><strong>Situação:</strong> <span class="font-bold ${data.ativo ? 'text-green-600' : 'text-red-600'}">${data.ativo ? 'Ativo' : 'Inativo'}</span></p>
            ${data.ativo && data.posicao ? `<p><strong>Posição:</strong> ${data.posicao}</p>` : ''}
        `;

        toggleButton.textContent = data.ativo ? 'Desativar Nível' : 'Ativar Nível';
        toggleButton.className = `w-full mt-4 px-4 py-2 rounded-lg transition text-white ${data.ativo ? 'bg-red-500 hover:bg-red-600' : 'bg-green-500 hover:bg-green-600'}`;
        
        toggleButton.onclick = async () => {
            if (!data.ativo) {
                positionInput.classList.remove('hidden');
                toggleButton.classList.add('hidden');
                saveButton.classList.remove('hidden');
            } else {
                if (confirm(`Desativar "${data.titulo}"?`)) {
                    await alterarStatusNivel(nivelId, false, null);
                    modal.classList.add('hidden');
                }
            }
        };

        saveButton.onclick = async () => {
            const novaPosicao = parseInt(posicaoInput.value);
            if (!novaPosicao || novaPosicao <= 0) {
                showFeedback("Informe uma posição válida!", false);
                return;
            }
            await alterarStatusNivel(nivelId, true, novaPosicao);
            modal.classList.add('hidden');
        };
    } catch (error) {
        statusContent.innerHTML = '<p class="text-red-500">Erro ao carregar dados.</p>';
    }

    document.querySelectorAll('#statusModal .closeModal').forEach(btn => {
        btn.onclick = () => modal.classList.add('hidden');
    });
}

async function alterarStatusNivel(nivelId, ativo, posicao) {
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`/niveis/${nivelId}/ativar`, {
            method: "PUT",
            headers: {
                "Content-Type": "application/json",
                "Authorization": `Bearer ${token}`
            },
            body: JSON.stringify({ ativo, posicao })
        });
        
        if (!response.ok) throw new Error("Erro ao alterar status");
        
        showFeedback(`Nível ${ativo ? 'ativado' : 'desativado'}!`, true);
        carregarNiveis();
    } catch (error) {
        showFeedback("Erro: " + error.message, false);
    }
}

// ============================================
// MODAL DE PERGUNTAS
// ============================================
async function mostrarPerguntas(nivelId, titulo) {
    currentNivelId = nivelId;
    const modal = document.getElementById('questionsModal');
    const questionsList = document.getElementById('questionsList');
    document.getElementById('questionsModalTitle').innerHTML = `<i class="fas fa-question-circle mr-2"></i>Perguntas - ${escapeHtml(titulo)}`;
    
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    questionsList.innerHTML = '<div class="text-center py-4"><i class="fas fa-spinner fa-spin mr-2"></i>Carregando...</div>';

    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`/perguntas?nivel_id=${nivelId}`, {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        
        const data = await response.json();
        const perguntas = data.perguntas || data;
        
        if (!perguntas || perguntas.length === 0) {
            questionsList.innerHTML = '<div class="text-center text-gray-500 py-4">Nenhuma pergunta cadastrada.</div>';
            return;
        }
        
        questionsList.innerHTML = perguntas.map(p => `
            <div class="pergunta-card">
                <div class="flex justify-between items-start flex-wrap gap-2">
                    <div class="flex-1">
                        <p class="font-semibold mb-2">📝 ${escapeHtml(p.texto)}</p>
                        <div class="space-y-1 ml-4">
                            <div class="opcao-item ${p.resposta_correta === 'opcao1' ? 'opcao-correta' : 'opcao-normal'}">
                                <span class="font-bold w-8">A)</span> ${escapeHtml(p.opcao1)}
                                ${p.resposta_correta === 'opcao1' ? '<span class="ml-auto text-green-600 text-sm"><i class="fas fa-check-circle"></i> Correta</span>' : ''}
                            </div>
                            <div class="opcao-item ${p.resposta_correta === 'opcao2' ? 'opcao-correta' : 'opcao-normal'}">
                                <span class="font-bold w-8">B)</span> ${escapeHtml(p.opcao2)}
                                ${p.resposta_correta === 'opcao2' ? '<span class="ml-auto text-green-600 text-sm"><i class="fas fa-check-circle"></i> Correta</span>' : ''}
                            </div>
                            <div class="opcao-item ${p.resposta_correta === 'opcao3' ? 'opcao-correta' : 'opcao-normal'}">
                                <span class="font-bold w-8">C)</span> ${escapeHtml(p.opcao3)}
                                ${p.resposta_correta === 'opcao3' ? '<span class="ml-auto text-green-600 text-sm"><i class="fas fa-check-circle"></i> Correta</span>' : ''}
                            </div>
                        </div>
                    </div>
                    <div class="flex gap-2">
                        <button onclick="editarPergunta(${p.id})" class="bg-blue-500 text-white px-3 py-1 rounded hover:bg-blue-600 text-sm">
                            <i class="fas fa-edit"></i> Editar
                        </button>
                        <button onclick="excluirPergunta(${p.id})" class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600 text-sm">
                            <i class="fas fa-trash"></i> Excluir
                        </button>
                    </div>
                </div>
            </div>
        `).join('');
    } catch (error) {
        questionsList.innerHTML = `<div class="text-red-500 text-center py-4">Erro: ${error.message}</div>`;
    }
    
    document.querySelectorAll('#questionsModal .closeQuestionsModal').forEach(btn => {
        btn.onclick = () => modal.classList.add('hidden');
    });
}

// ============================================
// EDITAR PERGUNTA
// ============================================
window.editarPergunta = async (perguntaId) => {
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`/perguntas/${perguntaId}`, {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        const p = await response.json();
        
        currentEditPerguntaId = perguntaId;
        document.getElementById('editTexto').value = p.texto;
        document.getElementById('editOpcao1').value = p.opcao1;
        document.getElementById('editOpcao2').value = p.opcao2;
        document.getElementById('editOpcao3').value = p.opcao3;
        document.getElementById('editRespostaCorreta').value = p.resposta_correta;
        
        document.getElementById('editQuestionModal').classList.remove('hidden');
        document.getElementById('editQuestionModal').classList.add('flex');
        document.getElementById('questionsModal').classList.add('hidden');
    } catch (error) {
        showFeedback("Erro ao carregar pergunta: " + error.message, false);
    }
};

document.getElementById('editQuestionForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const dados = {
        texto: document.getElementById('editTexto').value,
        opcao1: document.getElementById('editOpcao1').value,
        opcao2: document.getElementById('editOpcao2').value,
        opcao3: document.getElementById('editOpcao3').value,
        resposta_correta: document.getElementById('editRespostaCorreta').value
    };
    
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`/perguntas/${currentEditPerguntaId}`, {
            method: "PUT",
            headers: {
                "Content-Type": "application/json",
                "Authorization": `Bearer ${token}`
            },
            body: JSON.stringify(dados)
        });
        
        if (!response.ok) throw new Error("Erro ao salvar");
        
        showFeedback("Pergunta atualizada!", true);
        document.getElementById('editQuestionModal').classList.add('hidden');
        
        if (currentNivelId) {
            const nivel = niveisOrdenados.find(n => n.id === currentNivelId);
            if (nivel) mostrarPerguntas(currentNivelId, nivel.titulo);
        }
    } catch (error) {
        showFeedback("Erro: " + error.message, false);
    }
});

// ============================================
// EXCLUIR PERGUNTA
// ============================================
window.excluirPergunta = async (perguntaId) => {
    if (!confirm("Excluir esta pergunta? Esta ação não pode ser desfeita.")) return;
    
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`/perguntas/${perguntaId}`, {
            method: "DELETE",
            headers: { 'Authorization': `Bearer ${token}` }
        });
        
        if (!response.ok) throw new Error("Erro ao excluir");
        
        showFeedback("Pergunta excluída!", true);
        
        if (currentNivelId) {
            const nivel = niveisOrdenados.find(n => n.id === currentNivelId);
            if (nivel) mostrarPerguntas(currentNivelId, nivel.titulo);
        }
    } catch (error) {
        showFeedback("Erro: " + error.message, false);
    }
};

// ============================================
// FECHAR MODAIS
// ============================================
document.getElementById('cancelEditBtn')?.addEventListener('click', () => {
    document.getElementById('editQuestionModal').classList.add('hidden');
    if (currentNivelId) {
        const nivel = niveisOrdenados.find(n => n.id === currentNivelId);
        if (nivel) mostrarPerguntas(currentNivelId, nivel.titulo);
    }
});

document.querySelectorAll('#editQuestionModal .closeEditModal').forEach(btn => {
    btn.onclick = () => {
        document.getElementById('editQuestionModal').classList.add('hidden');
        if (currentNivelId) {
            const nivel = niveisOrdenados.find(n => n.id === currentNivelId);
            if (nivel) mostrarPerguntas(currentNivelId, nivel.titulo);
        }
    };
});

// ============================================
// LOGOUT
// ============================================
document.getElementById('logoutButton')?.addEventListener('click', () => {
    if (confirm('Sair do sistema?')) {
        localStorage.removeItem('token');
        window.location.href = '/';
    }
});

// ============================================
// INICIALIZAR
// ============================================
document.addEventListener('DOMContentLoaded', () => {
    const token = localStorage.getItem('token');
    if (!token) {
        window.location.href = '/';
        return;
    }
    carregarNiveis();
});
</script>