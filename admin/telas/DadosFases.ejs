<script>
// Função para exibir mensagens de feedback
function showFeedback(message, isError = true) {
    const feedbackDiv = document.createElement('div');
    feedbackDiv.className = `fixed bottom-4 right-4 p-4 rounded-lg shadow-lg ${isError ? 'bg-red-500' : 'bg-green-500'} text-white z-50 transition-opacity duration-300`;
    feedbackDiv.textContent = message;
    document.body.appendChild(feedbackDiv);
    setTimeout(() => feedbackDiv.remove(), 3000);
}

// Função auxiliar para escapar HTML
function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

let currentNivelId = null;
let currentEditPerguntaId = null;
let niveisOrdenados = [];

// Inicialização
document.addEventListener("DOMContentLoaded", () => {
    const token = localStorage.getItem('token');
    console.log('Token on load:', token ? 'Presente' : 'Ausente');

    if (!token) {
        showFeedback("Você precisa estar logado para acessar esta página.");
        setTimeout(() => {
            window.location.href = "/";
        }, 1500);
        return;
    }

    fetchNiveis();
});

// Buscar níveis
async function fetchNiveis() {
    try {
        const token = localStorage.getItem('token');
        console.log('Buscando níveis...');
        const response = await fetch('http://localhost:3000/niveis', {
            headers: { "Authorization": `Bearer ${token}` }
        });
        
        if (!response.ok) {
            if (response.status === 401) {
                localStorage.removeItem('token');
                showFeedback("Sessão expirada. Faça login novamente.");
                setTimeout(() => window.location.href = "/", 1500);
                return;
            }
            throw new Error("Erro ao buscar níveis");
        }
        
        const data = await response.json();
        console.log('Níveis recebidos:', data);
        niveisOrdenados = data.niveis || data;
        renderNiveis(niveisOrdenados);
    } catch (error) {
        console.error("Erro ao buscar níveis:", error);
        showFeedback("Erro ao buscar níveis: " + error.message);
    }
}

// Renderizar níveis
function renderNiveis(niveis) {
    const niveisList = document.getElementById('niveisList');
    
    if (!niveis || niveis.length === 0) {
        niveisList.innerHTML = '<li class="text-center text-gray-500 p-4">Nenhum nível cadastrado.</li>';
        return;
    }
    
    niveisList.innerHTML = niveis.map((nivel, index) => `
        <li class="nivel-item bg-gray-100 p-4 rounded-lg shadow-md" data-id="${nivel.id}" data-index="${index}">
            <div class="flex justify-between items-center flex-wrap gap-2">
                <div class="flex items-center gap-3 flex-1">
                    <i class="fas fa-grip-vertical ordem-handle text-gray-400 hover:text-blue-500 cursor-move"></i>
                    <div>
                        <span class="font-bold text-lg">${escapeHtml(nivel.titulo)}</span>
                        ${nivel.posicao ? `<span class="text-sm text-gray-500 ml-2">(Pos: ${nivel.posicao})</span>` : ''}
                        <span class="text-sm ml-2 px-2 py-1 rounded ${nivel.ativo ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}">
                            ${nivel.ativo ? 'Ativo' : 'Inativo'}
                        </span>
                    </div>
                </div>
                <div class="flex gap-2">
                    <button class="bg-blue-500 text-white px-3 py-1 rounded-lg hover:bg-blue-600 transition text-sm btn-primary" onclick="showDetails(${nivel.id})">
                        <i class="fas fa-info-circle mr-1"></i>Detalhes
                    </button>
                    <button class="bg-purple-500 text-white px-3 py-1 rounded-lg hover:bg-purple-600 transition text-sm btn-primary" onclick="showQuestions(${nivel.id}, '${escapeHtml(nivel.titulo)}')">
                        <i class="fas fa-question-circle mr-1"></i>Perguntas
                    </button>
                    <button class="bg-yellow-500 text-white px-3 py-1 rounded-lg hover:bg-yellow-600 transition text-sm btn-primary" onclick="showStatusModal(${nivel.id}, '${escapeHtml(nivel.titulo)}', ${nivel.ativo})">
                        <i class="fas fa-toggle-${nivel.ativo ? 'on' : 'off'} mr-1"></i>Situação
                    </button>
                </div>
            </div>
            <div id="details${nivel.id}" class="mt-4 hidden fade-in">
                <p class="text-gray-600"><strong>Descrição:</strong> ${escapeHtml(nivel.descricao || 'Sem descrição')}</p>
                <p class="text-gray-600"><strong>XP Total:</strong> ${nivel.xp_total || 'Não definido'}</p>
            </div>
        </li>
    `).join('');

    setupDragAndDrop();
}

// Configurar Drag and Drop
function setupDragAndDrop() {
    const items = document.querySelectorAll('#niveisList .nivel-item');
    let draggedItem = null;

    items.forEach(item => {
        item.setAttribute('draggable', 'true');
        
        item.addEventListener('dragstart', (e) => {
            draggedItem = item;
            item.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
        });

        item.addEventListener('dragend', (e) => {
            item.classList.remove('dragging');
            draggedItem = null;
            document.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
        });

        item.addEventListener('dragover', (e) => {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
        });

        item.addEventListener('dragenter', (e) => {
            e.preventDefault();
            if (draggedItem !== item) {
                item.classList.add('drag-over');
            }
        });

        item.addEventListener('dragleave', (e) => {
            item.classList.remove('drag-over');
        });

        item.addEventListener('drop', (e) => {
            e.preventDefault();
            item.classList.remove('drag-over');
            
            if (draggedItem && draggedItem !== item) {
                const parent = document.getElementById('niveisList');
                const draggedIndex = Array.from(parent.children).indexOf(draggedItem);
                const targetIndex = Array.from(parent.children).indexOf(item);
                
                if (draggedIndex < targetIndex) {
                    parent.insertBefore(draggedItem, item.nextSibling);
                } else {
                    parent.insertBefore(draggedItem, item);
                }
                
                // Atualizar array de níveis ordenados
                const newOrder = Array.from(parent.children).map(li => parseInt(li.dataset.id));
                niveisOrdenados = newOrder.map(id => niveisOrdenados.find(n => n.id === id)).filter(Boolean);
            }
        });
    });
}

// Salvar ordem
document.getElementById('ordenarBtn')?.addEventListener('click', async () => {
    try {
        const token = localStorage.getItem('token');
        const items = document.querySelectorAll('#niveisList .nivel-item');
        const ordem = Array.from(items).map((item, index) => ({
            id: parseInt(item.dataset.id),
            ordem: index + 1
        }));

        console.log('Salvando ordem:', ordem);
        
        const response = await fetch("http://localhost:3000/niveis/ordenar", {
            method: "PUT",
            headers: {
                "Content-Type": "application/json",
                "Authorization": `Bearer ${token}`
            },
            body: JSON.stringify({ ordem })
        });

        if (!response.ok) throw new Error("Erro ao salvar ordem");
        
        showFeedback("Ordem dos níveis salva com sucesso!", false);
        fetchNiveis();
    } catch (error) {
        console.error("Erro ao salvar ordem:", error);
        showFeedback("Erro ao salvar ordem: " + error.message);
    }
});

// Mostrar detalhes
function showDetails(nivelId) {
    const details = document.getElementById(`details${nivelId}`);
    if (details) {
        details.classList.toggle('hidden');
        if (!details.classList.contains('hidden')) {
            details.classList.add('fade-in');
            details.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
    }
}

// Modal de Situação
async function showStatusModal(nivelId, titulo, ativo) {
    currentNivelId = nivelId;
    const modal = document.getElementById('statusModal');
    const statusContent = document.getElementById('statusContent');
    const positionInput = document.getElementById('positionInput');
    const posicaoInput = document.getElementById('posicao');
    const toggleStatusButton = document.getElementById('toggleStatusButton');
    const saveChangesButton = document.getElementById('saveChangesButton');

    positionInput.classList.add('hidden');
    toggleStatusButton.classList.remove('hidden');
    saveChangesButton.classList.add('hidden');
    modal.style.display = "block";

    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`http://localhost:3000/niveis/${nivelId}`, {
            headers: { "Authorization": `Bearer ${token}` }
        });
        
        if (!response.ok) throw new Error("Erro ao buscar dados");
        const data = await response.json();

        statusContent.innerHTML = `
            <p class="text-gray-600 mb-2"><strong>Nível:</strong> ${escapeHtml(data.titulo)}</p>
            <p class="text-gray-600 mb-2"><strong>Situação Atual:</strong> 
                <span class="font-bold ${data.ativo ? 'text-green-600' : 'text-red-600'}">${data.ativo ? 'Ativo' : 'Inativo'}</span>
            </p>
            ${data.ativo && data.posicao ? `<p class="text-gray-600"><strong>Posição:</strong> ${data.posicao}</p>` : ''}
        `;

        toggleStatusButton.textContent = data.ativo ? 'Desativar Nível' : 'Ativar Nível';
        toggleStatusButton.className = data.ativo ? 
            'bg-red-500 text-white px-4 py-2 rounded mt-4 hover:bg-red-600 transition w-full' : 
            'bg-green-500 text-white px-4 py-2 rounded mt-4 hover:bg-green-600 transition w-full';
        
        toggleStatusButton.onclick = async () => {
            if (!data.ativo) {
                positionInput.classList.remove('hidden');
                toggleStatusButton.classList.add('hidden');
                saveChangesButton.classList.remove('hidden');
                posicaoInput.value = "";
            } else {
                if (confirm(`Desativar o nível "${data.titulo}"?`)) {
                    await toggleNivelStatus(nivelId, false, null);
                    modal.style.display = "none";
                }
            }
        };

        saveChangesButton.onclick = async () => {
            const novaPosicao = parseInt(posicaoInput.value);
            if (!novaPosicao || novaPosicao <= 0) {
                showFeedback("Informe uma posição válida.");
                return;
            }
            await toggleNivelStatus(nivelId, true, novaPosicao);
            modal.style.display = "none";
        };
    } catch (error) {
        statusContent.innerHTML = "<p class='text-red-500'>Erro ao carregar detalhes.</p>";
    }

    const closeBtn = document.querySelector('#statusModal .close');
    if (closeBtn) closeBtn.onclick = () => modal.style.display = "none";
    window.onclick = (event) => { if (event.target == modal) modal.style.display = "none"; };
}

async function toggleNivelStatus(nivelId, ativo, posicao) {
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`http://localhost:3000/niveis/${nivelId}/ativar`, {
            method: "PUT",
            headers: {
                "Content-Type": "application/json",
                "Authorization": `Bearer ${token}`
            },
            body: JSON.stringify({ ativo, posicao })
        });
        
        if (!response.ok) throw new Error("Erro ao alterar status");
        const result = await response.json();
        showFeedback(result.message || `Nível ${ativo ? 'ativado' : 'desativado'} com sucesso!`, false);
        fetchNiveis();
    } catch (error) {
        showFeedback("Erro ao alterar status: " + error.message);
    }
}

// Mostrar perguntas
async function showQuestions(nivelId, titulo) {
    currentNivelId = nivelId;
    const modal = document.getElementById('questionsModal');
    const questionsList = document.getElementById('questionsList');
    document.getElementById('questionsModalTitle').innerHTML = `<i class="fas fa-question-circle mr-2"></i>Perguntas - ${escapeHtml(titulo)}`;
    
    modal.style.display = "block";
    questionsList.innerHTML = '<div class="text-center py-4"><i class="fas fa-spinner fa-spin mr-2"></i>Carregando perguntas...</div>';

    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`http://localhost:3000/perguntas?nivel_id=${nivelId}`, {
            headers: { "Authorization": `Bearer ${token}` }
        });
        
        if (!response.ok) throw new Error("Erro ao buscar perguntas");
        const data = await response.json();
        const perguntas = data.perguntas || data;
        
        if (!perguntas || perguntas.length === 0) {
            questionsList.innerHTML = '<div class="text-center text-gray-500 py-4">Nenhuma pergunta cadastrada para este nível.</div>';
            return;
        }
        
        questionsList.innerHTML = perguntas.map(pergunta => `
            <div class="pergunta-card">
                <div class="flex justify-between items-start">
                    <div class="flex-1">
                        <p class="font-semibold text-gray-800 mb-2">📝 ${escapeHtml(pergunta.texto)}</p>
                        <div class="space-y-1 ml-4">
                            <div class="opcao-item ${pergunta.resposta_correta === 'opcao1' ? 'opcao-correta' : 'opcao-normal'}">
                                <span class="font-bold w-8">A)</span> ${escapeHtml(pergunta.opcao1)}
                                ${pergunta.resposta_correta === 'opcao1' ? '<span class="ml-auto text-green-600 text-sm"><i class="fas fa-check-circle"></i> Correta</span>' : ''}
                            </div>
                            <div class="opcao-item ${pergunta.resposta_correta === 'opcao2' ? 'opcao-correta' : 'opcao-normal'}">
                                <span class="font-bold w-8">B)</span> ${escapeHtml(pergunta.opcao2)}
                                ${pergunta.resposta_correta === 'opcao2' ? '<span class="ml-auto text-green-600 text-sm"><i class="fas fa-check-circle"></i> Correta</span>' : ''}
                            </div>
                            <div class="opcao-item ${pergunta.resposta_correta === 'opcao3' ? 'opcao-correta' : 'opcao-normal'}">
                                <span class="font-bold w-8">C)</span> ${escapeHtml(pergunta.opcao3)}
                                ${pergunta.resposta_correta === 'opcao3' ? '<span class="ml-auto text-green-600 text-sm"><i class="fas fa-check-circle"></i> Correta</span>' : ''}
                            </div>
                        </div>
                    </div>
                    <div class="flex gap-2 ml-4">
                        <button onclick="editPergunta(${pergunta.id})" class="bg-blue-500 text-white px-3 py-1 rounded hover:bg-blue-600 text-sm">
                            <i class="fas fa-edit"></i> Editar
                        </button>
                        <button onclick="deletePergunta(${pergunta.id})" class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600 text-sm">
                            <i class="fas fa-trash"></i> Excluir
                        </button>
                    </div>
                </div>
            </div>
        `).join('');
    } catch (error) {
        questionsList.innerHTML = `<div class="text-red-500 text-center py-4">Erro: ${error.message}</div>`;
    }
    
    document.querySelector('#questionsModal .close-questions').onclick = () => modal.style.display = "none";
    window.onclick = (event) => { if (event.target == modal) modal.style.display = "none"; };
}

// Editar pergunta
window.editPergunta = async (perguntaId) => {
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`http://localhost:3000/perguntas/${perguntaId}`, {
            headers: { "Authorization": `Bearer ${token}` }
        });
        
        if (!response.ok) throw new Error("Erro ao buscar pergunta");
        const pergunta = await response.json();
        
        currentEditPerguntaId = perguntaId;
        document.getElementById('editTexto').value = pergunta.texto;
        document.getElementById('editOpcao1').value = pergunta.opcao1;
        document.getElementById('editOpcao2').value = pergunta.opcao2;
        document.getElementById('editOpcao3').value = pergunta.opcao3;
        document.getElementById('editRespostaCorreta').value = pergunta.resposta_correta;
        
        document.getElementById('editQuestionModal').style.display = "block";
        document.getElementById('questionsModal').style.display = "none";
    } catch (error) {
        showFeedback("Erro ao carregar pergunta: " + error.message);
    }
};

// Salvar edição
document.getElementById('editQuestionForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const updatedPergunta = {
        texto: document.getElementById('editTexto').value,
        opcao1: document.getElementById('editOpcao1').value,
        opcao2: document.getElementById('editOpcao2').value,
        opcao3: document.getElementById('editOpcao3').value,
        resposta_correta: document.getElementById('editRespostaCorreta').value
    };
    
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`http://localhost:3000/perguntas/${currentEditPerguntaId}`, {
            method: "PUT",
            headers: {
                "Content-Type": "application/json",
                "Authorization": `Bearer ${token}`
            },
            body: JSON.stringify(updatedPergunta)
        });
        
        if (!response.ok) throw new Error("Erro ao salvar alterações");
        
        showFeedback("Pergunta atualizada com sucesso!", false);
        document.getElementById('editQuestionModal').style.display = "none";
        
        if (currentNivelId) {
            const nivel = niveisOrdenados.find(n => n.id === currentNivelId);
            if (nivel) showQuestions(currentNivelId, nivel.titulo);
        }
    } catch (error) {
        showFeedback("Erro ao salvar: " + error.message);
    }
});

// Excluir pergunta
window.deletePergunta = async (perguntaId) => {
    if (!confirm("Tem certeza que deseja excluir esta pergunta? Esta ação não pode ser desfeita.")) return;
    
    try {
        const token = localStorage.getItem('token');
        const response = await fetch(`http://localhost:3000/perguntas/${perguntaId}`, {
            method: "DELETE",
            headers: { "Authorization": `Bearer ${token}` }
        });
        
        if (!response.ok) throw new Error("Erro ao excluir pergunta");
        
        showFeedback("Pergunta excluída com sucesso!", false);
        
        if (currentNivelId) {
            const nivel = niveisOrdenados.find(n => n.id === currentNivelId);
            if (nivel) showQuestions(currentNivelId, nivel.titulo);
        }
    } catch (error) {
        showFeedback("Erro ao excluir: " + error.message);
    }
};

// Fechar modais de edição
document.getElementById('cancelEditBtn')?.addEventListener('click', () => {
    document.getElementById('editQuestionModal').style.display = "none";
    if (currentNivelId) {
        const nivel = niveisOrdenados.find(n => n.id === currentNivelId);
        if (nivel) showQuestions(currentNivelId, nivel.titulo);
    }
});

document.querySelector('#editQuestionModal .close-edit')?.addEventListener('click', () => {
    document.getElementById('editQuestionModal').style.display = "none";
    if (currentNivelId) {
        const nivel = niveisOrdenados.find(n => n.id === currentNivelId);
        if (nivel) showQuestions(currentNivelId, nivel.titulo);
    }
});

// Logout
const logoutBtn = document.getElementById('logoutButton');
if (logoutBtn) {
    logoutBtn.addEventListener('click', () => {
        console.log('Efetuando logout...');
        if (confirm('Tem certeza que deseja sair?')) {
            localStorage.removeItem('token');
            window.location.href = "/";
        }
    });
}
</script>