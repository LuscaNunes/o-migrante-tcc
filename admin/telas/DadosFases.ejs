<div class="flex-1 p-8 slide-in">
    <div class="flex justify-between items-center mb-6">
        <h2 class="text-2xl font-bold">Gerenciamento de Níveis</h2>
        <button id="logoutButton" class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600 transition">Sair</button>
    </div>

    <!-- Botão de Ordenação -->
    <div class="mb-4 flex justify-end">
        <button id="ordenarBtn" class="bg-green-500 text-white px-4 py-2 rounded-lg hover:bg-green-600 transition shadow-md">
            <i class="fas fa-sort mr-2"></i>Salvar Ordem dos Níveis
        </button>
    </div>

    <!-- Lista de Níveis -->
    <div id="niveisContainer" class="bg-white p-6 rounded-lg shadow-lg">
        <h3 class="text-xl font-bold mb-4">Níveis Cadastrados</h3>
        <ul id="niveisList" class="space-y-4">
            <!-- Níveis serão carregados dinamicamente aqui -->
        </ul>
    </div>
</div>

<!-- Modal de Situação (Ativar/Desativar) -->
<div id="statusModal" class="modal">
    <div class="modal-content">
        <span class="close">&times;</span>
        <h2 class="text-xl font-bold mb-4">Situação do Nível</h2>
        <div id="statusContent">
            <!-- Conteúdo da situação será carregado aqui -->
        </div>
        <div id="positionInput" class="hidden">
            <label for="posicao" class="block text-gray-700 font-bold mb-2">Posição:</label>
            <input type="number" id="posicao" class="w-full p-2 border rounded" placeholder="Informe a posição" />
        </div>
        <button id="toggleStatusButton" class="bg-red-500 text-white px-4 py-2 rounded mt-4 hover:bg-red-600 transition">
            Desativar
        </button>
        <button id="saveChangesButton" class="hidden bg-blue-500 text-white px-4 py-2 rounded mt-4 hover:bg-blue-600 transition">
            Salvar Alterações
        </button>
    </div>
</div>

<!-- Modal de Perguntas -->
<div id="questionsModal" class="modal">
    <div class="modal-content" style="max-width: 700px;">
        <span class="close-questions">&times;</span>
        <h2 class="text-xl font-bold mb-4" id="questionsModalTitle">Perguntas do Nível</h2>
        <div id="questionsList" class="max-h-96 overflow-y-auto">
            <!-- Perguntas serão carregadas aqui -->
        </div>
    </div>
</div>

<!-- Modal de Editar Pergunta -->
<div id="editQuestionModal" class="modal">
    <div class="modal-content">
        <span class="close-edit">&times;</span>
        <h2 class="text-xl font-bold mb-4">Editar Pergunta</h2>
        <form id="editQuestionForm">
            <div class="mb-3">
                <label class="block text-gray-700 font-bold mb-2">Texto da Pergunta:</label>
                <textarea id="editTexto" rows="3" class="w-full p-2 border rounded" required></textarea>
            </div>
            <div class="mb-3">
                <label class="block text-gray-700 font-bold mb-2">Opção 1:</label>
                <input type="text" id="editOpcao1" class="w-full p-2 border rounded" required>
            </div>
            <div class="mb-3">
                <label class="block text-gray-700 font-bold mb-2">Opção 2:</label>
                <input type="text" id="editOpcao2" class="w-full p-2 border rounded" required>
            </div>
            <div class="mb-3">
                <label class="block text-gray-700 font-bold mb-2">Opção 3:</label>
                <input type="text" id="editOpcao3" class="w-full p-2 border rounded" required>
            </div>
            <div class="mb-3">
                <label class="block text-gray-700 font-bold mb-2">Resposta Correta:</label>
                <select id="editRespostaCorreta" class="w-full p-2 border rounded" required>
                    <option value="">Selecione a resposta correta</option>
                    <option value="opcao1">Opção 1</option>
                    <option value="opcao2">Opção 2</option>
                    <option value="opcao3">Opção 3</option>
                </select>
            </div>
            <div class="flex gap-2 mt-4">
                <button type="submit" class="flex-1 bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 transition">Salvar</button>
                <button type="button" id="cancelEditBtn" class="flex-1 bg-gray-500 text-white px-4 py-2 rounded hover:bg-gray-600 transition">Cancelar</button>
            </div>
        </form>
    </div>
</div>

