<%
  // Esta página será injetada no layout.ejs como 'body'
  // O objeto 'user' já vem do server.js
  title = "Admin - Busca e Edição de Usuários - O Migrante";
%>

<style>
  /* Estilos específicos para a página de busca de usuários */
  .spinner {
    border-top-color: #3b82f6;
    border-left-color: #3b82f6;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* Ajustes para tabela responsiva */
  .table-container {
    overflow-x: auto;
    margin-top: 1rem;
  }

  .user-table {
    min-width: 100%;
    background: white;
    border-collapse: collapse;
  }

  .user-table th {
    padding: 0.75rem 1rem;
    text-align: left;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #4B5563;
    background-color: #F9FAFB;
    border-bottom: 1px solid #E5E7EB;
  }

  .user-table td {
    padding: 0.75rem 1rem;
    text-align: left;
    font-size: 0.875rem;
    color: #1F2937;
    border-bottom: 1px solid #F3F4F6;
  }

  .user-table tr:hover {
    background-color: #F9FAFB;
  }

  /* Botões de ação */
  .btn-edit {
    background-color: #3B82F6;
    color: white;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    border-radius: 0.5rem;
    transition: all 0.15s;
    border: none;
    cursor: pointer;
  }

  .btn-edit:hover {
    background-color: #2563EB;
    transform: translateY(-1px);
  }

  .btn-delete {
    background-color: #DC2626;
    color: white;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    border-radius: 0.5rem;
    transition: all 0.15s;
    border: none;
    cursor: pointer;
    margin-left: 0.5rem;
  }

  .btn-delete:hover {
    background-color: #B91C1C;
    transform: translateY(-1px);
  }

  /* Modal */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .modal-overlay.hidden {
    display: none;
  }

  .modal-box {
    background: white;
    border-radius: 1rem;
    padding: 1.75rem;
    width: 100%;
    max-width: 28rem;
  }

  /* Loading overlay */
  .loading-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .loading-overlay.hidden {
    display: none;
  }

  /* Toast */
  .toast {
    position: fixed;
    bottom: 1.5rem;
    right: 1rem;
    padding: 0.875rem 1.25rem;
    border-radius: 0.75rem;
    color: white;
    font-weight: 600;
    font-size: 0.875rem;
    z-index: 1100;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    animation: slideUp 0.3s ease;
  }

  @keyframes slideUp {
    from {
      transform: translateY(2rem);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  /* Cards */
  .admin-card {
    background: white;
    border-radius: 1rem;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.07), 0 4px 16px rgba(37, 99, 235, 0.06);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  /* Formulários */
  .form-input {
    width: 100%;
    padding: 0.625rem 0.875rem;
    border: 1px solid #E5E7EB;
    border-radius: 0.625rem;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.18s;
  }

  .form-input:focus {
    border-color: #2563EB;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  .form-label {
    display: block;
    color: #374151;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .btn-primary {
    background-color: #2563EB;
    color: white;
    padding: 0.5rem 1.5rem;
    border-radius: 0.75rem;
    transition: all 0.15s;
    border: none;
    cursor: pointer;
  }

  .btn-primary:hover {
    background-color: #1D4ED8;
    transform: translateY(-1px);
  }

  .btn-success {
    background-color: #10B981;
    color: white;
    padding: 0.5rem 1.5rem;
    border-radius: 0.75rem;
    transition: all 0.15s;
    border: none;
    cursor: pointer;
  }

  .btn-success:hover {
    background-color: #059669;
    transform: translateY(-1px);
  }

  .btn-secondary {
    background-color: #6B7280;
    color: white;
    padding: 0.5rem 1.5rem;
    border-radius: 0.75rem;
    transition: all 0.15s;
    border: none;
    cursor: pointer;
  }

  .btn-secondary:hover {
    background-color: #4B5563;
    transform: translateY(-1px);
  }

  /* Grid */
  .form-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .form-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

<!-- Loading Overlay -->
<div id="loadingOverlay" class="loading-overlay hidden">
  <div class="spinner w-12 h-12 border-4 border-dashed rounded-full"></div>
</div>

<!-- Modal de Confirmação -->
<div id="confirmationModal" class="modal-overlay hidden">
  <div class="modal-box">
    <h3 class="text-xl font-bold mb-4 text-red-600">Confirmar Deleção</h3>
    <p id="confirmationMessage" class="mb-6 text-gray-700">Tem certeza que deseja deletar este usuário?</p>
    <div class="flex justify-end gap-3">
      <button id="cancelDeleteButton" class="btn-secondary">Cancelar</button>
      <button id="confirmDeleteButton" class="btn-primary" style="background-color:#DC2626;">Deletar</button>
    </div>
  </div>
</div>

<div>
  <!-- Título da Página -->
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900 flex items-center">
      <i class="fas fa-users-cog text-blue-600 mr-3"></i>
      Busca e Edição de Usuários
    </h1>
  </div>

  <!-- Formulário de Busca -->
  <div class="admin-card">
    <h2 class="text-xl font-bold mb-4 text-blue-600">Buscar Usuário</h2>
    <form id="buscaUsuarioForm">
      <div class="mb-4">
        <label for="buscaUsuario" class="form-label">ID, Nome ou E-mail:</label>
        <input type="text" id="buscaUsuario" class="form-input" placeholder="Digite o ID, nome ou email do usuário" required>
      </div>
      <button type="submit" class="btn-primary">
        <i class="fas fa-search mr-2"></i> Buscar
      </button>
    </form>
  </div>

  <!-- Tabela de Usuários -->
  <div id="usuariosTable" class="admin-card hidden">
    <h2 class="text-xl font-bold mb-4 text-blue-600">Resultados</h2>
    <div class="table-container">
      <table class="user-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Nome</th>
            <th>Email</th>
            <th>Tipo</th>
            <th>XP Total</th>
            <th>Fase Atual</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody id="usuariosTableBody">
        </tbody>
      </table>
    </div>
  </div>

  <!-- Formulário de Edição -->
  <form id="editaUsuarioForm" class="admin-card hidden">
    <h2 class="text-xl font-bold mb-4 text-green-600">
      <i class="fas fa-edit mr-2"></i> Editar Usuário Selecionado
    </h2>
    <input type="hidden" id="editaUsuarioId">
    
    <div class="form-grid">
      <div>
        <label for="editaUsuarioNome" class="form-label">Nome Completo:</label>
        <input type="text" id="editaUsuarioNome" class="form-input" required>
      </div>
      <div>
        <label for="editaUsuarioEmail" class="form-label">Email:</label>
        <input type="email" id="editaUsuarioEmail" class="form-input" required>
      </div>
      <div>
        <label for="editaUsuarioTipo" class="form-label">Tipo de Conta:</label>
        <select id="editaUsuarioTipo" class="form-input" required>
          <option value="user">Usuário Comum</option>
          <option value="admin">Administrador</option>
        </select>
      </div>
      <div>
        <label for="editaUsuarioXpTotal" class="form-label">XP Total:</label>
        <input type="number" id="editaUsuarioXpTotal" class="form-input" required>
      </div>
      <div>
        <label for="editaUsuarioFaseAtual" class="form-label">Fase Atual:</label>
        <input type="number" id="editaUsuarioFaseAtual" class="form-input" required>
      </div>
    </div>
    
    <div class="mt-6 flex gap-3">
      <button type="submit" class="btn-success">
        <i class="fas fa-save mr-2"></i> Salvar Alterações
      </button>
      <button type="reset" class="btn-secondary">
        <i class="fas fa-times mr-2"></i> Cancelar
      </button>
    </div>
  </form>
</div>

<script>
  (function() {
    const API_BASE_URL = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
      ? `http://${window.location.hostname}:${window.location.port || 3000}`
      : 'https://o-migrante.onrender.com';
    
    const API_USER_PATH = '/usuarios';
    
    let lastSearchedUsers = [];
    let userIdToDelete = null;

    function showFeedback(message, isError = true) {
      const existingFeedback = document.querySelector('.toast');
      if (existingFeedback) existingFeedback.remove();

      const toast = document.createElement('div');
      toast.className = 'toast';
      toast.style.background = isError ? '#DC2626' : '#10B981';
      toast.textContent = message;
      document.body.appendChild(toast);
      
      setTimeout(() => {
        toast.style.opacity = '0';
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }

    function toggleLoading(isLoading) {
      const overlay = document.getElementById('loadingOverlay');
      if (overlay) {
        overlay.classList.toggle('hidden', !isLoading);
      }
    }

    async function makeAuthenticatedRequest(url, options = {}) {
      const opts = {
        credentials: 'include',
        headers: { 'Content-Type': 'application/json', ...options.headers },
        ...options
      };
      const response = await fetch(`${API_BASE_URL}${url}`, opts);
      return response;
    }

    function renderUsuarios(usuarios) {
      const tbody = document.getElementById('usuariosTableBody');
      if (!tbody) return;
      
      tbody.innerHTML = '';
      lastSearchedUsers = usuarios;

      if (!usuarios || usuarios.length === 0) {
        showFeedback("Nenhum usuário encontrado.", true);
        const table = document.getElementById('usuariosTable');
        if (table) table.classList.add('hidden');
        return;
      }

      usuarios.forEach(usuario => {
        const row = document.createElement('tr');
        row.innerHTML = `
          <td>${usuario.id_usuario || '-'}</td>
          <td>${escapeHtml(usuario.nome || '-')}</td>
          <td>${escapeHtml(usuario.email || '-')}</td>
          <td class="capitalize">${usuario.tipo || 'user'}</td>
          <td>${usuario.xp_total || 0}</td>
          <td>${usuario.fase_atual || 1}</td>
          <td class="whitespace-nowrap">
            <button class="btn-edit" data-user-id="${usuario.id_usuario}">
              <i class="fas fa-edit mr-1"></i> Editar
            </button>
            <button class="btn-delete" data-user-id="${usuario.id_usuario}">
              <i class="fas fa-trash mr-1"></i> Deletar
            </button>
          </td>
        `;
        tbody.appendChild(row);
      });

      const table = document.getElementById('usuariosTable');
      if (table) table.classList.remove('hidden');
    }

    function escapeHtml(str) {
      if (!str) return '';
      return str.replace(/[&<>]/g, function(m) {
        if (m === '&') return '&amp;';
        if (m === '<') return '&lt;';
        if (m === '>') return '&gt;';
        return m;
      });
    }

    async function editarUsuario(id) {
      const usuario = lastSearchedUsers.find(u => String(u.id_usuario) === String(id));
      
      if (!usuario) {
        showFeedback("Erro ao carregar dados do usuário.", true);
        return;
      }

      const editId = document.getElementById('editaUsuarioId');
      const editNome = document.getElementById('editaUsuarioNome');
      const editEmail = document.getElementById('editaUsuarioEmail');
      const editTipo = document.getElementById('editaUsuarioTipo');
      const editXpTotal = document.getElementById('editaUsuarioXpTotal');
      const editFaseAtual = document.getElementById('editaUsuarioFaseAtual');
      const editForm = document.getElementById('editaUsuarioForm');

      if (editId) editId.value = usuario.id_usuario || '';
      if (editNome) editNome.value = usuario.nome || '';
      if (editEmail) editEmail.value = usuario.email || '';
      if (editTipo) editTipo.value = usuario.tipo || 'user';
      if (editXpTotal) editXpTotal.value = usuario.xp_total || 0;
      if (editFaseAtual) editFaseAtual.value = usuario.fase_atual || 1;
      if (editForm) editForm.classList.remove('hidden');
      
      const table = document.getElementById('usuariosTable');
      if (table) table.classList.add('hidden');
    }

    function showConfirmationModal(id) {
      const usuario = lastSearchedUsers.find(u => String(u.id_usuario) === String(id));
      if (!usuario) {
        showFeedback("Erro: Não foi possível encontrar o usuário.", true);
        return;
      }

      userIdToDelete = id;
      const messageEl = document.getElementById('confirmationMessage');
      if (messageEl) {
        messageEl.textContent = `Tem certeza que deseja deletar o usuário "${usuario.nome}" (ID: ${id})? Esta ação é irreversível.`;
      }
      const modal = document.getElementById('confirmationModal');
      if (modal) modal.classList.remove('hidden');
    }

    async function deleteUsuario(id) {
      toggleLoading(true);
      try {
        const response = await makeAuthenticatedRequest(`${API_USER_PATH}/${id}`, {
          method: "DELETE"
        });

        if (!response.ok) {
          const errorData = await response.json().catch(() => ({}));
          throw new Error(errorData.message || `Erro ao deletar (Status: ${response.status})`);
        }

        showFeedback("Usuário deletado com sucesso!", false);
        
        const buscaInput = document.getElementById('buscaUsuario');
        if (buscaInput && buscaInput.value.trim()) {
          document.getElementById('buscaUsuarioForm').dispatchEvent(new Event('submit', { bubbles: true }));
        } else {
          const table = document.getElementById('usuariosTable');
          if (table) table.classList.add('hidden');
          const tbody = document.getElementById('usuariosTableBody');
          if (tbody) tbody.innerHTML = '';
          lastSearchedUsers = [];
        }
      } catch (error) {
        console.error("Erro ao deletar usuário:", error);
        showFeedback("Erro ao deletar usuário: " + error.message, true);
      } finally {
        toggleLoading(false);
      }
    }

    // Event Listeners
    document.addEventListener("DOMContentLoaded", () => {
      // Busca de usuários
      const buscaForm = document.getElementById('buscaUsuarioForm');
      if (buscaForm) {
        buscaForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const busca = document.getElementById('buscaUsuario')?.value.trim();
          
          const editForm = document.getElementById('editaUsuarioForm');
          if (editForm) editForm.classList.add('hidden');
          
          const tbody = document.getElementById('usuariosTableBody');
          if (tbody) tbody.innerHTML = '';

          if (!busca) {
            showFeedback("Por favor, insira um ID, nome ou e-mail para buscar.", true);
            return;
          }

          toggleLoading(true);
          try {
            const urlBusca = `${API_USER_PATH}?busca=${encodeURIComponent(busca)}`;
            const response = await makeAuthenticatedRequest(urlBusca);

            if (!response.ok) {
              throw new Error(`Erro ao buscar usuários (${response.status})`);
            }

            const data = await response.json();
            renderUsuarios(data.usuarios || []);
          } catch (error) {
            console.error("Erro ao buscar usuários:", error);
            showFeedback("Erro ao buscar usuários: " + error.message, true);
          } finally {
            toggleLoading(false);
          }
        });
      }

      // Delegation para botões de editar/deletar
      const tableBody = document.getElementById('usuariosTableBody');
      if (tableBody) {
        tableBody.addEventListener('click', (e) => {
          const editBtn = e.target.closest('.btn-edit');
          const deleteBtn = e.target.closest('.btn-delete');
          
          if (editBtn) {
            const userId = editBtn.getAttribute('data-user-id');
            if (userId) editarUsuario(userId);
          } else if (deleteBtn) {
            const userId = deleteBtn.getAttribute('data-user-id');
            if (userId) showConfirmationModal(userId);
          }
        });
      }

      // Modal de confirmação
      const cancelBtn = document.getElementById('cancelDeleteButton');
      if (cancelBtn) {
        cancelBtn.addEventListener('click', () => {
          const modal = document.getElementById('confirmationModal');
          if (modal) modal.classList.add('hidden');
          userIdToDelete = null;
        });
      }

      const confirmBtn = document.getElementById('confirmDeleteButton');
      if (confirmBtn) {
        confirmBtn.addEventListener('click', () => {
          const modal = document.getElementById('confirmationModal');
          if (modal) modal.classList.add('hidden');
          if (userIdToDelete) {
            deleteUsuario(userIdToDelete);
            userIdToDelete = null;
          }
        });
      }

      // Formulário de edição
      const editForm = document.getElementById('editaUsuarioForm');
      if (editForm) {
        editForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          
          const id = document.getElementById('editaUsuarioId')?.value;
          const nome = document.getElementById('editaUsuarioNome')?.value.trim();
          const email = document.getElementById('editaUsuarioEmail')?.value.trim();
          const tipo = document.getElementById('editaUsuarioTipo')?.value;
          const xp_total = document.getElementById('editaUsuarioXpTotal')?.value;
          const fase_atual = document.getElementById('editaUsuarioFaseAtual')?.value;

          if (!id || !nome || !email || !tipo || !xp_total || !fase_atual) {
            showFeedback("Por favor, preencha todos os campos.", true);
            return;
          }

          const xpTotalNum = parseInt(xp_total);
          const faseAtualNum = parseInt(fase_atual);
          
          if (isNaN(xpTotalNum) || isNaN(faseAtualNum)) {
            showFeedback("XP Total e Fase Atual devem ser números válidos.", true);
            return;
          }
          
          toggleLoading(true);
          try {
            const payload = { nome, email, tipo, xp_total: xpTotalNum, fase_atual: faseAtualNum };
            
            const response = await makeAuthenticatedRequest(`${API_USER_PATH}/${id}`, {
              method: "PUT",
              body: JSON.stringify(payload)
            });

            if (!response.ok) {
              const errorData = await response.json().catch(() => ({}));
              throw new Error(errorData.message || `Erro ao salvar edição (Status: ${response.status})`);
            }
            
            showFeedback("Usuário atualizado com sucesso!", false);
            
            editForm.reset();
            editForm.classList.add('hidden');
            
            const buscaInput = document.getElementById('buscaUsuario');
            if (buscaInput && buscaInput.value.trim()) {
              buscaForm.dispatchEvent(new Event('submit', { bubbles: true }));
            } else {
              const table = document.getElementById('usuariosTable');
              if (table) table.classList.remove('hidden');
            }
          } catch (error) {
            console.error("Erro ao salvar edição:", error);
            showFeedback("Erro ao salvar edição: " + error.message, true);
          } finally {
            toggleLoading(false);
          }
        });

        editForm.addEventListener('reset', () => {
          editForm.classList.add('hidden');
          const table = document.getElementById('usuariosTable');
          if (table) table.classList.remove('hidden');
        });
      }
    });
  })();
</script>